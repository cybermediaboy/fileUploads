string lvg_base_symbol = lvg_auto_symbol ? syminfo.ticker : lvg_manual_symbol
string lvg_premium_base = str.replace(lvg_base_symbol, ".P", "")
bool sep_null_test = false  // release invariant; null experiment moved out
// sep diagnostic gate. Primary = erosion ratio (self-calibrating), baseline
// ratio 0.71 measured K3 jul8 2026-07-08 (seed 2.18 -> live 1.54).
// Secondary absolute floor = null-calibrated (see null run), NOT an EM target.
// The prior green>=1.5 was an AI-proposed heuristic fit to the current model
// and is retired as the primary criterion.
float SEP_ABS_FLOOR = 1.0

type SSSMState
    array<RG.GaussianRegime> regimes
    matrix<float> Pi
    int   active_regime
    int   active_since_bar
    float posterior_active
    float posterior_runner_up
    float log_likelihood
    bool  trained
    RG.PosteriorHistory posterior_history
    // B7 composite output: regime-conditional oscillator centroids.
    array<float> mu_out                // [K] raw regime output centroids in btc_ret_z units
    array<float> mu_out_scored         // [K] scored regime output centroids in [-2, +2]
    array<float> n_out                 // [K] count of bars contributing to each μ_out
    array<float> s_out                 // [K] running sum of btc_ret_z per regime
    // B8 IRF: per-factor regime-conditional responses.
    array<float> mu_out_vix            // [K] regime-conditional VIX response
    array<float> mu_out_horc           // [K] regime-conditional HORC response
    array<float> mu_out_bei            // [K] regime-conditional BEI response

type FactorRingBuffer
    array<float> f1
    array<float> f2
    array<float> f3
    array<float> f5
    array<float> posterior_active_hist
    array<float> adm_weight            // per-slot admission weight (HARD: 0/1, SOFT: [0,1])
    int write_idx
    int count
    int capacity

type IRFCache
    matrix<float> psi_vix
    matrix<float> psi_horc
    matrix<float> psi_bei
    int last_recompute_bar


type TrainingState
    int   phase
    int   phase_offset
    int   em_pass_idx
    int   km_iter_idx
    bool  training_complete
    int   last_train_bar
    int   last_train_time
    array<float> log_lik_history
    array<int>   regime_smoothed

// Per-call-site state holders (replace function-scope `var`; remove ambiguity across
// multi-call sites and align with C6 UDT-state convention).
var SSSMState        sssm     = SSSMState.new()
// SSSM-GUARD: rb.f1/f2/f3 are FACTOR-ONLY ring buffers consumed by SSSM update loop
// in Pass B. NEVER push btc_ret here — BTC must remain isolated to the causality
// layer (te_btc / TE/Granger weights) per TZ §6 and v0.6 acceptance test §17.
var FactorRingBuffer rb       = FactorRingBuffer.new()
var IRFCache         irf_c    = IRFCache.new()
var TrainingState    train_st = TrainingState.new()

// Hamilton forward filter state (B4). α_filt[t][j] = P(s_t = j | x_1..t).
// α_prev mirrors the previous bar's filter — needed for the soft-ξ transition
// counting in the online Π update step.
var array<float> alpha_filt = na
var array<float> alpha_prev = na
var float b2_seed_sep_min_log = na
var int b2_seed_sep_i_log = na
var int b2_seed_sep_j_log = na
var string b2_seed_pairs_log = ""
var string b2_seed_mu_i_log = "na"
var string b2_seed_mu_j_log = "na"
var float b2_train_sil_bar_log = na
var float b2_train_explainable_log = na
var bool frozen_loaded = false
var bool frozen_parse_error = false
var bool frozen_serialized = false
var int parsed_payload_f5 = -1
var int payload_k = -1
var bool payload_f5 = false
var bool schema_ok = false
var string model_source = "B2"

// ─── Regime Admission state ────────────────────────────────────────────────
var int   adm_regime_run_len  = 0       // consecutive bars on current active_regime
var int   adm_prev_regime     = -1      // last-bar's active_regime for run tracking
var array<float> adm_sign_hist = array.new<float>(20, 0.0)  // rolling sign-agree bits
var int   adm_sign_hist_idx   = 0
var array<float> adm_hold_hist = array.new<float>(20, 0.0)  // rolling hold-above-tau bits
var int   adm_hold_hist_idx   = 0
var float adm_weight_now      = 0.0    // current bar's admission weight (export)
var float adm_sign_rate_now   = 0.0    // sign agreement rate (export)

// B6 backward smoother state: smoothed posterior and regime assignment.
var array<float> gamma_smooth = na
var int k_smooth = 0
var float gamma_smooth_max = 0.0  // Max posterior probability from γ_smooth (confidence)
var bool b6_warmup = true          // True until b6_count >= 2 (1-step live smoother)

// Parallel full-Kim ground-truth pass: γ_kim_gt[t] = posterior for bar t-KIM_GT_H.
// Lives alongside the frozen 1-step smoother; never fed to live plots/alerts.
var array<float> gamma_kim_gt = na
var int kim_gt_truncate_bars = KIM_GT_H
// _kim_gt_inv_ok declared at top next to constants; no var needed here.

// Rolling Pi snapshot for the Kim-GT pass (locally-consistent smoothing).
var matrix<float> kim_gt_pi = na

// Session-reset is gap-based (see _kg_transition); no prev-state var needed.

// B7 composite output state: regime-conditional oscillator.
var float composite = 0.0
var float composite_scaled = 0.0
var float macro3f = 50.0

// B8 IRF state: EMA-convolution blend scalars (echo model, Step 1c).
var float irf_vix_blend  = 0.0
var float irf_horc_blend = 0.0
var float irf_bei_blend  = 0.0

// Per-call-site state instances for Kalman / ramp / factor-weight helpers.
var KE.KalmanState1D k_sofr_far  = KE.f_kalman1d_init(1.0, 0.0, 0.0)
var KE.KalmanState1D k_sofr_near = KE.f_kalman1d_init(1.0, 0.0, 0.0)
var BL.BlendRamp rs_horc = BL.BlendRamp.new(weight=0.0)
var BL.BlendRamp rs_bei  = BL.BlendRamp.new(weight=0.0)

if barstate.isfirst
    sssm.regimes             := array.new<RG.GaussianRegime>()
    // B4: sticky-regime prior on Π — diag=0.85, off-diag = 0.15/(K-1).
    // Empirically updated online via soft transition counts (see B4.5 below).
    float pi_diag_init = 0.85
    float pi_off_init  = (1.0 - pi_diag_init) / float(K_REG - 1)
    sssm.Pi                  := matrix.new<float>(K_REG, K_REG, pi_off_init)
    for i = 0 to K_REG - 1
        matrix.set(sssm.Pi, i, i, pi_diag_init)
    sssm.trained             := false
    sssm.active_regime       := 0
    sssm.active_since_bar    := 0
    sssm.posterior_active    := 1.0 / float(K_REG)
    sssm.posterior_runner_up := 1.0 / float(K_REG)
    sssm.log_likelihood      := 0.0
    alpha_filt := array.new<float>(K_REG, 1.0 / float(K_REG))
    alpha_prev := array.new<float>(K_REG, 1.0 / float(K_REG))
    sssm.posterior_history := RG.f_history_new(B6_HORIZON, K_REG)
    gamma_smooth := array.new<float>(K_REG, 0.0)
    k_smooth     := 0
    gamma_smooth_max := 0.0
    b6_warmup    := true
    gamma_kim_gt := array.new<float>(K_REG, 0.0)
    kim_gt_truncate_bars := KIM_GT_H
    kim_gt_pi := matrix.new<float>(K_REG, K_REG, 1.0 / float(K_REG))
    // gap-based transition detector needs no state reset
    // Runtime invariant: log.error surfaces in TV script error list if constants drifted.
    if not _kim_gt_inv_ok
        log.error("KIMGTERR: KIM_GT_H=" + str.tostring(KIM_GT_H) + " > B6_HORIZON=" + str.tostring(B6_HORIZON) + " — look-ahead exceeds ring buffer; all gamma_kim_gt_* will be na.")
    // B7 composite output: initialize regime centroids to neutral.
    sssm.mu_out        := array.new<float>(K_REG, 0.0)
    sssm.mu_out_scored := array.new<float>(K_REG, 0.0)
    sssm.n_out         := array.new<float>(K_REG, 0.0)
    sssm.s_out         := array.new<float>(K_REG, 0.0)
    // B8 IRF: initialize per-factor mu_out arrays (toggle-gated for v0.7.5 diagnostic).
    if b8_udt_enabled
        sssm.mu_out_vix  := array.new<float>(K_REG, 0.0)
        sssm.mu_out_horc := array.new<float>(K_REG, 0.0)
        sssm.mu_out_bei  := array.new<float>(K_REG, 0.0)
    else
        sssm.mu_out_vix  := na
        sssm.mu_out_horc := na
        sssm.mu_out_bei  := na
    rb.f1                    := array.new<float>(te_hist_bars, na)
    rb.f2                    := array.new<float>(te_hist_bars, na)
    rb.f3                    := array.new<float>(te_hist_bars, na)
    rb.f5                    := array.new<float>(te_hist_bars, na)
    rb.posterior_active_hist := array.new<float>(te_hist_bars, na)
    rb.adm_weight            := array.new<float>(te_hist_bars, 1.0)
    rb.capacity              := te_hist_bars
    rb.write_idx             := 0
    rb.count                 := 0
    irf_c.psi_vix  := matrix.new<float>(3, H_VOL, 0.0)
    irf_c.psi_horc := matrix.new<float>(3, H_HORC, 0.0)
    irf_c.psi_bei  := matrix.new<float>(3, H_BEI, 0.0)
    irf_c.last_recompute_bar := -1
    train_st.log_lik_history := array.new<float>()
    train_st.regime_smoothed := array.new<int>()

bool compute_active = bar_index >= last_bar_index - aeSpanBack or barstate.isrealtime

f_regime_sep_diag(array<RG.GaussianRegime> regimes, int k_count, bool use_f4, bool use_f5) =>
    float sep_min = na
    int sep_bad = 0
    int sep_i = na
    int sep_j = na
    string pairs = ""
    if array.size(regimes) >= k_count and k_count >= 2
        for j = 0 to k_count - 2
            RG.GaussianRegime rp_a = array.get(regimes, j)
            for k = j + 1 to k_count - 1
                RG.GaussianRegime rp_b = array.get(regimes, k)
                float sep = KE.f_sep_pair5(rp_a.mu, rp_a.Sigma, rp_b.mu, rp_b.Sigma, use_f4, use_f5, 0.08)
                pairs += (str.length(pairs) > 0 ? "," : "") + "sep_" + str.tostring(j) + "_" + str.tostring(k) + "=" + str.tostring(sep, "#.##")
                bool is_min = na(sep_min) or sep < sep_min
                sep_min := is_min ? sep : sep_min
                sep_i := is_min ? j : sep_i
                sep_j := is_min ? k : sep_j
                sep_bad += sep < SEP_ABS_FLOOR ? 1 : 0
    [sep_min, sep_bad, sep_i, sep_j, pairs]

f_regime_mu_vec(array<RG.GaussianRegime> regimes, int idx) =>
    idx >= 0 and idx < array.size(regimes) ? Log.f_float_array_text(array.get(regimes, idx).mu, 5, "#.###", "[", ",", "]") : "na"

f_apply_unanchored_regs(SSSMState st, array<RG.GaussianRegime> regs, int kK, bool use_f5, bool b8_on) =>
    st.regimes := RG.f_clone_regimes(regs)
    for j = 0 to kK - 1
        RG.GaussianRegime rp = array.get(st.regimes, j)
        float ff1 = array.get(rp.mu, 0)
        float ff2 = array.get(rp.mu, 1)
        float ff3 = array.get(rp.mu, 2)
        float ff5 = use_f5 ? array.get(rp.mu, 4) : 0.0
        float fmu = math.max(-1.5, math.min(1.5, (0.3 * ff1 + 0.2 * ff2 - 0.1 * ff3 + (use_f5 ? 0.10 * ff5 : 0.0)) * 0.5))
        array.set(st.mu_out, j, fmu)
        array.set(st.mu_out_scored, j, fmu)
        if b8_on
            array.set(st.mu_out_vix, j, ff1)
            array.set(st.mu_out_horc, j, ff2)
            array.set(st.mu_out_bei, j, ff3)

f_refit_unanchored_candidate(FactorRingBuffer rbuf, int kK, bool use_f5, int seed_base, int iters, int min_adm_samp) =>
    [cx, cy, cz, cv, _assignment, _weights, cn, sx2, sy2, sz2, sv2, sxx, syy, szz, svv, sxy, sxz, syz, sil, expl] = LRN.f_weighted_kmeans4_stats(rbuf.f1, rbuf.f2, rbuf.f3, rbuf.f5, rbuf.adm_weight, kK, use_f5, seed_base, iters, min_adm_samp, 5.0)
    float total_w = 0.0
    for j = 0 to kK - 1
        total_w += array.get(cn, j)
    array<RG.GaussianRegime> regs = array.new<RG.GaussianRegime>()
    for j = 0 to kK - 1
        RG.GaussianRegime rp = RG.GaussianRegime.new()
        rp.mu := array.new<float>(5, 0.0)
        array.set(rp.mu, 0, array.get(cx, j))
        array.set(rp.mu, 1, array.get(cy, j))
        array.set(rp.mu, 2, array.get(cz, j))
        array.set(rp.mu, 3, 0.0)
        array.set(rp.mu, 4, use_f5 ? array.get(cv, j) : 0.0)
        rp.mu_seed := array.copy(rp.mu)
        rp.Sigma := matrix.new<float>(5, 5, 0.0)
        rp.Sigma_inv := matrix.new<float>(5, 5, 0.0)
        rp.F := matrix.new<float>(5, 5, 0.0)
        for d = 0 to 4
            matrix.set(rp.F, d, d, 1.0)
        rp.Q_diag := array.new<float>(5, 1.0)
        float w = math.max(array.get(cn, j), 1e-6)
        float inv_w = 1.0 / w
        rp.prior := total_w > 0.0 ? w / total_w : 1.0 / float(kK)
        rp.n_eff := w
        rp.sum_x := array.new<float>(5, 0.0)
        rp.sum_xx := matrix.new<float>(5, 5, 0.0)
        array.set(rp.sum_x, 0, array.get(sx2, j))
        array.set(rp.sum_x, 1, array.get(sy2, j))
        array.set(rp.sum_x, 2, array.get(sz2, j))
        array.set(rp.sum_x, 3, 0.0)
        array.set(rp.sum_x, 4, array.get(sv2, j))
        matrix.set(rp.sum_xx, 0, 0, array.get(sxx, j))
        matrix.set(rp.sum_xx, 1, 1, array.get(syy, j))
        matrix.set(rp.sum_xx, 2, 2, array.get(szz, j))
        matrix.set(rp.sum_xx, 3, 3, 0.0)
        matrix.set(rp.sum_xx, 4, 4, array.get(svv, j))
        matrix.set(rp.sum_xx, 0, 1, array.get(sxy, j))
        matrix.set(rp.sum_xx, 1, 0, array.get(sxy, j))
        matrix.set(rp.sum_xx, 0, 2, array.get(sxz, j))
        matrix.set(rp.sum_xx, 2, 0, array.get(sxz, j))
        matrix.set(rp.sum_xx, 1, 2, array.get(syz, j))
        matrix.set(rp.sum_xx, 2, 1, array.get(syz, j))
        float mx = array.get(rp.mu, 0)
        float my = array.get(rp.mu, 1)
        float mz = array.get(rp.mu, 2)
        float mv = array.get(rp.mu, 4)
        float v21_rho = 0.10
        matrix.set(rp.Sigma, 0, 0, math.max(0.08, (1.0 - v21_rho) * (array.get(sxx, j) * inv_w - mx * mx + 0.08) + v21_rho))
        matrix.set(rp.Sigma, 1, 1, math.max(0.08, (1.0 - v21_rho) * (array.get(syy, j) * inv_w - my * my + 0.08) + v21_rho))
        matrix.set(rp.Sigma, 2, 2, math.max(0.08, (1.0 - v21_rho) * (array.get(szz, j) * inv_w - mz * mz + 0.08) + v21_rho))
        matrix.set(rp.Sigma, 3, 3, 1.0)
        matrix.set(rp.Sigma, 4, 4, use_f5 ? math.max(0.08, (1.0 - v21_rho) * (array.get(svv, j) * inv_w - mv * mv + 0.08) + v21_rho) : 1.0)
        float cxy = (1.0 - v21_rho) * (array.get(sxy, j) * inv_w - mx * my)
        float cxz = (1.0 - v21_rho) * (array.get(sxz, j) * inv_w - mx * mz)
        float cyz = (1.0 - v21_rho) * (array.get(syz, j) * inv_w - my * mz)
        matrix.set(rp.Sigma, 0, 1, cxy)
        matrix.set(rp.Sigma, 1, 0, cxy)
        matrix.set(rp.Sigma, 0, 2, cxz)
        matrix.set(rp.Sigma, 2, 0, cxz)
        matrix.set(rp.Sigma, 1, 2, cyz)
        matrix.set(rp.Sigma, 2, 1, cyz)
        matrix.set(rp.Sigma_inv, 0, 0, 1.0 / math.max(matrix.get(rp.Sigma, 0, 0), 1e-6))
        matrix.set(rp.Sigma_inv, 1, 1, 1.0 / math.max(matrix.get(rp.Sigma, 1, 1), 1e-6))
        matrix.set(rp.Sigma_inv, 2, 2, 1.0 / math.max(matrix.get(rp.Sigma, 2, 2), 1e-6))
        matrix.set(rp.Sigma_inv, 3, 3, 1.0)
        matrix.set(rp.Sigma_inv, 4, 4, use_f5 ? 1.0 / math.max(matrix.get(rp.Sigma, 4, 4), 1e-6) : 1.0)
        array.push(regs, rp)
    [regs, sil, expl]

f_refit_keepbest_checkpoint(SSSMState st, FactorRingBuffer rbuf, int kK, bool use_f5, bool b8_on, int seed_base, int iters, int min_adm_samp, float current_sil, float current_sep, float eps, float expl_min, bool bad_gate, bool diff_gate, bool eff_gate, float delta, float hi, float committed_i, array<RG.GaussianRegime> committed_regs) =>
    bool have_snapshot = array.size(committed_regs) >= kK and not na(committed_i)
    [free_regs, free_sil, free_expl] = f_refit_unanchored_candidate(rbuf, kK, use_f5, seed_base, iters, min_adm_samp)
    [_free_sep, _free_bad, _free_i, _free_j, _free_pairs] = f_regime_sep_diag(free_regs, kK, false, use_f5)
    float free_occ_entropy = 0.0
    for j = 0 to kK - 1
        float free_pop = array.size(free_regs) >= kK ? math.max(array.get(free_regs, j).prior, 0.0) : 0.0
        free_occ_entropy += free_pop > 1e-10 ? -free_pop * math.log(free_pop) : 0.0
    float free_eff_ratio = math.exp(free_occ_entropy) / float(kK)
    bool free_better = array.size(free_regs) >= kK and not na(free_sil) and free_sil > nz(current_sil, -1.0) + eps and nz(free_expl) >= expl_min and _free_bad == 0 and free_eff_ratio >= 0.84 and _free_sep >= nz(current_sep, _free_sep) - eps
    float out_hi = hi
    float out_committed_i = committed_i
    array<RG.GaussianRegime> out_committed_regs = committed_regs
    bool adopted = false
    log.info("REFITFREE,bar=" + str.tostring(bar_index) + ",sil=" + str.tostring(free_sil) + ",expl=" + str.tostring(free_expl) + ",sep=" + str.tostring(_free_sep) + ",eff=" + str.tostring(free_eff_ratio) + ",adopt=" + str.tostring(free_better))
    if free_better
        f_apply_unanchored_regs(st, free_regs, kK, use_f5, b8_on)
        out_hi := na(hi) ? math.max(0.0, (free_sil + 1.0) * 0.5) : math.max(hi, math.max(0.0, (free_sil + 1.0) * 0.5))
        out_committed_i := out_hi
        out_committed_regs := RG.f_clone_regimes(st.regimes)
        adopted := true
    else
        bool health_accept = bad_gate and diff_gate and eff_gate and delta >= 0.0 and (not have_snapshot or hi >= committed_i - eps)
        log.info("REFITHEALTH,bar=" + str.tostring(bar_index) + ",I=" + str.tostring(hi) + ",accept=" + str.tostring(health_accept))
        if health_accept
            out_committed_i := hi
            out_committed_regs := RG.f_clone_regimes(st.regimes)
        else if have_snapshot
            st.regimes := RG.f_clone_regimes(committed_regs)
            out_hi := committed_i
    [out_hi, out_committed_i, out_committed_regs, adopted ? free_sil : current_sil]

serialize_regimes(array<RG.GaussianRegime> regs, int K, bool useF5) =>
    string s = "M3F|v19|K=" + str.tostring(K) + "|F5=" + (useF5 ? "1" : "0")
    for j = 0 to K - 1
        RG.GaussianRegime rp = array.get(regs, j)
        s := s + "#R" + str.tostring(j) + ":"
        for d = 0 to 4
            s := s + str.tostring(array.get(rp.mu, d), "#.#####") + ","
        for r = 0 to 4
            for c = r to 4
                s := s + str.tostring(matrix.get(rp.Sigma, r, c), "#.#####") + ","
        s := s + str.tostring(rp.n_eff, "#.###") + "," + str.tostring(rp.prior, "#.#####")
    s

f_parse_payload_schema(string payload, bool packed) =>
    string p = str.replace_all(str.replace_all(payload, "\n", ""), " ", "")
    array<string> parts = str.split(p, "|")
    int parsed_k = -1
    int parsed_f5 = -1
    bool header_ok = array.size(parts) >= 4
    if header_ok
        string k_part = packed ? array.get(parts, 1) : array.get(parts, 2)
        string f5_part = packed ? array.get(parts, 2) : array.get(parts, 3)
        if not packed
            k_part := array.get(parts, 2)
            f5_part := array.get(parts, 3)
            int f5_end = str.pos(f5_part, "#")
            f5_part := f5_end >= 0 ? str.substring(f5_part, 0, f5_end) : f5_part
        parsed_k := str.startswith(k_part, "K=") ? int(nz(str.tonumber(str.substring(k_part, 2, str.length(k_part))), -1.0)) : -1
        parsed_f5 := str.startswith(f5_part, "F5=") ? int(nz(str.tonumber(str.substring(f5_part, 3, str.length(f5_part))), -1.0)) : -1
        header_ok := parsed_k >= 0 and (parsed_f5 == 0 or parsed_f5 == 1)
    [parsed_k, parsed_f5, header_ok]

parse_regimes(string payload, int K, bool useF5) =>
    array<RG.GaussianRegime> regs = array.new<RG.GaussianRegime>()
    bool ok = true
    string p = str.replace_all(str.replace_all(payload, "\n", ""), " ", "")
    array<string> blocks = str.split(p, "#")
    for bi = 0 to array.size(blocks) - 1
        string b = array.get(blocks, bi)
        if str.length(b) > 1 and str.substring(b, 0, 1) == "R"
            int colon = str.pos(b, ":")
            if colon >= 0
                string body = str.substring(b, colon + 1, str.length(b))
                array<string> v = str.split(body, ",")
                if array.size(v) >= 22
                    RG.GaussianRegime rp = RG.GaussianRegime.new()
                    rp.mu := array.new<float>(5, 0.0)
                    rp.Sigma := matrix.new<float>(5, 5, 0.0)
                    for d = 0 to 4
                        array.set(rp.mu, d, N.f_parse_float_at(v, d, 0.0))
                    int k = 5
                    for r = 0 to 4
                        for c = r to 4
                            float val = N.f_parse_float_at(v, k, r == c ? 1.0 : 0.0)
                            matrix.set(rp.Sigma, r, c, val)
                            matrix.set(rp.Sigma, c, r, val)
                            k += 1
                    rp.n_eff := math.max(N.f_parse_float_at(v, 20, 1.0), 1e-6)
                    rp.prior := N.f_parse_float_at(v, 21, 1.0 / float(K))
                    rp.initialize_stats(K, array.from(true, true, true, false, useF5))
                    array.push(regs, rp)
                else
                    ok := false
            else
                ok := false
    ok := ok and array.size(regs) == K
    [regs, ok]

int PACK_SCALE = 5000

serialize_packed(array<RG.GaussianRegime> regs, int K, bool useF5) =>
    string s = "M3FX|K=" + str.tostring(K) + "|F5=" + (useF5 ? "1" : "0") + "|"
    for j = 0 to K - 1
        RG.GaussianRegime rp = array.get(regs, j)
        s += LRN.f_pack_gaussian5_i16(rp.mu, rp.Sigma, rp.n_eff, rp.prior, float(PACK_SCALE))
    s

parse_packed(string payload, int K, bool useF5) =>
    array<RG.GaussianRegime> regs = array.new<RG.GaussianRegime>()
    string p = str.replace_all(str.replace_all(payload, "\n", ""), " ", "")
    array<string> parts = str.split(p, "|")
    string data = array.size(parts) >= 4 ? array.get(parts, 3) : ""
    int per = 88
    bool ok = str.length(data) >= K * per
    if ok
        for j = 0 to K - 1
            [_mu, _sigma, _n_eff, _prior, _row_ok] = LRN.f_unpack_gaussian5_i16(data, j * per, float(PACK_SCALE))
            ok := ok and _row_ok
            if _row_ok
                RG.GaussianRegime rp = RG.GaussianRegime.new()
                rp.mu := _mu
                rp.Sigma := _sigma
                rp.n_eff := _n_eff
                rp.prior := _prior
                rp.initialize_stats(K, array.from(true, true, true, false, useF5))
                array.push(regs, rp)
    ok := ok and array.size(regs) == K
    [regs, ok]

vx1   = request.security("CBOE:VX1!",    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vx2   = request.security("CBOE:VX2!",    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
bviv  = request.security(dvol_tk,        timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
zq1   = request.security("CBOT:ZQ1!",    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
zq3   = request.security("CBOT:ZQ3!",    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
us10y = request.security("TVC:US10Y",    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
tips  = request.security("TVC:US10YIEF", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
gold     = request.security("COMEX:GC1!",   timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
fred_bei = request.security("FRED:T10YIE",  timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
sr3_far  = request.security(sofr_far_tk,    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
sr3_near = request.security(sofr_near_tk,   timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
zn       = request.security("CBOT:ZN1!",    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
rinf     = request.security("AMEX:RINF",    timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
cl       = request.security("NYMEX:CL1!",   timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vix9d    = request.security("CBOE:VIX9D",   timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vix_sp   = request.security("CBOE:VIX",     timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vix3m    = request.security("CBOE:VIX3M",   timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
ovx      = request.security("CBOE:OVX",     timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
gvz      = request.security("CBOE:GVZ",     timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_bin_oi = request.security("BINANCE:" + lvg_base_symbol + "_OI", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_byb_oi = request.security("BYBIT:" + lvg_base_symbol + "_OI", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_okx_oi = request.security("OKX:" + lvg_base_symbol + "_OI", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_bitget_oi = request.security("BITGET:" + lvg_base_symbol + "_OI", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_htx_oi = request.security("HTX:" + lvg_base_symbol + "_OI", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_bin_lsr = request.security("BINANCE:" + lvg_base_symbol + "_LSR", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_byb_lsr = request.security("BYBIT:" + lvg_base_symbol + "_LSR", timeframe.period, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
lvg_premium_hand = request.security("BINANCE:" + lvg_premium_base + "_PREMIUM", "1", ta.wma(close, lvg_fund_len), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
bool lvg_native_funding_valid = not na(lvg_native_funding_src) and math.abs(lvg_native_funding_src) < 1.0
lvg_premium = lvg_funding_source_mode == "Native import" and lvg_native_funding_valid ? lvg_native_funding_src : lvg_premium_hand

float vx_ratio = not na(vx1) and not na(vx2) and vx2 > 0.0 ? vx1 / vx2 : na
float vix_ts_front = not na(vix9d) and not na(vix_sp) and vix_sp > 0.0 ? vix9d / vix_sp : na
float vix_ts_back  = not na(vix_sp) and not na(vix3m) and vix3m > 0.0  ? vix_sp / vix3m : na
float vix_struct_raw = nz(vx_ratio,1.0)*0.50 + nz(vix_ts_front,1.0)*0.35 + nz(vix_ts_back,1.0)*0.15
float bviv_norm = N.f_relative_ema(bviv, 200)
float bviv_src  = nz(bviv_norm + 1.0, 1.0)
float vix_src = not na(vx_ratio) ? (use_dvol ? vix_struct_raw * 0.7 + bviv_src * 0.3 : vix_struct_raw) : bviv_src
float vix_fast_ss = N.f_supersmoother_seeded(vix_src, vix_fast)
float vix_slow_ss = N.f_supersmoother_seeded(vix_src, vix_slow)
float vix_macd    = vix_fast_ss - vix_slow_ss
float vix_ema_src = ta.ema(vix_src, vix_fast)
float z_vix_raw   = N.f_zscore_mean_mad(vix_src, vix_zlen)
float z_vix_double = N.f_zscore_mean_mad(vix_macd, vix_zlen)
float z_vix_ema   = N.f_zscore_mean_mad(vix_ema_src, vix_zlen)
float z_vix       = factor_smooth_mode == "Raw" ? z_vix_raw : factor_smooth_mode == "EMA" ? z_vix_ema : z_vix_double

float zq_spread   = not na(zq3) and not na(zq1) ? zq3 - zq1 : na
float sr3_far_sm  = k_sofr_far.update_value(sr3_far, horc_kq, horc_kr)
float sr3_near_sm = k_sofr_near.update_value(sr3_near, horc_kq, horc_kr)
float sr3_spread  = not na(sr3_far_sm) and not na(sr3_near_sm) ? sr3_far_sm - sr3_near_sm : na
var BL.TickerState st_horc = BL.TickerState.new()
bool _zq_ticked = not na(zq_spread) and (math.abs(nz(ta.change(zq_spread))) > 1e-6 or math.abs(nz(ta.change(zq_spread[1]))) > 1e-6)
st_horc.update(_zq_ticked, 4, 1, 6)
var float horc_delta = na
if st_horc.is_live() and not na(sr3_spread)
    float _hd = nz(zq_spread) - nz(sr3_spread)
    horc_delta := na(horc_delta) ? _hd : horc_delta * 0.999 + _hd * 0.001
float sr3_adj   = nz(sr3_spread) + nz(horc_delta, 0.0)
float horc_ramp = rs_horc.update(st_horc.is_live(), ramp_alpha, ramp_alpha)
float horc_src  = BL.f_sw_blend(sr3_adj, nz(zq_spread, sr3_adj), horc_ramp)
float horc_fast_ss = N.f_supersmoother_seeded(horc_src, horc_fast)
float horc_slow_ss = N.f_supersmoother_seeded(horc_src, horc_slow)
float horc_macd    = horc_fast_ss - horc_slow_ss
float horc_ema_src = ta.ema(horc_src, horc_fast)
float z_horc_raw   = N.f_zscore_mean_mad(horc_src, horc_zlen)
float z_horc_double = N.f_zscore_mean_mad(horc_macd, horc_zlen)
float z_horc_ema   = N.f_zscore_mean_mad(horc_ema_src, horc_zlen)
float z_horc       = factor_smooth_mode == "Raw" ? z_horc_raw : factor_smooth_mode == "EMA" ? z_horc_ema : z_horc_double

float rinf_nz      = nz(rinf, 25.0)
float rinf_norm    = rinf_nz / math.max(ta.ema(rinf_nz, 500), 0.01) - 1.0
float bei_rth_rinf = not na(rinf) and math.abs(nz(rinf) - nz(rinf[1])) > 1e-6 ? rinf_norm * 20.0 : na
float bei_raw      = not na(us10y) and not na(tips) ? us10y - tips : na
float bei_prim     = not na(bei_rth_rinf) ? bei_rth_rinf : not na(fred_bei) ? fred_bei : bei_raw
float gc_ln        = math.log(math.max(nz(gold, 1800.0), 1e-5))
float gc_trend     = ta.ema(gc_ln, 200)
float gc_detrended = gc_ln - gc_trend
float zn_yield     = not na(zn) ? (100.0 - nz(zn, 110.0)) / 6.6 : 2.0
float zn_yield_dev = zn_yield - ta.ema(zn_yield, 200)
float bei_gc_raw   = gc_detrended - zn_yield_dev * 0.3
float bei_gc_src   = nz(bei_gc_raw)
float bei_gc_prox  = ta.ema(bei_gc_src, 20)
float cl_nz        = nz(cl)
float cl_mom       = not na(cl) ? ta.ema(cl_nz, 10) / math.max(ta.ema(cl_nz, 100), 0.01) - 1.0 : 0.0
float oil_weight   = math.max(0.0, math.min(0.4, math.abs(cl_mom) * 10.0))
float ovx_norm     = N.f_relative_ema(ovx, 200)
float gvz_norm     = N.f_relative_ema(gvz, 200)
float cl_ret_b     = not na(cl)  ? math.log(math.max(nz(cl)  / math.max(nz(cl[1]),  1e-5), 1e-5)) : 0.0
float ovx_ret_b    = not na(ovx) ? nz(ovx) - nz(ovx[1]) : 0.0
float corr_ovx     = ta.correlation(cl_ret_b, ovx_ret_b, 60)
float ovx_sign     = corr_ovx < -0.2 ? -1.0 : corr_ovx > 0.2 ? 1.0 : 0.0
float bei_proxy    = bei_gc_prox * (1.0 - oil_weight) + cl_mom * oil_weight + ovx_sign * nz(ovx_norm) * 0.10 + nz(gvz_norm) * 0.15
var BL.TickerState st_bei = BL.TickerState.new()
bool _bei_live = not na(bei_rth_rinf) or (not na(fred_bei) and math.abs(nz(fred_bei) - nz(fred_bei[1])) > 1e-6)
st_bei.update(_bei_live, 3, 1, 3)
var float bei_delta = na
if st_bei.is_live() and not na(bei_proxy)
    float _bd = nz(bei_prim) - nz(bei_proxy)
    bei_delta := na(bei_delta) ? _bd : bei_delta * 0.999 + _bd * 0.001
float bei_proxy_adj = nz(bei_proxy) + nz(bei_delta, 0.0)
float bei_ramp = rs_bei.update(st_bei.is_live(), ramp_alpha, ramp_alpha)
float bei_src  = BL.f_sw_blend(bei_proxy_adj, nz(bei_prim, bei_proxy_adj), bei_ramp)
float bei_fast_ss = N.f_supersmoother_seeded(bei_src, bei_fast)
float bei_slow_ss = N.f_supersmoother_seeded(bei_src, bei_slow)
float bei_macd    = bei_fast_ss - bei_slow_ss
float bei_ema_src = ta.ema(bei_src, bei_fast)
float z_bei_raw   = N.f_zscore_mean_mad(bei_src, bei_zlen)
float z_bei_double = N.f_zscore_mean_mad(bei_macd, bei_zlen)
float z_bei_ema   = N.f_zscore_mean_mad(bei_ema_src, bei_zlen)
float z_bei       = factor_smooth_mode == "Raw" ? z_bei_raw : factor_smooth_mode == "EMA" ? z_bei_ema : z_bei_double

float F1 = -z_vix
float F2 =  z_horc
float F3 =  z_bei
float lvg_lsr_alpha = 2.0 / (float(lvg_win) + 1.0)
var float lvg_ema_bin_w = na
var float lvg_ema_byb_w = na
float lvg_raw_bin_w = na(lvg_bin_oi) ? 0.0 : lvg_bin_oi
float lvg_raw_byb_w = na(lvg_byb_oi) ? 0.0 : lvg_byb_oi
float lvg_lsr_w_den = lvg_raw_bin_w + lvg_raw_byb_w
if lvg_on and lvg_lsr_w_den > 0.0
    float lvg_norm_bin_w = lvg_raw_bin_w / lvg_lsr_w_den
    float lvg_norm_byb_w = lvg_raw_byb_w / lvg_lsr_w_den
    lvg_ema_bin_w := na(lvg_ema_bin_w) ? lvg_norm_bin_w : lvg_ema_bin_w + lvg_lsr_alpha * (lvg_norm_bin_w - lvg_ema_bin_w)
    lvg_ema_byb_w := na(lvg_ema_byb_w) ? lvg_norm_byb_w : lvg_ema_byb_w + lvg_lsr_alpha * (lvg_norm_byb_w - lvg_ema_byb_w)
float lvg_w_bin = nz(lvg_ema_bin_w, 0.5)
float lvg_w_byb = nz(lvg_ema_byb_w, 0.5)
float lvg_w_sum = lvg_w_bin + lvg_w_byb
float lvg_lsr = lvg_w_sum > 0.0 and not na(lvg_bin_lsr) and not na(lvg_byb_lsr) ? (lvg_bin_lsr * lvg_w_bin + lvg_byb_lsr * lvg_w_byb) / lvg_w_sum : nz(lvg_bin_lsr, lvg_byb_lsr)
float lvg_lsr_log = na(lvg_lsr) or lvg_lsr <= 0.0 ? na : math.log(lvg_lsr)
int lvg_oi_venue_count = (na(lvg_bin_oi) ? 0 : 1) + (na(lvg_byb_oi) ? 0 : 1) + (na(lvg_okx_oi) ? 0 : 1) + (na(lvg_bitget_oi) ? 0 : 1) + (na(lvg_htx_oi) ? 0 : 1)
float lvg_oi_den = (na(lvg_bin_oi) ? 0.0 : lvg_bin_oi) + (na(lvg_byb_oi) ? 0.0 : lvg_byb_oi) + (na(lvg_okx_oi) ? 0.0 : lvg_okx_oi) + (na(lvg_bitget_oi) ? 0.0 : lvg_bitget_oi) + (na(lvg_htx_oi) ? 0.0 : lvg_htx_oi)
float lvg_venue_oi_agg = lvg_oi_venue_count >= lvg_oi_min_venues and lvg_oi_den > 0.0 ? ((na(lvg_bin_oi) ? 0.0 : lvg_bin_oi * lvg_bin_oi) + (na(lvg_byb_oi) ? 0.0 : lvg_byb_oi * lvg_byb_oi) + (na(lvg_okx_oi) ? 0.0 : lvg_okx_oi * lvg_okx_oi) + (na(lvg_bitget_oi) ? 0.0 : lvg_bitget_oi * lvg_bitget_oi) + (na(lvg_htx_oi) ? 0.0 : lvg_htx_oi * lvg_htx_oi)) / lvg_oi_den : na
float lvg_oi_agg = lvg_oi_source_mode == "Native import" ? lvg_native_oi_src : lvg_venue_oi_agg
float lvg_oi_delta = na(lvg_oi_agg) ? na : lvg_oi_agg - lvg_oi_agg[lvg_oi_len]
float lvg_price_delta = math.log(math.max(close / math.max(close[lvg_oi_len], 1e-5), 1e-5))
float lvg_z_oi = N.f_zscore_mean_mad(lvg_oi_agg, lvg_win)
float lvg_z_oid = N.f_zscore_mean_mad(lvg_oi_delta, lvg_win)
float lvg_z_price_delta = N.f_zscore_mean_mad(lvg_price_delta, lvg_win)
float lvg_z_lsr = N.f_zscore_mean_mad(lvg_lsr_log, lvg_win)
float lvg_z_fund_raw = N.f_zscore_mean_mad(lvg_premium, lvg_win)
float lvg_z_fund_accum = math.sum(nz(lvg_z_fund_raw), lvg_fund_accum_len) / math.sqrt(float(lvg_fund_accum_len))
float lvg_z_fund = ta.ema(lvg_z_fund_accum, lvg_fund_smooth_len)
float lvg_axis_build = lvg_on ? nz(lvg_z_oid) : na
float lvg_axis_crowd = lvg_on ? 0.65 * nz(lvg_z_oid) + 0.20 * nz(lvg_z_fund) + 0.15 * nz(lvg_z_lsr) : na
float lvg_band_basis = ta.sma(close, lvg_band_len)
float lvg_band_half = ta.stdev(close, lvg_band_len) * lvg_band_mult
float lvg_price_band_pos = not na(lvg_band_basis) and not na(lvg_band_half) and lvg_band_half > 1e-10 ? math.max(-1.0, math.min(1.0, (close - lvg_band_basis) / lvg_band_half)) : na
float lvg_axis_build_adj = lvg_on and lvg_use_band_confirm and not na(lvg_price_band_pos) ? lvg_axis_build + 0.25 * lvg_price_band_pos : lvg_axis_build
float lvg_quadrant = nz(lvg_z_price_delta) >= 0.0 and nz(lvg_z_oid) >= 0.0 ? 1.0 : nz(lvg_z_price_delta) < 0.0 and nz(lvg_z_oid) >= 0.0 ? 0.5 : nz(lvg_z_price_delta) >= 0.0 and nz(lvg_z_oid) < 0.0 ? -0.5 : -1.0
float lvg_cycle = lvg_on ? 0.45 * nz(lvg_axis_build_adj) + 0.35 * nz(lvg_axis_crowd) + 0.20 * lvg_quadrant : na
float lvg_score_raw = 50.0 + 18.0 * nz(lvg_axis_build_adj) + 12.0 * nz(lvg_axis_crowd) + 8.0 * lvg_quadrant
float lvg_score = lvg_on ? math.max(0.0, math.min(100.0, lvg_score_raw)) : na
float lvg_abs_z_oid = math.abs(nz(lvg_z_oid))
float lvg_oi_event_gate_pctl = ta.percentile_nearest_rank(lvg_abs_z_oid, lvg_oi_event_win, lvg_oi_event_pct)
float lvg_oi_event_gate_std = ta.sma(lvg_abs_z_oid, lvg_oi_event_win) + ta.stdev(lvg_abs_z_oid, lvg_oi_event_win)
float lvg_oi_event_gate_raw = lvg_oi_event_mode == "Fixed" ? lvg_oi_event_thr : lvg_oi_event_mode == "Mean + 1 Std" ? lvg_oi_event_gate_std : lvg_oi_event_gate_pctl
float lvg_oi_event_gate = nz(lvg_oi_event_gate_raw, lvg_oi_event_thr)
bool lvg_oi_event = lvg_abs_z_oid >= lvg_oi_event_gate
float lvg_score_q25_raw = ta.percentile_nearest_rank(lvg_score, lvg_phase_q_win, 25)
float lvg_score_q50_raw = ta.percentile_nearest_rank(lvg_score, lvg_phase_q_win, 50)
float lvg_score_q75_raw = ta.percentile_nearest_rank(lvg_score, lvg_phase_q_win, 75)
float lvg_score_q25 = nz(lvg_score_q25_raw, 40.0)
float lvg_score_q50 = nz(lvg_score_q50_raw, 50.0)
float lvg_score_q75 = nz(lvg_score_q75_raw, 60.0)
bool lvg_flush_override = nz(lvg_z_oid) <= -lvg_override_oi_z and nz(lvg_z_price_delta) <= -lvg_override_price_z
bool lvg_build_override = nz(lvg_z_oid) >= lvg_override_oi_z and nz(lvg_z_price_delta) >= lvg_override_price_z
bool lvg_reprice_shock = math.abs(nz(lvg_z_price_delta)) >= lvg_reprice_z
var int lvg_reprice_ttl = 0
lvg_reprice_ttl := lvg_reprice_shock ? lvg_reprice_bars : math.max(lvg_reprice_ttl - 1, 0)
float lvg_phase_hyst_eff = lvg_reprice_ttl > 0 ? lvg_fast_hyst : lvg_phase_hyst
var int lvg_phase_state = 1
int lvg_phase_hyst_candidate = lvg_phase_state <= 0 ? (lvg_score > lvg_score_q25 + lvg_phase_hyst_eff ? 1 : 0) : lvg_phase_state == 1 ? (lvg_score <= lvg_score_q25 - lvg_phase_hyst_eff ? 0 : lvg_score > lvg_score_q50 + lvg_phase_hyst_eff ? 2 : 1) : lvg_phase_state == 2 ? (lvg_score <= lvg_score_q50 - lvg_phase_hyst_eff ? 1 : lvg_score > lvg_score_q75 + lvg_phase_hyst_eff ? 3 : 2) : lvg_score <= lvg_score_q75 - lvg_phase_hyst_eff ? 2 : 3
int lvg_phase_candidate = lvg_flush_override ? 3 : lvg_build_override ? 2 : lvg_phase_hyst_candidate
lvg_phase_state := not lvg_on or na(lvg_cycle) ? -1 : lvg_phase_candidate
int lvg_phase = lvg_phase_state
float F5 = lvg_on ? (cfg_best_balanced ? (lvg_native_funding_valid ? 0.50 * nz(lvg_z_fund_raw) : 0.0) : nz(lvg_cycle)) : 0.0
if barstate.isconfirmed and bar_index % 200 == 0
    log.info("V21FUND,bar=" + str.tostring(bar_index) + ",native_valid=" + str.tostring(lvg_native_funding_valid) + ",raw=" + str.tostring(lvg_native_funding_src) + ",z=" + str.tostring(lvg_z_fund_raw) + ",feature=" + str.tostring(F5))
float lvg_m1_inflate = lvg_denoise_on and lvg_phase == 3 ? lvg_m1_flush_inflate : lvg_denoise_on and lvg_phase == 2 ? lvg_m1_crowd_inflate : 1.0
float lvg_denoise_weight = lvg_m1_inflate - 1.0
string lvg_phase_txt = lvg_phase == 0 ? "reset" : lvg_phase == 1 ? "accum" : lvg_phase == 2 ? "crowd" : lvg_phase == 3 ? "flush" : "off"
if lvg_logs and barstate.isconfirmed and bar_index % 200 == 0
    log.info("LVGCYCLE,bar=" + str.tostring(bar_index) + ",cycle=" + str.tostring(lvg_cycle, "#.####") + ",phase=" + str.tostring(lvg_phase) + ",candidate=" + str.tostring(lvg_phase_candidate) + ",score=" + str.tostring(lvg_score, "#.##") + ",quad=" + str.tostring(lvg_quadrant, "#.##") + ",oi_z=" + str.tostring(lvg_z_oi, "#.####") + ",oid_z=" + str.tostring(lvg_z_oid, "#.####") + ",price_z=" + str.tostring(lvg_z_price_delta, "#.####") + ",lsr_z=" + str.tostring(lvg_z_lsr, "#.####") + ",fund_z=" + str.tostring(lvg_z_fund, "#.####") + ",gate=" + str.tostring(lvg_oi_event_gate, "#.####") + ",q25=" + str.tostring(lvg_score_q25, "#.##") + ",q50=" + str.tostring(lvg_score_q50, "#.##") + ",q75=" + str.tostring(lvg_score_q75, "#.##") + ",oi_event=" + str.tostring(lvg_oi_event) + ",flush_override=" + str.tostring(lvg_flush_override) + ",build_override=" + str.tostring(lvg_build_override) + ",reprice=" + str.tostring(lvg_reprice_shock) + ",hyst_eff=" + str.tostring(lvg_phase_hyst_eff, "#.##") + ",band=" + str.tostring(lvg_price_band_pos, "#.####") + ",denoise=" + str.tostring(lvg_denoise_weight, "#.####"))
var array<label> lvg_phase_labels = array.new<label>()
if lvg_show_phase_labels and lvg_on and barstate.isconfirmed and lvg_phase >= 0 and lvg_phase != nz(lvg_phase[1], -1) and not na(lvg_cycle)
    color lvg_lbl_color = lvg_phase == 0 ? color.new(color.aqua, 0) : lvg_phase == 1 ? color.new(color.lime, 0) : lvg_phase == 2 ? color.new(color.orange, 0) : color.new(color.red, 0)
    lvg_lbl_style = lvg_phase == 3 or lvg_phase == 2 ? label.style_label_down : label.style_label_up
    label lvg_lbl = label.new(bar_index, lvg_cycle, lvg_phase_txt, xloc=xloc.bar_index, yloc=yloc.price, color=lvg_lbl_color, textcolor=color.white, style=lvg_lbl_style, size=size.tiny)
    array.push(lvg_phase_labels, lvg_lbl)
    if array.size(lvg_phase_labels) > lvg_max_phase_labels
        label.delete(array.shift(lvg_phase_labels))
float irf_vix_out  = ta.ema(z_vix,  int(_eff_hvol))
float irf_horc_out = ta.ema(z_horc, int(_eff_hhorc))
float irf_bei_out  = ta.ema(z_bei,  int(_eff_hbei))
float irf_blend_out = irf_vix_out * _eff_wvix + irf_horc_out * _eff_whorc + irf_bei_out * _eff_wbei
// B8.5 — IRF-corrected observations (gated by b8_enabled AND obs_use_irf toggle)

// B8.6 computation moved to after B7 (needs macro3f)
var bool sssm_seeded = false  // moved here (forward-ref fix): needed by admission gate below

// ─── Regime Admission v0.7.18-final: LOCKED config ─────────────────────────
// HARD AND gate: dwell>=2 AND sign==W(5/5) AND hold_kof W (3-of-5) >= tau(0.50)
// resid_lev_factors=on: F1/F2/F3 residualized vs lev.z_price_delta before B2/B5
// Reprice-shock exemption: w_t set to 1.0 whenever lvg_reprice_shock is active.
bool  adm_soft        = cfg_c02_offline_jul91 ? false : adm_mode_in == "SOFT"
bool  adm_denoise_lev = cfg_c02_offline_jul91 ? true : adm_denoise_lev_in
int   adm_min_dwell   = cfg_c02_offline_jul91 ? 2 : adm_min_dwell_in
bool  adm_use_sign_gate = cfg_c02_offline_jul91 ? true : adm_use_sign_gate_in
int   adm_sign_W      = cfg_c02_offline_jul91 ? 5 : adm_sign_win_in
int   adm_sign_k      = cfg_c02_offline_jul91 ? 5 : math.min(adm_sign_k_in, adm_sign_W)
int   adm_dwell_sat   = cfg_c02_offline_jul91 ? 5 : adm_dwell_sat_in
bool  adm_use_hold_gate = cfg_c02_offline_jul91 ? true : adm_use_hold_gate_in
int   adm_hold_ma_win = cfg_c02_offline_jul91 ? 5 : adm_hold_ma_win_in
int   adm_hold_k      = cfg_c02_offline_jul91 ? 3 : math.min(adm_hold_k_in, adm_hold_ma_win)
float adm_hard_hold_tau = cfg_c02_offline_jul91 ? 0.50 : adm_hard_hold_tau_in
int   adm_min_samp    = cfg_c02_offline_jul91 ? 20 : adm_min_samples_in

// 1. Dwell tracker.
int adm_cur_regime = sssm_seeded ? sssm.active_regime : -1
if adm_cur_regime != adm_prev_regime
    adm_regime_run_len := 1
else
    adm_regime_run_len := adm_regime_run_len + 1
adm_prev_regime := adm_cur_regime

// 2. Sign-consistency: leverage-residualized price velocity vs macro3f direction.
//    NTE is intentionally excluded from this test (dispatch spec).
float adm_price_vel_raw = nz(lvg_z_price_delta)
float adm_price_vel = adm_denoise_lev and not na(lvg_score) ? adm_price_vel_raw - nz(lvg_score / 50.0 - 1.0) * 0.25 : adm_price_vel_raw
float adm_macro_dir = nz(macro3f) - 50.0
bool  adm_sign_agree = (adm_macro_dir >= 0.0 and adm_price_vel >= 0.0) or (adm_macro_dir < 0.0 and adm_price_vel < 0.0)
// Rotate sign agreement into history ring (ring size 20 covers max adm_sign_W=20).
array.set(adm_sign_hist, adm_sign_hist_idx, adm_sign_agree ? 1.0 : 0.0)
adm_sign_hist_idx := (adm_sign_hist_idx + 1) % 20
float adm_sign_sum = 0.0
for _si = 0 to adm_sign_W - 1
    adm_sign_sum += array.get(adm_sign_hist, (adm_sign_hist_idx - 1 - _si + 20) % 20)
float adm_sign_frac = adm_sign_sum / float(adm_sign_W)  // in [0,1]
adm_sign_rate_now := adm_sign_frac

// 3. Hold-score count gate (3-of-5): push hold_above_tau bit into ring buffer.
var float _adm_hold_carry = 0.5
float adm_hold_now = _adm_hold_carry  // previous bar's committed hold score (1-bar lag correct)
// Rolling mean (for SOFT weight) and count gate (for HARD gate).
var float _adm_hold_ma = 0.5
float _adm_hold_ma_alpha = adm_hold_ma_win > 1 ? 2.0 / float(adm_hold_ma_win + 1) : 1.0
_adm_hold_ma := _adm_hold_ma + _adm_hold_ma_alpha * (adm_hold_now - _adm_hold_ma)
float adm_hold_ma5 = math.max(0.0, math.min(_adm_hold_ma, 1.0))
// Count-based hold gate: track how many of last adm_hold_ma_win bars had hold > tau
bool adm_hold_above_tau = adm_hold_now >= adm_hard_hold_tau
array.set(adm_hold_hist, adm_hold_hist_idx, adm_hold_above_tau ? 1.0 : 0.0)
adm_hold_hist_idx := (adm_hold_hist_idx + 1) % 20
float adm_hold_count = 0.0
for _hi = 0 to adm_hold_ma_win - 1
    adm_hold_count += array.get(adm_hold_hist, (adm_hold_hist_idx - 1 - _hi + 20) % 20)
bool adm_hold_gate = adm_hold_count >= float(adm_hold_k)

// 4a. SOFT weight components:
//   sign_frac_sq  = clip(sign_frac)^2
//   dwell_frac    = clip(run_len / dwell_sat, 0, 1)
//   hold_ma5      = rolling mean of hold score
float adm_sign_frac_sq  = adm_sign_frac * adm_sign_frac
float adm_dwell_frac    = math.min(float(adm_regime_run_len) / float(adm_dwell_sat), 1.0)
float adm_weight_soft   = adm_sign_frac_sq * adm_dwell_frac * adm_hold_ma5

// 4b. HARD gate (strict AND, locked): min_dwell AND sign_k/x AND hold_kofW>=tau
bool adm_dwell_gate = adm_regime_run_len >= adm_min_dwell
bool adm_sign_gate = not adm_use_sign_gate or adm_sign_sum >= float(adm_sign_k)
bool adm_nte_hold_gate = not adm_use_hold_gate or adm_hold_gate
bool adm_eligible_hard  = adm_gate_logic == "AND" ? adm_dwell_gate and adm_sign_gate and adm_nte_hold_gate : adm_dwell_gate or adm_sign_gate or adm_nte_hold_gate

// 5. Final w_t: reprice-shock exemption overrides both modes to 1.0.
bool  adm_shock_exempt  = lvg_reprice_shock
float adm_weight_pre    = adm_soft ? adm_weight_soft : (adm_eligible_hard ? 1.0 : 0.0)
adm_weight_now := adm_shock_exempt ? 1.0 : (sssm_seeded ? adm_weight_pre : 1.0)

// Pass-B B1: factor-only ring buffer fill. SSSM-GUARD enforced — only F1/F2/F3
// land here; btc_ret is isolated to the causality layer (te_btc). Consumed by
// K-means init (B2), Mahalanobis posterior (B3), Hamilton forward filter (B4),
// and online EM (B5). O(1) modular write; capacity = W_TE.
// resid_lev_factors=on: residualize F1/F2/F3 vs lev.z_price_delta (rolling OLS β, W=rb.capacity)
// before push so that B2/B5 cluster on leverage-cleaned factors.
var float _rb_cov_f1_p = 0.0   // EMA cov(F1, lev.z_price_delta)
var float _rb_cov_f2_p = 0.0
var float _rb_cov_f3_p = 0.0
var float _rb_var_p    = 1.0   // EMA var(lev.z_price_delta)
float _rb_ema_alpha = 2.0 / (float(rb.capacity) + 1.0)
float _lzpd = nz(lvg_z_price_delta)
_rb_var_p    := _rb_var_p    + _rb_ema_alpha * (_lzpd * _lzpd      - _rb_var_p)
_rb_cov_f1_p := _rb_cov_f1_p + _rb_ema_alpha * (nz(F1) * _lzpd   - _rb_cov_f1_p)
_rb_cov_f2_p := _rb_cov_f2_p + _rb_ema_alpha * (nz(F2) * _lzpd   - _rb_cov_f2_p)
_rb_cov_f3_p := _rb_cov_f3_p + _rb_ema_alpha * (nz(F3) * _lzpd   - _rb_cov_f3_p)
float _rb_b1 = _rb_var_p > 1e-10 ? _rb_cov_f1_p / _rb_var_p : 0.0
float _rb_b2 = _rb_var_p > 1e-10 ? _rb_cov_f2_p / _rb_var_p : 0.0
float _rb_b3 = _rb_var_p > 1e-10 ? _rb_cov_f3_p / _rb_var_p : 0.0
float F1r = adm_denoise_lev ? nz(F1) - _rb_b1 * _lzpd : nz(F1)
float F2r = adm_denoise_lev ? nz(F2) - _rb_b2 * _lzpd : nz(F2)
float F3r = adm_denoise_lev ? nz(F3) - _rb_b3 * _lzpd : nz(F3)
array.set(rb.f1, rb.write_idx, F1r)
array.set(rb.f2, rb.write_idx, F2r)
array.set(rb.f3, rb.write_idx, F3r)
array.set(rb.f5, rb.write_idx, nz(F5))
array.set(rb.adm_weight, rb.write_idx, 1.0)
rb.write_idx := (rb.write_idx + 1) % rb.capacity
if rb.count < rb.capacity
    rb.count := rb.count + 1

if use_frozen and not sssm_seeded and not frozen_loaded and not frozen_parse_error
    [_payload_k, _payload_f5, _header_ok] = f_parse_payload_schema(frozen_in, frozen_pack_mode == "Hex packed")
    payload_k := _payload_k
    parsed_payload_f5 := _payload_f5
    payload_f5 := parsed_payload_f5 == 1
    schema_ok := _header_ok and payload_k == K_REG and payload_f5 == nw_use_f5
    if not schema_ok
        frozen_parse_error := true
        model_source := "SCHEMA_ERROR"
        runtime.error("Frozen model K=" + str.tostring(payload_k) + ", F5=" + str.tostring(parsed_payload_f5) + " but runtime K=" + str.tostring(K_REG) + ", F5=" + str.tostring(nw_use_f5 ? 1 : 0))
    [_frozen_regs, _frozen_ok] = if frozen_pack_mode == "Hex packed"
        parse_packed(frozen_in, K_REG, nw_use_f5)
    else
        parse_regimes(frozen_in, K_REG, nw_use_f5)
    if _frozen_ok
        sssm.regimes := _frozen_regs
        if adm_online_mode == "RefitKeepBest"
            [_prior_n_raw, _prior_n_cap, _prior_scale] = RG.f_cap_prior_stats(sssm.regimes, refit_prior_cap)
            log.info("REFITPRIOR,raw_n=" + str.tostring(_prior_n_raw, "#.##") + ",cap=" + str.tostring(_prior_n_cap, "#.##") + ",scale=" + str.tostring(_prior_scale, "#.####"))
            model_source := "FROZEN"
        else
            model_source := "FROZEN"
        sssm_seeded := true
        frozen_loaded := true
        sssm.active_since_bar := bar_index
        for j = 0 to K_REG - 1
            RG.GaussianRegime rp = array.get(sssm.regimes, j)
            float f1_seed = array.get(rp.mu, 0)
            float f2_seed = array.get(rp.mu, 1)
            float f3_seed = array.get(rp.mu, 2)
            float f5_seed = nw_use_f5 ? array.get(rp.mu, 4) : 0.0
            float mu_init = math.max(-1.5, math.min(1.5, (0.3 * f1_seed + 0.2 * f2_seed - 0.1 * f3_seed + (nw_use_f5 ? 0.10 * f5_seed : 0.0)) * 0.5))
            array.set(sssm.mu_out, j, mu_init)
            array.set(sssm.mu_out_scored, j, mu_init)
            if b8_udt_enabled
                array.set(sssm.mu_out_vix, j, f1_seed)
                array.set(sssm.mu_out_horc, j, f2_seed)
                array.set(sssm.mu_out_bei, j, f3_seed)
        log.info("FROZENLOAD,ok=1,K=" + str.tostring(K_REG) + ",mode=" + frozen_mode + ",pack=" + frozen_pack_mode)
    else
        frozen_parse_error := true
        model_source := "PARSE_ERROR"
        log.info("FROZENLOAD,ok=0,K=" + str.tostring(K_REG) + ",pack=" + frozen_pack_mode + ",fallback=BLOCKED")

// ─── Pass-B B2: K-means++ initialization for K_REG regime centroids ───────────
// Single-bar execution gated to fire once per training session when:
//   1) rb ring buffer is full (rb.count >= rb.capacity)
//   2) SSSM not yet seeded
//   3) Training mode enabled OR running in heavy compute window
// Output: K_REG RG.GaussianRegime pushed into sssm.regimes, each with:
//   - mu       = centroid coordinate (3-dim: F1/F2/F3)
//   - Sigma / Sigma_inv = identity (seed; refined by EM in B5)
//   - F        = identity (state-transition seed)
//   - Q_diag   = ones (process noise seed)
//   - prior    = 1/K_REG
// Diagnostic: log.info("B2KMEANS,...") emits inertia + drift per Lloyd iter.
// B2 gate with bar-anchored option + NA coverage guard
bool b2_buffer_ready = rb.count >= rb.capacity
bool b2_terminal_training = mode_in == "training" and barstate.islastconfirmedhistory
bool b2_timing_gate = b2_terminal_training ? b2_buffer_ready : (b2_anchor_bar_offset < 0 ? b2_buffer_ready : (bar_index >= b2_anchor_bar_offset and b2_buffer_ready))
bool b2_mode_gate = b2_terminal_training or (mode_in != "training" and compute_active)
bool b2_gate = b2_timing_gate and not sssm_seeded and b2_mode_gate and not frozen_parse_error

// B2 gate diagnostic: log every evaluation attempt (throttled to avoid spam)
if b2_buffer_ready and not sssm_seeded and bar_index % 50 == 0
    log.info("B2GATE,bar=" + str.tostring(bar_index) + ",offset=" + str.tostring(b2_anchor_bar_offset) + ",rb_count=" + str.tostring(rb.count) + ",timing_gate=" + str.tostring(b2_timing_gate) + ",mode_gate=" + str.tostring(b2_mode_gate) + ",final_gate=" + str.tostring(b2_gate))

if b2_gate
    int kN = rb.capacity
    int kK = K_REG
    int feat_dim = 3 + (nw_use_f5 ? 1 : 0)
    // B2.0: NA coverage guard — count non-NA bars in each factor's sample window
    int na_count_f1 = 0
    int na_count_f2 = 0
    int na_count_f3 = 0
    int na_count_f5 = 0
    for i = 0 to kN - 1
        if na(array.get(rb.f1, i))
            na_count_f1 += 1
        if na(array.get(rb.f2, i))
            na_count_f2 += 1
        if na(array.get(rb.f3, i))
            na_count_f3 += 1
        if nw_use_f5 and na(array.get(rb.f5, i))
            na_count_f5 += 1
    float coverage_f1 = 1.0 - float(na_count_f1) / float(kN)
    float coverage_f2 = 1.0 - float(na_count_f2) / float(kN)
    float coverage_f3 = 1.0 - float(na_count_f3) / float(kN)
    float coverage_f5 = nw_use_f5 ? 1.0 - float(na_count_f5) / float(kN) : 1.0
    float min_coverage = math.min(math.min(coverage_f1, coverage_f2), math.min(coverage_f3, coverage_f5))
    bool b2_na_gate_pass = min_coverage >= b2_min_na_coverage
    
    // Log NA coverage decision (pass or block)
    if not b2_na_gate_pass
        log.info("B2KMEANS,BLOCKED_NA_COVERAGE,bar=" + str.tostring(bar_index) + ",min_coverage=" + str.tostring(min_coverage, "#.###") + ",threshold=" + str.tostring(b2_min_na_coverage, "#.###") + ",f1=" + str.tostring(coverage_f1, "#.###") + ",f2=" + str.tostring(coverage_f2, "#.###") + ",f3=" + str.tostring(coverage_f3, "#.###"))
    else
        log.info("B2KMEANS,NA_GATE_PASS,bar=" + str.tostring(bar_index) + ",dim=" + str.tostring(feat_dim) + ",min_coverage=" + str.tostring(min_coverage, "#.###") + ",f1=" + str.tostring(coverage_f1, "#.###") + ",f2=" + str.tostring(coverage_f2, "#.###") + ",f3=" + str.tostring(coverage_f3, "#.###") + ",f5=" + str.tostring(coverage_f5, "#.###"))
    
    if b2_na_gate_pass
        // B2.1: snapshot points from ring buffer (order irrelevant for K-means).
        // Clip |z|>5 outliers BEFORE K-means input — prevents extreme tail points
        // from being chosen as centroid seeds (run-mode dead-regime-4 root cause).
        // Tail points are still classified at runtime by B3 against the cleaned
        // centroids; only the seed selection is shielded.
        float CLIP_Z = 5.0
        array<float> pts_f1 = array.new<float>(kN, na)
        array<float> pts_f2 = array.new<float>(kN, na)
        array<float> pts_f3 = array.new<float>(kN, na)
        array<float> pts_f5 = array.new<float>(kN, na)
        array<float> pts_aw  = array.new<float>(kN, 1.0)  // admission weight per slot
        int adm_b2_admitted = 0
        for i = 0 to kN - 1
            int idx_f1 = i
            int idx_f2 = sep_null_test ? (i + 17) % kN : i
            int idx_f3 = sep_null_test ? (i + 31) % kN : i
            int idx_f5 = sep_null_test ? (i + 59) % kN : i
            float aw_i = nz(array.get(rb.adm_weight, i), 1.0)
            array.set(pts_f1, i, math.max(-CLIP_Z, math.min(CLIP_Z, nz(array.get(rb.f1, idx_f1)))))
            array.set(pts_f2, i, math.max(-CLIP_Z, math.min(CLIP_Z, nz(array.get(rb.f2, idx_f2)))))
            array.set(pts_f3, i, math.max(-CLIP_Z, math.min(CLIP_Z, nz(array.get(rb.f3, idx_f3)))))
            array.set(pts_f5, i, nw_use_f5 ? math.max(-CLIP_Z, math.min(CLIP_Z, nz(array.get(rb.f5, idx_f5)))) : 0.0)
            array.set(pts_aw,  i, aw_i)
            if aw_i > 0.0
                adm_b2_admitted += 1
        // Guardrail: if admission filter starves the sample below min_samples floor, disable it.
        bool adm_b2_active = adm_b2_admitted >= adm_min_samp
        if not adm_b2_active
            for i = 0 to kN - 1
                array.set(pts_aw, i, 1.0)
            log.info("ADMB2,FALLBACK,admitted=" + str.tostring(adm_b2_admitted) + ",min=" + str.tostring(adm_min_samp) + " — gates disabled for this B2 seed")
        else
            log.info("ADMB2,admitted=" + str.tostring(adm_b2_admitted) + "/" + str.tostring(kN))
        if sep_null_test
            log.info("SEPNULL,mode=shifted_marginals,kN=" + str.tostring(kN) + ",offsets=0_17_31_43_59")
        // B2.2: K-means++ seed centroids (deterministic RNG seeded by km_seed input).
        array<float> cx = array.new<float>(kK, 0.0)
        array<float> cy = array.new<float>(kK, 0.0)
        array<float> cz = array.new<float>(kK, 0.0)
        array<float> cv = array.new<float>(kK, 0.0)
        // Deterministic RNG: seed0 = hash(km_seed + 0) mod kN
        float rnd0 = math.sin(float(km_seed_eff) * 12.9898 + 0.0 * 78.233) * 43758.5453
        rnd0 := rnd0 - math.floor(rnd0)
        int seed0 = int(math.min(rnd0 * float(kN), float(kN - 1)))
        seed0 := math.max(0, math.min(seed0, kN - 1))
        if seed0 >= 0 and seed0 < array.size(pts_f1)
            array.set(cx, 0, array.get(pts_f1, seed0))
        else
            array.set(cx, 0, 0.0)
        if seed0 >= 0 and seed0 < array.size(pts_f2)
            array.set(cy, 0, array.get(pts_f2, seed0))
        else
            array.set(cy, 0, 0.0)
        if seed0 >= 0 and seed0 < array.size(pts_f3)
            array.set(cz, 0, array.get(pts_f3, seed0))
        else
            array.set(cz, 0, 0.0)
        if seed0 >= 0 and seed0 < array.size(pts_f5)
            array.set(cv, 0, array.get(pts_f5, seed0))
        else
            array.set(cv, 0, 0.0)
        for k = 1 to kK - 1
            float total_d2 = 0.0
            array<float> d2 = array.new<float>(kN, 0.0)
            for i = 0 to kN - 1
                float min_d2 = 1e10
                float px = array.get(pts_f1, i)
                float py = array.get(pts_f2, i)
                float pz = array.get(pts_f3, i)
                float pv = array.get(pts_f5, i)
                float aw_i = array.get(pts_aw, i)
                for j = 0 to k - 1
                    float dx = px - array.get(cx, j)
                    float dy = py - array.get(cy, j)
                    float dz = pz - array.get(cz, j)
                    float dv = pv - array.get(cv, j)
                    float d = dx * dx + dy * dy + dz * dz + (nw_use_f5 ? dv * dv : 0.0)
                    if d < min_d2
                        min_d2 := d
                float wd2 = min_d2 * aw_i  // admission-weighted D² for K-means++ sampling
                array.set(d2, i, wd2)
                total_d2 += wd2
            // Deterministic RNG: seedk = hash(km_seed + k) mod total_d2
            float rndk = math.sin(float(km_seed_eff) * 12.9898 + float(k) * 31.4159) * 43758.5453
            rndk := rndk - math.floor(rndk)
            float target = rndk * total_d2
            float cum = 0.0
            int pick = kN - 1
            bool found = false
            for i = 0 to kN - 1
                if not found
                    cum += array.get(d2, i)
                    if cum >= target
                        pick := i
                        found := true
            array.set(cx, k, array.get(pts_f1, pick))
            array.set(cy, k, array.get(pts_f2, pick))
            array.set(cz, k, array.get(pts_f3, pick))
            array.set(cv, k, array.get(pts_f5, pick))
        // B2.3: Lloyd iterations (KM_ITERS passes).
        array<int> assign = array.new<int>(kN, 0)
        for it = 0 to KM_ITERS - 1
            // E-step: assign each point to nearest centroid.
            float inertia = 0.0
            for i = 0 to kN - 1
                float px_l = array.get(pts_f1, i)
                float py_l = array.get(pts_f2, i)
                float pz_l = array.get(pts_f3, i)
                float pv_l = array.get(pts_f5, i)
                int best = 0
                float best_d = 1e20
                for j = 0 to kK - 1
                    float dx_l = px_l - array.get(cx, j)
                    float dy_l = py_l - array.get(cy, j)
                    float dz_l = pz_l - array.get(cz, j)
                    float dv_l = pv_l - array.get(cv, j)
                    float d_l = dx_l * dx_l + dy_l * dy_l + dz_l * dz_l + (nw_use_f5 ? dv_l * dv_l : 0.0)
                    if d_l < best_d
                        best_d := d_l
                        best := j
                array.set(assign, i, best)
                inertia += best_d
            // M-step: recompute centroids.
            array<float> sx = array.new<float>(kK, 0.0)
            array<float> sy = array.new<float>(kK, 0.0)
            array<float> sz = array.new<float>(kK, 0.0)
            array<float> sv = array.new<float>(kK, 0.0)
            array<int>   cn = array.new<int>(kK, 0)
            for i = 0 to kN - 1
                int g = array.get(assign, i)
                float aw_m = array.get(pts_aw, i)  // admission weight for M-step
                array.set(sx, g, array.get(sx, g) + aw_m * array.get(pts_f1, i))
                array.set(sy, g, array.get(sy, g) + aw_m * array.get(pts_f2, i))
                array.set(sz, g, array.get(sz, g) + aw_m * array.get(pts_f3, i))
                array.set(sv, g, array.get(sv, g) + aw_m * array.get(pts_f5, i))
                array.set(cn, g, array.get(cn, g) + int(math.round(aw_m)))
            float drift = 0.0
            for j = 0 to kK - 1
                float w_j = 0.0
                for i = 0 to kN - 1
                    if array.get(assign, i) == j
                        w_j += array.get(pts_aw, i)
                if w_j > 1e-10
                    float new_x = array.get(sx, j) / w_j
                    float new_y = array.get(sy, j) / w_j
                    float new_z = array.get(sz, j) / w_j
                    float new_v = array.get(sv, j) / w_j
                    float dxc = new_x - array.get(cx, j)
                    float dyc = new_y - array.get(cy, j)
                    float dzc = new_z - array.get(cz, j)
                    float dvc = new_v - array.get(cv, j)
                    drift += math.sqrt(dxc * dxc + dyc * dyc + dzc * dzc + (nw_use_f5 ? dvc * dvc : 0.0))
                    array.set(cx, j, new_x)
                    array.set(cy, j, new_y)
                    array.set(cz, j, new_z)
                    array.set(cv, j, new_v)
                else
                    // Empty-cluster fallback: re-seed centroid j to the point with
                    // the largest min-distance to any OTHER centroid. Prevents the
                    // dead-regime artefact where K-means++ picked an isolated
                    // outlier as seed and no point ever assigns back to it.
                    int   worst_i  = 0
                    float worst_d2 = -1.0
                    for i = 0 to kN - 1
                        float min_d2 = 1e20
                        for jj = 0 to kK - 1
                            if jj != j
                                float dx = array.get(pts_f1, i) - array.get(cx, jj)
                                float dy = array.get(pts_f2, i) - array.get(cy, jj)
                                float dz = array.get(pts_f3, i) - array.get(cz, jj)
                                float dv = array.get(pts_f5, i) - array.get(cv, jj)
                                float d2 = dx * dx + dy * dy + dz * dz + (nw_use_f5 ? dv * dv : 0.0)
                                if d2 < min_d2
                                    min_d2 := d2
                        if min_d2 > worst_d2
                            worst_d2 := min_d2
                            worst_i  := i
                    array.set(cx, j, array.get(pts_f1, worst_i))
                    array.set(cy, j, array.get(pts_f2, worst_i))
                    array.set(cz, j, array.get(pts_f3, worst_i))
                    array.set(cv, j, array.get(pts_f5, worst_i))
                    log.info("B2KMEANS,empty_cluster_reseed,j=" + str.tostring(j) + ",iter=" + str.tostring(it) + ",worst_i=" + str.tostring(worst_i) + ",worst_d2=" + str.tostring(worst_d2, "#.###"))
            int b2_repel_moves = 0
            if b2_repulse_lambda > 0.0
                for j = 0 to kK - 2
                    for k = j + 1 to kK - 1
                        float _rdx = array.get(cx, j) - array.get(cx, k)
                        float _rdy = array.get(cy, j) - array.get(cy, k)
                        float _rdz = array.get(cz, j) - array.get(cz, k)
                        float _rdv = nw_use_f5 ? array.get(cv, j) - array.get(cv, k) : 0.0
                        float _rd2 = _rdx * _rdx + _rdy * _rdy + _rdz * _rdz + _rdv * _rdv
                        float _rd = math.sqrt(_rd2)
                        if _rd < b2_min_seed_sep
                            float _ux = _rd > 1e-6 ? _rdx / _rd : 0.0
                            float _uy = _rd > 1e-6 ? _rdy / _rd : (j % 2 == 0 ? 1.0 : -1.0)
                            float _uz = _rd > 1e-6 ? _rdz / _rd : 0.0
                            float _uv = _rd > 1e-6 and nw_use_f5 ? _rdv / _rd : 0.0
                            float _rpush = math.min(0.25, b2_repulse_lambda / math.max(_rd2, 0.05))
                            array.set(cx, j, array.get(cx, j) + _ux * _rpush)
                            array.set(cy, j, array.get(cy, j) + _uy * _rpush)
                            array.set(cz, j, array.get(cz, j) + _uz * _rpush)
                            array.set(cv, j, nw_use_f5 ? array.get(cv, j) + _uv * _rpush : array.get(cv, j))
                            array.set(cx, k, array.get(cx, k) - _ux * _rpush)
                            array.set(cy, k, array.get(cy, k) - _uy * _rpush)
                            array.set(cz, k, array.get(cz, k) - _uz * _rpush)
                            array.set(cv, k, nw_use_f5 ? array.get(cv, k) - _uv * _rpush : array.get(cv, k))
                            b2_repel_moves += 1
            log.info("B2KMEANS,iter=" + str.tostring(it) + ",inertia=" + str.tostring(inertia, "#.######") + ",drift=" + str.tostring(drift, "#.######") + ",repel=" + str.tostring(b2_repel_moves))
        float b2_mean_x = 0.0
        float b2_mean_y = 0.0
        float b2_mean_z = 0.0
        float b2_mean_v = 0.0
        for i = 0 to kN - 1
            b2_mean_x += array.get(pts_f1, i)
            b2_mean_y += array.get(pts_f2, i)
            b2_mean_z += array.get(pts_f3, i)
            b2_mean_v += array.get(pts_f5, i)
        b2_mean_x /= float(kN)
        b2_mean_y /= float(kN)
        b2_mean_z /= float(kN)
        b2_mean_v /= float(kN)
        float b2_var_x = 0.0
        float b2_var_y = 0.0
        float b2_var_z = 0.0
        float b2_var_v = 0.0
        for i = 0 to kN - 1
            float _vx = array.get(pts_f1, i) - b2_mean_x
            float _vy = array.get(pts_f2, i) - b2_mean_y
            float _vz = array.get(pts_f3, i) - b2_mean_z
            float _vv = array.get(pts_f5, i) - b2_mean_v
            b2_var_x += _vx * _vx
            b2_var_y += _vy * _vy
            b2_var_z += _vz * _vz
            b2_var_v += nw_use_f5 ? _vv * _vv : 0.0
        int b2_pc_axis = b2_var_y >= b2_var_x and b2_var_y >= b2_var_z and b2_var_y >= b2_var_v ? 1 : b2_var_x >= b2_var_z and b2_var_x >= b2_var_v ? 0 : b2_var_z >= b2_var_v ? 2 : 4
        int b2_sep_moves = 0
        if b2_min_seed_sep > 0.0
            for j = 0 to kK - 2
                for k = j + 1 to kK - 1
                    float _dxs = array.get(cx, j) - array.get(cx, k)
                    float _dys = array.get(cy, j) - array.get(cy, k)
                    float _dzs = array.get(cz, j) - array.get(cz, k)
                    float _dvs = array.get(cv, j) - array.get(cv, k)
                    float _sep = math.sqrt(_dxs * _dxs + _dys * _dys + _dzs * _dzs + (nw_use_f5 ? _dvs * _dvs : 0.0))
                    if _sep < b2_min_seed_sep
                        float _norm_j = math.sqrt(array.get(cx, j) * array.get(cx, j) + array.get(cy, j) * array.get(cy, j) + array.get(cz, j) * array.get(cz, j) + (nw_use_f5 ? array.get(cv, j) * array.get(cv, j) : 0.0))
                        float _norm_k = math.sqrt(array.get(cx, k) * array.get(cx, k) + array.get(cy, k) * array.get(cy, k) + array.get(cz, k) * array.get(cz, k) + (nw_use_f5 ? array.get(cv, k) * array.get(cv, k) : 0.0))
                        int _move = _norm_j <= _norm_k ? j : k
                        float _axis_val = b2_pc_axis == 0 ? array.get(cx, _move) : b2_pc_axis == 1 ? array.get(cy, _move) : b2_pc_axis == 2 ? array.get(cz, _move) : array.get(cv, _move)
                        float _axis_mean = b2_pc_axis == 0 ? b2_mean_x : b2_pc_axis == 1 ? b2_mean_y : b2_pc_axis == 2 ? b2_mean_z : b2_mean_v
                        float _sign = _axis_val >= _axis_mean ? 1.0 : -1.0
                        _sign := math.abs(_axis_val - _axis_mean) < 1e-6 ? (_move == j ? -1.0 : 1.0) : _sign
                        float _new_axis = _axis_mean + _sign * b2_min_seed_sep
                        if b2_pc_axis == 0
                            array.set(cx, _move, _new_axis)
                        else if b2_pc_axis == 1
                            array.set(cy, _move, _new_axis)
                        else if b2_pc_axis == 2
                            array.set(cz, _move, _new_axis)
                        else
                            array.set(cv, _move, nw_use_f5 ? _new_axis : array.get(cv, _move))
                        b2_sep_moves += 1
                        log.info("B2KMEANS,min_sep_displace,pair=" + str.tostring(j) + ":" + str.tostring(k) + ",move=" + str.tostring(_move) + ",axis=" + str.tostring(b2_pc_axis) + ",sep=" + str.tostring(_sep, "#.###") + ",new_axis=" + str.tostring(_new_axis, "#.###"))
        if b2_sep_moves > 0
            log.info("B2KMEANS,min_sep_done,moves=" + str.tostring(b2_sep_moves) + ",threshold=" + str.tostring(b2_min_seed_sep, "#.###") + ",axis=" + str.tostring(b2_pc_axis))
        array<float> b2_cn = array.new<float>(kK, 0.0)
        array<float> b2_sx = array.new<float>(kK, 0.0)
        array<float> b2_sy = array.new<float>(kK, 0.0)
        array<float> b2_sz = array.new<float>(kK, 0.0)
        array<float> b2_sv = array.new<float>(kK, 0.0)
        array<float> b2_sxx = array.new<float>(kK, 0.0)
        array<float> b2_syy = array.new<float>(kK, 0.0)
        array<float> b2_szz = array.new<float>(kK, 0.0)
        array<float> b2_svv = array.new<float>(kK, 0.0)
        array<float> b2_sxy = array.new<float>(kK, 0.0)
        array<float> b2_sxz = array.new<float>(kK, 0.0)
        array<float> b2_syz = array.new<float>(kK, 0.0)
        float b2_total_w = 0.0
        for i = 0 to kN - 1
            float px = array.get(pts_f1, i)
            float py = array.get(pts_f2, i)
            float pz = array.get(pts_f3, i)
            float pv = nw_use_f5 ? array.get(pts_f5, i) : 0.0
            float aw = math.max(nz(array.get(pts_aw, i), 1.0), 0.0)
            int best = 0
            float best_d2 = 1e20
            for j = 0 to kK - 1
                float dx = px - array.get(cx, j)
                float dy = py - array.get(cy, j)
                float dz = pz - array.get(cz, j)
                float dv = pv - array.get(cv, j)
                float d2 = dx * dx + dy * dy + dz * dz + (nw_use_f5 ? dv * dv : 0.0)
                if d2 < best_d2
                    best_d2 := d2
                    best := j
            array.set(b2_cn, best, array.get(b2_cn, best) + aw)
            array.set(b2_sx, best, array.get(b2_sx, best) + aw * px)
            array.set(b2_sy, best, array.get(b2_sy, best) + aw * py)
            array.set(b2_sz, best, array.get(b2_sz, best) + aw * pz)
            array.set(b2_sv, best, array.get(b2_sv, best) + aw * pv)
            array.set(b2_sxx, best, array.get(b2_sxx, best) + aw * px * px)
            array.set(b2_syy, best, array.get(b2_syy, best) + aw * py * py)
            array.set(b2_szz, best, array.get(b2_szz, best) + aw * pz * pz)
            array.set(b2_svv, best, array.get(b2_svv, best) + aw * pv * pv)
            array.set(b2_sxy, best, array.get(b2_sxy, best) + aw * px * py)
            array.set(b2_sxz, best, array.get(b2_sxz, best) + aw * px * pz)
            array.set(b2_syz, best, array.get(b2_syz, best) + aw * py * pz)
            b2_total_w += aw
        float b2_sil_sum = 0.0
        float b2_sil_w = 0.0
        float b2_explain_w = 0.0
        for i = 0 to kN - 1
            int _sil_g = array.get(assign, i)
            float _sil_px = array.get(pts_f1, i)
            float _sil_py = array.get(pts_f2, i)
            float _sil_pz = array.get(pts_f3, i)
            float _sil_pv = array.get(pts_f5, i)
            float _sil_aw = math.max(nz(array.get(pts_aw, i), 1.0), 0.0)
            float _sil_dx = _sil_px - array.get(cx, _sil_g)
            float _sil_dy = _sil_py - array.get(cy, _sil_g)
            float _sil_dz = _sil_pz - array.get(cz, _sil_g)
            float _sil_dv = _sil_pv - array.get(cv, _sil_g)
            float _sil_a = math.sqrt(_sil_dx * _sil_dx + _sil_dy * _sil_dy + _sil_dz * _sil_dz + (nw_use_f5 ? _sil_dv * _sil_dv : 0.0))
            float _sil_b = na
            for _sil_k = 0 to kK - 1
                if _sil_k != _sil_g
                    float _sil_bx = _sil_px - array.get(cx, _sil_k)
                    float _sil_by = _sil_py - array.get(cy, _sil_k)
                    float _sil_bz = _sil_pz - array.get(cz, _sil_k)
                    float _sil_bv = _sil_pv - array.get(cv, _sil_k)
                    float _sil_d = math.sqrt(_sil_bx * _sil_bx + _sil_by * _sil_by + _sil_bz * _sil_bz + (nw_use_f5 ? _sil_bv * _sil_bv : 0.0))
                    _sil_b := na(_sil_b) ? _sil_d : math.min(_sil_b, _sil_d)
            float _sil_s = not na(_sil_b) and math.max(_sil_a, _sil_b) > 1e-10 ? (_sil_b - _sil_a) / math.max(_sil_a, _sil_b) : na
            if not na(_sil_s) and _sil_aw > 0.0
                b2_sil_sum += _sil_aw * _sil_s
                b2_sil_w += _sil_aw
                b2_explain_w += _sil_s >= 0.0 ? _sil_aw : 0.0
        b2_train_sil_bar_log := b2_sil_w > 1e-10 ? b2_sil_sum / b2_sil_w : na
        b2_train_explainable_log := b2_sil_w > 1e-10 ? b2_explain_w / b2_sil_w : na
        log.info("B2TRAINHEALTH,sil_bar=" + str.tostring(b2_train_sil_bar_log, "#.####") + ",explainable=" + str.tostring(b2_train_explainable_log, "#.####") + ",N=" + str.tostring(kN) + ",W=" + str.tostring(b2_sil_w, "#.##"))
        for j = 0 to kK - 1
            RG.GaussianRegime rp = RG.GaussianRegime.new()
            rp.mu        := array.new<float>(5, 0.0)
            array.set(rp.mu, 0, array.get(cx, j))
            array.set(rp.mu, 1, array.get(cy, j))
            array.set(rp.mu, 2, array.get(cz, j))
            array.set(rp.mu, 3, 0.0)
            array.set(rp.mu, 4, nw_use_f5 ? array.get(cv, j) : 0.0)
            rp.mu_seed   := array.copy(rp.mu)
            rp.Sigma     := matrix.new<float>(5, 5, 0.0)
            rp.Sigma_inv := matrix.new<float>(5, 5, 0.0)
            rp.F         := matrix.new<float>(5, 5, 0.0)
            for d = 0 to 4
                matrix.set(rp.F, d, d, 1.0)
            rp.Q_diag := array.new<float>(5, 1.0)
            float cn = math.max(array.get(b2_cn, j), 1e-6)
            rp.prior  := b2_total_w > 0.0 ? cn / b2_total_w : 1.0 / float(kK)
            rp.n_eff  := cn
            rp.sum_x  := array.new<float>(5, 0.0)
            rp.sum_xx := matrix.new<float>(5, 5, 0.0)
            array.set(rp.sum_x, 0, array.get(b2_sx, j))
            array.set(rp.sum_x, 1, array.get(b2_sy, j))
            array.set(rp.sum_x, 2, array.get(b2_sz, j))
            array.set(rp.sum_x, 3, 0.0)
            array.set(rp.sum_x, 4, array.get(b2_sv, j))
            matrix.set(rp.sum_xx, 0, 0, array.get(b2_sxx, j))
            matrix.set(rp.sum_xx, 1, 1, array.get(b2_syy, j))
            matrix.set(rp.sum_xx, 2, 2, array.get(b2_szz, j))
            matrix.set(rp.sum_xx, 3, 3, 0.0)
            matrix.set(rp.sum_xx, 4, 4, array.get(b2_svv, j))
            matrix.set(rp.sum_xx, 0, 1, array.get(b2_sxy, j))
            matrix.set(rp.sum_xx, 1, 0, array.get(b2_sxy, j))
            matrix.set(rp.sum_xx, 0, 2, array.get(b2_sxz, j))
            matrix.set(rp.sum_xx, 2, 0, array.get(b2_sxz, j))
            matrix.set(rp.sum_xx, 1, 2, array.get(b2_syz, j))
            matrix.set(rp.sum_xx, 2, 1, array.get(b2_syz, j))
            float inv_cn = 1.0 / cn
            float mx_b2 = array.get(rp.mu, 0)
            float my_b2 = array.get(rp.mu, 1)
            float mz_b2 = array.get(rp.mu, 2)
            float mv_b2 = array.get(rp.mu, 4)
            float v21_rho = 0.10
            matrix.set(rp.Sigma, 0, 0, math.max(0.08, (1.0 - v21_rho) * (array.get(b2_sxx, j) * inv_cn - mx_b2 * mx_b2 + 0.08) + v21_rho))
            matrix.set(rp.Sigma, 1, 1, math.max(0.08, (1.0 - v21_rho) * (array.get(b2_syy, j) * inv_cn - my_b2 * my_b2 + 0.08) + v21_rho))
            matrix.set(rp.Sigma, 2, 2, math.max(0.08, (1.0 - v21_rho) * (array.get(b2_szz, j) * inv_cn - mz_b2 * mz_b2 + 0.08) + v21_rho))
            matrix.set(rp.Sigma, 3, 3, 1.0)
            matrix.set(rp.Sigma, 4, 4, nw_use_f5 ? math.max(0.08, (1.0 - v21_rho) * (array.get(b2_svv, j) * inv_cn - mv_b2 * mv_b2 + 0.08) + v21_rho) : 1.0)
            float cov_xy = (1.0 - v21_rho) * (array.get(b2_sxy, j) * inv_cn - mx_b2 * my_b2)
            float cov_xz = (1.0 - v21_rho) * (array.get(b2_sxz, j) * inv_cn - mx_b2 * mz_b2)
            float cov_yz = (1.0 - v21_rho) * (array.get(b2_syz, j) * inv_cn - my_b2 * mz_b2)
            matrix.set(rp.Sigma, 0, 1, cov_xy)
            matrix.set(rp.Sigma, 1, 0, cov_xy)
            matrix.set(rp.Sigma, 0, 2, cov_xz)
            matrix.set(rp.Sigma, 2, 0, cov_xz)
            matrix.set(rp.Sigma, 1, 2, cov_yz)
            matrix.set(rp.Sigma, 2, 1, cov_yz)
            array<bool> seed_active_dims = array.from(true, true, true, false, nw_use_f5)
            rp.Sigma_inv := KE.f_inverse_covariance3_diag(rp.Sigma, seed_active_dims, 1e-6, 1e-10)
            array.push(sssm.regimes, rp)
            log.info("B2KMEANS,centroid=" + str.tostring(j) + ",dim=" + str.tostring(feat_dim) + ",mu=[" + str.tostring(array.get(cx, j), "#.###") + "," + str.tostring(array.get(cy, j), "#.###") + "," + str.tostring(array.get(cz, j), "#.###") + "]") 
        // B7 semantic prior: initialize μ_out from F-vector centroids.
        // BTC bullish when -VIX↑ (less fear), HORC↑ (rate cuts), BEI moderate.
        for j = 0 to kK - 1
            float f1 = array.get(cx, j)  // -VIX z
            float f2 = array.get(cy, j)  // HORC z
            float f3 = array.get(cz, j)  // BEI z
            float f5 = nw_use_f5 ? array.get(cv, j) : 0.0
            float prior = 0.3 * f1 + 0.2 * f2 - 0.1 * f3 + (nw_use_f5 ? 0.10 * f5 : 0.0)
            float mu_init = math.max(-1.5, math.min(1.5, prior * 0.5))
            array.set(sssm.mu_out, j, mu_init)
            array.set(sssm.mu_out_scored, j, mu_init)
            // B8 IRF: initialize per-factor mu_out from centroid components (toggle-gated).
            if b8_udt_enabled
                array.set(sssm.mu_out_vix,  j, f1)
                array.set(sssm.mu_out_horc, j, f2)
                array.set(sssm.mu_out_bei,  j, f3)
            log.info("B7INIT,regime=" + str.tostring(j) + ",mu_out=" + str.tostring(mu_init, "#.####") + ",centroid=[" + str.tostring(f1, "#.##") + "," + str.tostring(f2, "#.##") + "," + str.tostring(f3, "#.##") + "," + str.tostring(nw_use_f5 ? f5 : na, "#.##") + "]")
        [_seed_sep, _seed_bad, _seed_i, _seed_j, _seed_pairs] = f_regime_sep_diag(sssm.regimes, kK, false, nw_use_f5)
        b2_seed_sep_min_log := _seed_sep
        b2_seed_sep_i_log := _seed_i
        b2_seed_sep_j_log := _seed_j
        b2_seed_pairs_log := _seed_pairs
        b2_seed_mu_i_log := f_regime_mu_vec(sssm.regimes, _seed_i)
        b2_seed_mu_j_log := f_regime_mu_vec(sssm.regimes, _seed_j)
        log.info("B2SEP,seed_sep_min=" + str.tostring(_seed_sep, "#.###") + ",bad=" + str.tostring(_seed_bad) + ",pair=" + str.tostring(_seed_i) + "_" + str.tostring(_seed_j))
        log.info("B2PAIRS,seed," + _seed_pairs)
        log.info("B2MINMU,pair=" + str.tostring(_seed_i) + "_" + str.tostring(_seed_j) + ",mu_" + str.tostring(_seed_i) + "=" + f_regime_mu_vec(sssm.regimes, _seed_i) + ",mu_" + str.tostring(_seed_j) + "=" + f_regime_mu_vec(sssm.regimes, _seed_j))
        sssm_seeded := true
        sssm.active_since_bar := bar_index
        model_source := "B2"
        log.info("B2KMEANS,done,K=" + str.tostring(kK) + ",N=" + str.tostring(kN) + ",bar=" + str.tostring(bar_index) + ",km_seed=" + str.tostring(km_seed_eff) + ",seed0=" + str.tostring(seed0))
// ─── Pass-B B3+B4: Hamilton forward filter + Mahalanobis likelihood + hysteresis
// Replaces B3's flat-prior softmax with the proper recursive filter:
//   1) Predict: α_pred[j] = Σ_i α_prev[i] · Π[i,j]
//   2) Likelihood: L[j] = exp(-D²_j / (2·q_alpha))  (Mahalanobis under Σ_j^{-1})
//   3) Update:  α_filt[j] ∝ α_pred[j] · L[j], renormalize
//   4) Online Π update via soft transition counts ξ_ij = α_prev[i]·Π[i,j]·L[j] / Z,
//      EMA-blended into Π with rate B4_PI_ETA, row-normalised.
//   5) Hysteresis on argmax(α_filt) — same margin/dwell criteria as B3.
// All computations in log-domain where possible (logsumexp pattern).
float B4_PI_ETA = 0.01
bool regime_exit_pending = false
if sssm_seeded
    int b4K = K_REG
    array<float> obs = array.new<float>(5, 0.0)
    array.set(obs, 0, nz(F1r))
    array.set(obs, 1, nz(F2r))
    array.set(obs, 2, nz(F3r))
    array.set(obs, 3, 0.0)
    array.set(obs, 4, nw_use_f5 ? nz(F5) : 0.0)
    // (B4.2) Mahalanobis log-likelihoods.
    array<float> ll = array.new<float>(b4K, 0.0)
    for j = 0 to b4K - 1
        RG.GaussianRegime rp = array.get(sssm.regimes, j)
        float dx = array.get(obs, 0) - array.get(rp.mu, 0)
        float dy = array.get(obs, 1) - array.get(rp.mu, 1)
        float dz = array.get(obs, 2) - array.get(rp.mu, 2)
        float dw = 0.0
        float dv = nw_use_f5 ? array.get(obs, 4) - array.get(rp.mu, 4) : 0.0
        float s00 = matrix.get(rp.Sigma_inv, 0, 0)
        float s01 = matrix.get(rp.Sigma_inv, 0, 1)
        float s02 = matrix.get(rp.Sigma_inv, 0, 2)
        float s11 = matrix.get(rp.Sigma_inv, 1, 1)
        float s12 = matrix.get(rp.Sigma_inv, 1, 2)
        float s22 = matrix.get(rp.Sigma_inv, 2, 2)
        float s44 = matrix.get(rp.Sigma_inv, 4, 4)
        float m1_f1 = lvg_denoise_on and lvg_denoise_target == "F1" ? lvg_m1_inflate : 1.0
        float m1_f2 = lvg_denoise_on and lvg_denoise_target == "F2" ? lvg_m1_inflate : 1.0
        float m1_f3 = lvg_denoise_on and lvg_denoise_target == "F3" ? lvg_m1_inflate : 1.0
        float m1_f5 = lvg_denoise_on and lvg_denoise_target == "F5" and nw_use_f5 ? lvg_m1_inflate : 1.0
        float m1_e1 = lvg_m1_mode == "Sharpen target" ? m1_f1 : 1.0 / m1_f1
        float m1_e2 = lvg_m1_mode == "Sharpen target" ? m1_f2 : 1.0 / m1_f2
        float m1_e3 = lvg_m1_mode == "Sharpen target" ? m1_f3 : 1.0 / m1_f3
        float m1_e5 = lvg_m1_mode == "Sharpen target" ? m1_f5 : 1.0 / m1_f5
        float d2  = dx * dx * s00 * m1_e1 * m1_e1 + 2.0 * dx * dy * s01 * m1_e1 * m1_e2 + 2.0 * dx * dz * s02 * m1_e1 * m1_e3 + dy * dy * s11 * m1_e2 * m1_e2 + 2.0 * dy * dz * s12 * m1_e2 * m1_e3 + dz * dz * s22 * m1_e3 * m1_e3 + (nw_use_f5 ? dv * dv * s44 * m1_e5 * m1_e5 : 0.0)
        array.set(ll, j, math.max(-d2 / (2.0 * math.max(q_alpha, 1e-3)), -10.0))  // FIX 5: LL clamp — prevents spikes when Sigma_inv sharp on outlier bars
    [alpha_pred, filter_log_likelihood, argmax, pmax, p2nd] = RG.f_hamilton_step(sssm.Pi, alpha_filt, ll, b4K)
    sssm.log_likelihood := filter_log_likelihood
    sssm.posterior_active := pmax
    sssm.posterior_runner_up := p2nd
    // (B4.5) Online Π update via soft transition counts. ξ_ij = α_prev[i]·Π[i,j]·L[j]/Z.
    // Use α_filt[j] / α_pred[j] as L[j]/Z (identity from update step).
    // Dirichlet prior: α_diag=5.0 (self-loop), α_off=1.0 (off-diagonal) to prevent absorbing states.
    LRN.f_hmm_transition_em_step(sssm.Pi, alpha_prev, alpha_filt, alpha_pred, b4K, B4_PI_ETA, 5.0, 1.0)
    // ─── Pass-B B5: online EM (sufficient statistics + Σ regularization) ──────
    // E-step: γ_t[j] = α_filt[j] (Hamilton filter posterior already computed).
    // Accumulator: EMA-decayed sufficient stats, decay rate λ = 1/EM_TICK.
    //   n_eff_j  ← (1-λ) n_eff_j  + λ · γ_t[j]
    //   sum_x_j  ← (1-λ) sum_x_j  + λ · γ_t[j] · x_t
    //   sum_xx_j ← (1-λ) sum_xx_j + λ · γ_t[j] · x_t x_t^T
    // M-step every EM_TICK bars: refresh μ_j, Σ_j, Σ_j^{-1} for regimes that
    // have accumulated sufficient mass (n_eff > MIN_N_EFF). Sub-threshold
    // regimes retain B2 seed (identity-Σ, K-means μ).
    // FIX A: TF-scaled λ — half-life proportional to wall-clock time, not bar count.
    //   5m: λ=0.02 (35 bars = 2.9h); 30m: λ=0.0033 (210 bars = 105h = 4.4 days).
    //   Prevents pathological fast-decay on slow TF (forensic: 30m collapse at 38d).
    float tf_minutes = math.max(timeframe.in_seconds() / 60.0, 5.0)
    float EM_LAMBDA  = (1.0 / float(EM_TICK)) * (5.0 / tf_minutes)
    float EM_LAMBDA_EFF = (use_frozen and run_freeze_centroids) or (mode_in == "training" and barstate.islastconfirmedhistory) ? 0.0 : EM_LAMBDA
    float EM_REG     = 0.08
    float EM_REG_AUX = 0.08
    float MIN_N_EFF  = 0.005        // FIX 3: lowered from 0.02 to keep weak regimes updating
    float SHRINKAGE  = 0.10         // FIX 5: lowered 0.10→0.05 to reduce Σ bloat (paired with EM_REG reduction)
    // FIX 1: Posterior floor — 0.1% minimum responsibility per regime.
    //   Prevents one-hot γ_t → ensures all regimes get ≥0.1% mass → n_eff stays above MIN_N_EFF.
    //   Applied to gamma_em (for EM stats), NOT to alpha_filt (for regime assignment).
    float GAMMA_FLOOR = 3e-4  // FIX 4: lowered from 1e-3 to reduce posterior dilution
    // FIX 1: Compute floored gamma_em for EM sufficient stats (separate from alpha_filt).
    array<float> gamma_em = LRN.f_probability_floor_normalize(alpha_filt, b4K, GAMMA_FLOOR)
    // E-step: accumulate sufficient stats using gamma_em (floored), admission-gated.
    // adm_weight_now gates the update contribution: 0 = skip, (0,1] = partial (SOFT), 1 = full.
    float b5_adm_w = adm_weight_now
    bool b5_prior_weighted = frozen_loaded and adm_online_mode == "RefitKeepBest"
    RG.f_accumulate_stats(sssm.regimes, gamma_em, obs, EM_LAMBDA_EFF, b5_adm_w, b4K, b5_prior_weighted, 3)
    // M-step throttled to every EM_TICK bars to amortise 3x3 matrix-inverse cost.
    if EM_LAMBDA_EFF > 0.0 and bar_index % EM_TICK == 0
        int m_updated = 0
        int m_skipped = 0
        for j = 0 to b4K - 1
            RG.GaussianRegime rp = array.get(sssm.regimes, j)
            if rp.mstep(array.from(true, true, true, false, nw_use_f5), EM_REG, EM_REG_AUX, SHRINKAGE, MIN_N_EFF, em_mu_anchor)
                m_updated := m_updated + 1
            else
                m_skipped := m_skipped + 1
        log.info("B5EM,bar=" + str.tostring(bar_index) + ",updated=" + str.tostring(m_updated) + ",skipped=" + str.tostring(m_skipped) + ",adm_w=" + str.tostring(b5_adm_w, "#.###") + ",n_eff=[" + str.tostring(RG.f_n_eff_at(sssm.regimes, 0), "#.###") + "," + str.tostring(RG.f_n_eff_at(sssm.regimes, 1), "#.###") + "," + str.tostring(RG.f_n_eff_at(sssm.regimes, 2), "#.###") + "," + str.tostring(RG.f_n_eff_at(sssm.regimes, 3), "#.###") + "," + str.tostring(RG.f_n_eff_at(sssm.regimes, 4), "#.###") + "," + str.tostring(RG.f_n_eff_at(sssm.regimes, 5), "#.###") + "]")
        // Occupancy floor guard: log regimes below minimum effective samples.
        float adm_n_floor = float(adm_min_samp) * MIN_N_EFF
        for j = 0 to b4K - 1
            float nj = RG.f_n_eff_at(sssm.regimes, j)
            if not na(nj) and nj < adm_n_floor
                log.info("ADMFLOOR,bar=" + str.tostring(bar_index) + ",regime=" + str.tostring(j) + ",n_eff=" + str.tostring(nj, "#.####") + ",floor=" + str.tostring(adm_n_floor, "#.####") + ",adm_w=" + str.tostring(b5_adm_w, "#.###"))
    if mode_in == "training" and barstate.islastconfirmedhistory and not frozen_serialized
        log.info(frozen_pack_mode == "Hex packed" ? serialize_packed(sssm.regimes, K_REG, nw_use_f5) : serialize_regimes(sssm.regimes, K_REG, nw_use_f5))
        frozen_serialized := true
    sssm.posterior_history.push(alpha_filt, alpha_pred)
    [_gamma_smooth, _k_smooth, _gamma_smooth_max, _b6_warmup] = sssm.posterior_history.smooth_one(sssm.Pi, argmax, pmax)
    gamma_smooth := _gamma_smooth
    k_smooth := _k_smooth
    gamma_smooth_max := _gamma_smooth_max
    b6_warmup := _b6_warmup

    // ─── Parallel full-Kim ground-truth pass (KIM_GT_H = 6 look-ahead) ───────
    // Lives alongside the frozen 1-step smoother; never fed to live plots or alerts.
    // Output at bar t is the smoothed posterior for bar t-KIM_GT_H. The Python
    // builder shifts the six gamma_kim_gt_* columns forward by KIM_GT_H so that
    // corpus row i describes bar i. Leading and trailing KIM_GT_H rows are na.

    // Instrument-agnostic session-reset: fire on actual data gaps, not scheduled closures.
    // Threshold = 2× expected bar interval; catches exchange downtime / feed dropout
    // without false-firing on BTC perpetuals that have no scheduled close.
    int _kg_bar_gap_ms   = int(time - nz(time[1]))
    int _kg_expected_ms  = int(timeframe.in_seconds()) * 1000
    bool _kg_transition  = _kg_bar_gap_ms > _kg_expected_ms * 2
    if _kg_transition
        kim_gt_truncate_bars := KIM_GT_H

    // Rolling Pi snapshot: locally-consistent transition matrix for the backward pass.
    if sssm_seeded
        kim_gt_pi := matrix.copy(sssm.Pi)

    // Right-edge truncation: the last KIM_GT_H bars of the panel lack future data.
    // Must use last_bar_index (fixed panel end), NOT replayAnchor which equals bar_index in history.
    bool kim_gt_right_edge = bar_index > last_bar_index - KIM_GT_H

    // Full Kim backward recursion from current bar t down to t-KIM_GT_H.
    bool kim_gt_can_compute = sssm_seeded and sssm.posterior_history.count >= KIM_GT_H and kim_gt_truncate_bars == 0 and not kim_gt_right_edge and barstate.isconfirmed
    if barstate.isconfirmed and sssm_seeded and bar_index % 50 == 0
        log.info("KIMGT,bar=" + str.tostring(bar_index) + ",b6_count=" + str.tostring(sssm.posterior_history.count) + ",truncate=" + str.tostring(kim_gt_truncate_bars) + ",right_edge=" + str.tostring(kim_gt_right_edge) + ",can_compute=" + str.tostring(kim_gt_can_compute) + ",lbi=" + str.tostring(last_bar_index) + ",gkg0=" + str.tostring(array.get(gamma_kim_gt, 0), "#.####"))
    if kim_gt_can_compute
        gamma_kim_gt := sssm.posterior_history.smooth_fixed(kim_gt_pi, KIM_GT_H)
    else
        // Stale or uncomputed bars leave the array zeroed; export masks them as na.
        for j = 0 to b4K - 1
            array.set(gamma_kim_gt, j, 0.0)

    // Decrement post-transition truncation counter.
    if kim_gt_truncate_bars > 0
        kim_gt_truncate_bars := kim_gt_truncate_bars - 1

    // B6 diagnostic logging every EM_TICK bars (post-warmup).
    if bar_index % EM_TICK == 0 and not b6_warmup
        int delta_count = (k_smooth != argmax) ? 1 : 0
        log.info("B6SMOOTH,bar=" + str.tostring(bar_index) + ",horizon=" + str.tostring(B6_HORIZON) + ",b6_count=" + str.tostring(sssm.posterior_history.count) + ",k_smooth=" + str.tostring(k_smooth) + ",k_filt=" + str.tostring(argmax) + ",delta=" + str.tostring(delta_count) + ",gs_max=" + str.tostring(gamma_smooth_max, "#.####") + ",pmax=" + str.tostring(pmax, "#.####"))
    // B6 switch-rate diagnostic (Vector 1.2): every 100 bars.
    if barstate.isconfirmed and bar_index % 100 == 0 and sssm_seeded
        log.info("B6DIAG,bar=" + str.tostring(bar_index) + ",gmm=" + str.tostring(gamma_smooth_max, "#.###") + ",k_active=" + str.tostring(sssm.active_regime) + ",k_smooth=" + str.tostring(k_smooth) + ",delta=" + str.tostring(k_smooth != sssm.active_regime ? 1 : 0) + ",LL=" + str.tostring(sssm.log_likelihood, "#.##"))
    // Save current filter for next bar's predict step.
    for j = 0 to b4K - 1
        array.set(alpha_prev, j, array.get(alpha_filt, j))
    [next_active_regime, next_active_since] = RG.f_hysteresis_state(sssm.active_regime, sssm.active_since_bar, argmax, pmax, p2nd, delta_hyst, hyst_bars, bar_index)
    regime_exit_pending := argmax != next_active_regime
    sssm.active_regime := next_active_regime
    sssm.active_since_bar := next_active_since
    // Record posterior of active regime in rb history (rb.write_idx was already
    // advanced by B1, so previous slot = current bar's slot).
    int prev_idx = (rb.write_idx + rb.capacity - 1) % rb.capacity
    array.set(rb.posterior_active_hist, prev_idx, array.get(alpha_filt, sssm.active_regime))
    // Diagnostic emit every 100 bars (post-seed).
    if bar_index % 100 == 0
        log.info("B4FILTER,bar=" + str.tostring(bar_index) + ",active=" + str.tostring(sssm.active_regime) + ",pmax=" + str.tostring(pmax, "#.####") + ",p2nd=" + str.tostring(p2nd, "#.####") + ",LL=" + str.tostring(sssm.log_likelihood, "#.###") + ",Pi_diag_mean=" + str.tostring(N.f_matrix_diag_mean(sssm.Pi, na), "#.####"))

// ─── Signal confidence gate (B6.conf) ────────────────────────────────────────
// Multiplicative trust: any starved/flat/borderline component collapses confidence to 0.
// MIN_TRUST_NEFF: n_eff threshold for a «fed» regime (empirically ~0.05 at steady state).
float MIN_TRUST_NEFF = 0.05
float n_eff_active   = sssm_seeded ? array.get(sssm.regimes, sssm.active_regime).n_eff : 0.0
float conf_margin    = sssm_seeded ? math.max(sssm.posterior_active - sssm.posterior_runner_up, 0.0) : 0.0
float conf_neff      = sssm_seeded ? math.min(1.0, n_eff_active / MIN_TRUST_NEFF) : 0.0
float conf_smooth    = sssm_seeded ? gamma_smooth_max : 0.0
float signal_confidence = (not b6_warmup) ? math.pow(conf_margin, 0.6) * math.pow(conf_neff, 0.2) * math.pow(conf_smooth, 0.2) : 0.0

// ─── Pass-B B7: Composite output layer (regime-conditional oscillator) ───────
// Compute BTC log-return z-score for regime centroid learning.
float btc_ret_raw = math.log(math.max(close / math.max(nz(close[1]), 1e-5), 1e-5))
float btc_vol_ema = ta.ema(math.abs(btc_ret_raw), 20)
float btc_ret_z = btc_ret_raw / math.max(btc_vol_ema, 1e-6)
// B7.2 — Online μ_out estimation: occupancy-gated EMA, all regimes (Step 1b).
// α_j = alpha_mu_base × alpha_filt[j]: active regime ≈ full rate, dormant near-frozen.
// Closes Q10: inactive regimes no longer accumulate stale centroid drift.
float alpha_mu_base = 0.03  // Occupancy-weighted EMA rate for per-regime conditional mean
if sssm_seeded and not b6_warmup
    int j_active = sssm.active_regime
    // Pass 1: EMA each regime's conditional mean of btc_ret_z (occupancy-weighted).
    // mu_out[j] tracks E[btc_ret_z | regime=j] via slow EMA — this is the raw conditional mean.
    for j = 0 to K_REG - 1
        float occ     = array.get(alpha_filt, j)
        float alpha_j = alpha_mu_base * occ
        float mu_prev = array.get(sssm.mu_out, j)
        array.set(sssm.mu_out, j, mu_prev * (1.0 - alpha_j) + btc_ret_z * alpha_j)
    // Pass 2: Re-center and scale mu_out across regimes to restore dynamic range.
    // The raw conditional means all sit near the grand mean (≈0) because absolute
    // BTC returns are near-zero-mean. Recentering: mu_out[j] := (mu_j - mu_bar) / sigma_bar
    // where mu_bar is the occupancy-weighted grand mean and sigma_bar is cross-regime std.
    // This converts "regime j earns 0.02 vs grand mean 0.01" into a z-score with ±1 range.
    float _b7_wsum = 0.0
    float _b7_mubar = 0.0
    for j = 0 to K_REG - 1
        float occ_j = array.get(alpha_filt, j)
        float mu_j = array.get(sssm.mu_out, j)
        if not na(mu_j)
            _b7_wsum  += occ_j
            _b7_mubar += occ_j * mu_j
    _b7_mubar := _b7_wsum > 1e-8 ? _b7_mubar / _b7_wsum : 0.0
    float _b7_var = 0.0
    for j = 0 to K_REG - 1
        float dev = array.get(sssm.mu_out, j) - _b7_mubar
        _b7_var += dev * dev
    float _b7_sig = math.sqrt(_b7_var / float(K_REG))
    // Only rescale when cross-regime spread is meaningful (avoids div-by-noise at init).
    if _b7_sig > 1e-5
        for j = 0 to K_REG - 1
            float z_j = (array.get(sssm.mu_out, j) - _b7_mubar) / _b7_sig
            // Soft-clamp to ±2 so extreme regimes don't dominate composite.
            array.set(sssm.mu_out_scored, j, math.max(-2.0, math.min(2.0, z_j)))
    array.set(sssm.s_out, j_active, array.get(sssm.s_out, j_active) + btc_ret_z)
    array.set(sssm.n_out, j_active, array.get(sssm.n_out, j_active) + 1.0)
// B7.3 — Composite oscillator: weighted sum of regime centroids by γ_smooth.
if sssm_seeded
    composite := 0.0
    for j = 0 to K_REG - 1
        composite += array.get(gamma_smooth, j) * array.get(sssm.mu_out_scored, j)
    composite_scaled := composite * 2.0 + (b8_enabled and not b6_warmup ? irf_blend_out * _eff_scale : 0.0)
    // Soft clamp: algebraic x/√(1+x²) for gentle saturation (softest, most linear).
    float x_norm = composite_scaled / 1.5
    float clamped = x_norm / math.sqrt(1.0 + x_norm * x_norm)
    macro3f := 50.0 + 50.0 * clamped
// B8.6 — Effective Leading Price Line (macro3f-driven, placed after B7)
// macro3f pressure signal: zone + velocity → algebraic soft-clamp [-1..+1]
float _macroBias  = (macro3f - 50.0) / 50.0
float _macroVel   = _macroBias - nz(_macroBias[1])
float _zonePress  = macro3f < 40.0 ? -(40.0 - macro3f) / 10.0 : (macro3f > 60.0 ? (macro3f - 60.0) / 10.0 : 0.0)
float _macroArg   = (0.65 * _macroBias + 0.25 * _zonePress + 0.10 * _macroVel) * 1.5
float macroLeadSig = _macroArg / math.sqrt(1.0 + _macroArg * _macroArg)
max_bars_back(macroLeadSig, 51)
// Inertial anchor: Kalman(55%) + LinReg(35%) + EMA(10%) — no raw close to avoid price-following
var float _kx = close
var float _kP = 1.0
float _kP2 = _kP + _eff_kalq
float _kg  = _kP2 / (_kP2 + _eff_kalr)
_kx       := _kx + _kg * (close - _kx)
_kP       := (1.0 - _kg) * _kP2
float anchorLead = 0.55 * _kx + 0.35 * ta.linreg(close, int(_eff_anclen), 0) + 0.10 * ta.ema(close, int(_eff_anclen))
// Causal beta inputs: signal at t-H predicts return t-H..t (lookahead-free)
max_bars_back(close, 51)
float _retH = math.log(close / math.max(close[_eff_fwdh], 1e-10))
float _sigH = macroLeadSig[_eff_fwdh]
// Global beta (fallback for neutral zone)
float _vx_mac  = ta.variance(_sigH, int(_eff_betalen))
float _cov_mac = ta.sma(_sigH * _retH, int(_eff_betalen)) - ta.sma(_sigH, int(_eff_betalen)) * ta.sma(_retH, int(_eff_betalen))
float _betaMac = _vx_mac > 1e-10 ? _cov_mac / _vx_mac : 0.0
// Zone-specific betas via conditional SMA (mask = 1 only when in zone H bars ago)
float _maskB = _sigH < -0.10 ? 1.0 : 0.0
float _maskU = _sigH >  0.10 ? 1.0 : 0.0
float _nb    = math.max(ta.sma(_maskB, int(_eff_betalen)), 1e-10)
float _nu    = math.max(ta.sma(_maskU, int(_eff_betalen)), 1e-10)
float _ExB   = ta.sma(_maskB * _sigH,        _eff_betalen) / _nb
float _EyB   = ta.sma(_maskB * _retH,        _eff_betalen) / _nb
float _ExyB  = ta.sma(_maskB * _sigH * _retH, _eff_betalen) / _nb
float _VxB   = ta.sma(_maskB * _sigH * _sigH, _eff_betalen) / _nb - _ExB * _ExB
float _ExU   = ta.sma(_maskU * _sigH,        _eff_betalen) / _nu
float _EyU   = ta.sma(_maskU * _retH,        _eff_betalen) / _nu
float _ExyU  = ta.sma(_maskU * _sigH * _retH, _eff_betalen) / _nu
float _VxU   = ta.sma(_maskU * _sigH * _sigH, _eff_betalen) / _nu - _ExU * _ExU
float _betaBear = _VxB > 1e-10 ? (_ExyB - _ExB * _EyB) / _VxB : _betaMac
float _betaBull = _VxU > 1e-10 ? (_ExyU - _ExU * _EyU) / _VxU : _betaMac
float _betaUse  = macro3f < 40.0 ? _betaBear : (macro3f > 60.0 ? _betaBull : _betaMac)
float _betaSgn  = macro3f < 40.0 ? math.abs(_betaUse) : (macro3f > 60.0 ? math.abs(_betaUse) : _betaUse)
float _betaClip = math.max(math.min(_betaSgn, 0.04), -0.04)
// Hard directional gate: zone-force is final directional constraint, not soft correction
float _atr14   = ta.atr(14)
float _cap     = _atr14 * _eff_atrcp
float _rawGap  = anchorLead * math.exp(_betaClip * macroLeadSig) - anchorLead
float _bearF   = macro3f < 40.0 ? math.min((40.0 - macro3f) / 10.0, 1.0) : 0.0
float _bullF   = macro3f > 60.0 ? math.min((macro3f - 60.0) / 10.0, 1.0) : 0.0
float _zoneGap = _bearF > 0.0 ? -_cap * _bearF : (_bullF > 0.0 ? _cap * _bullF : _rawGap)
float _finalGap = _bearF > 0.0 ? math.min(_rawGap, _zoneGap) : (_bullF > 0.0 ? math.max(_rawGap, _zoneGap) : _rawGap)
float effectiveLead = b8_enabled ? anchorLead + math.max(math.min(_finalGap, _cap), -_cap) : na
// Causal diagnostics
float _leadGap  = nz(effectiveLead - close)
max_bars_back(_leadGap, 51)
var bool _r_seen = false
bool _r_end = false
bool _r_end_up = false
if sssm_seeded and barstate.isconfirmed
    _r_end := _r_seen and sssm.active_since_bar == bar_index
    _r_end_up := _r_end and nz(macro3f[1]) >= 50.0
    _r_seen := true
var int _hr_prev_k = -1
var float _hr_start_price = na
if sssm_seeded and barstate.isconfirmed
    int _hr_k = sssm.active_regime
    if _hr_k != _hr_prev_k or na(_hr_start_price)
        _hr_start_price := open
    _hr_prev_k := _hr_k
float _hr_chg_sig = sssm_seeded and not na(_hr_start_price) and _hr_start_price != 0.0 ? close / _hr_start_price - 1.0 : na
float _hr_dir_sig = not na(_hr_chg_sig) and _hr_chg_sig > 0.0 ? 1.0 : not na(_hr_chg_sig) and _hr_chg_sig < 0.0 ? -1.0 : 0.0
float _retH_dir = _retH > 0.0 ? 1.0 : _retH < 0.0 ? -1.0 : 0.0
max_bars_back(_hr_dir_sig, 51)
float _dirHit = _hr_dir_sig[_eff_fwdh] != 0.0 and _retH_dir != 0.0 ? (_hr_dir_sig[_eff_fwdh] == _retH_dir ? 1.0 : 0.0) : na
float lead_hit  = ta.sma(_dirHit, 300)
float lead_corr = ta.correlation(_leadGap[_eff_fwdh], _retH, 300)
float irf_realized_err_atr = not na(effectiveLead[_eff_fwdh]) and not na(_atr14[_eff_fwdh]) ? (close - effectiveLead[_eff_fwdh]) / math.max(_atr14[_eff_fwdh], syminfo.mintick) : na
float irf_realized_mae_atr = ta.sma(math.abs(irf_realized_err_atr), 300)
// B7.6 — Periodic diagnostic log (every 200 bars post-warmup).
if barstate.isconfirmed and bar_index % 200 == 0 and sssm_seeded and not b6_warmup
    log.info("B7_OUT,bar=" + str.tostring(bar_index) + 
             ",μ=[" + str.tostring(N.f_safe_get_f(sssm.mu_out_scored, 0),"#.##") + "," + 
                       str.tostring(N.f_safe_get_f(sssm.mu_out_scored, 1),"#.##") + "," +
                       str.tostring(N.f_safe_get_f(sssm.mu_out_scored, 2),"#.##") + "," +
                       str.tostring(N.f_safe_get_f(sssm.mu_out_scored, 3),"#.##") + "," +
                       str.tostring(N.f_safe_get_f(sssm.mu_out_scored, 4),"#.##") + "," +
                       str.tostring(N.f_safe_get_f(sssm.mu_out_scored, 5),"#.##") + "]" +
             ",comp=" + str.tostring(composite, "#.####") +
             ",macro3f=" + str.tostring(macro3f, "#.##"))
    // B9 diagnostic log (disabled until toggle invariance passes)
    // if b9_enable
    //     log.info("B9LOG,enable=" + str.tostring(b9_enable) + ",composite=" + str.tostring(composite, "#.####"))

// Fixed-size ring buffers for causality layer. O(1) per-bar writes; chronological
// snapshots reconstructed only at te_tick (every ete_recompute bars) for the TE
// consumer which requires ordered input. Replaces array.push+shift anti-pattern (C6).
int max_arr = te_win_slow + math.max(te_lag_max_vix, math.max(te_lag_max_horc, te_lag_max_bei)) + 10
var array<float> te_btc  = array.new<float>(max_arr, na)
var array<float> te_vix  = array.new<float>(max_arr, na)
var array<float> te_horc = array.new<float>(max_arr, na)
var array<float> te_bei  = array.new<float>(max_arr, na)
var int  rb_te_w   = 0
var bool rb_te_full = false
float btc_ret = math.log(math.max(close / math.max(nz(close[1]), 1e-5), 1e-5))
float btc_vol = ta.rma(math.abs(btc_ret), 20)

array.set(te_btc,  rb_te_w, btc_ret)
array.set(te_vix,  rb_te_w, nz(F1))
array.set(te_horc, rb_te_w, nz(F2))
array.set(te_bei,  rb_te_w, nz(F3))
rb_te_w := (rb_te_w + 1) % max_arr
if rb_te_w == 0
    rb_te_full := true

int   eff_vix  = math.max(te_lag_min_vix,  te_lag_max_vix)
int   eff_horc = math.max(te_lag_min_horc, te_lag_max_horc)
int   eff_bei  = math.max(te_lag_min_bei,  te_lag_max_bei)
int   eff_max  = math.max(eff_vix, math.max(eff_horc, eff_bei))
bool te_tick = (barstate.isconfirmed and (bar_index >= last_bar_index - te_hist_bars or barstate.isrealtime) and bar_index > te_win_slow + eff_max + 5)

var CL.EteState ste_vix_f  = CL.f_ete_state_new()
var CL.EteState ste_vix_r  = CL.f_ete_state_new()
var CL.EteState ste_horc_f = CL.f_ete_state_new()
var CL.EteState ste_horc_r = CL.f_ete_state_new()
var CL.EteState ste_bei_f  = CL.f_ete_state_new()
var CL.EteState ste_bei_r  = CL.f_ete_state_new()
// Fixed-size ring buffers for NTE z-score normalization (mean/std consumer — order
// irrelevant). 50 elements covers ~10 ETE cycles for adaptive normalization scale.
var array<float> _rfv_buf = array.new<float>(50, na)
var array<float> _rfh_buf = array.new<float>(50, na)
var array<float> _rfb_buf = array.new<float>(50, na)
var int _rfv_w = 0
var int _rfh_w = 0
var int _rfb_w = 0
var int _rfv_n = 0
var int _rfh_n = 0
var int _rfb_n = 0
var float nte_vix  = 0.0
var float nte_horc = 0.0
var float nte_bei  = 0.0
var int   lag_vix  = 1
var int   lag_horc = 1
var int   lag_bei  = 1

if te_tick
    float coup = math.min(nz(btc_vol) * 50.0, 1.0)
    if bar_index % ete_recompute == 0 and coup >= te_coupling_floor
        // Reconstruct chronological snapshots from ring buffers (oldest → newest).
        array<float> te_btc_o  = array.new<float>(max_arr, na)
        array<float> te_vix_o  = array.new<float>(max_arr, na)
        array<float> te_horc_o = array.new<float>(max_arr, na)
        array<float> te_bei_o  = array.new<float>(max_arr, na)
        for _i = 0 to max_arr - 1
            int _sx = (rb_te_w + _i) % max_arr
            array.set(te_btc_o,  _i, array.get(te_btc,  _sx))
            array.set(te_vix_o,  _i, array.get(te_vix,  _sx))
            array.set(te_horc_o, _i, array.get(te_horc, _sx))
            array.set(te_bei_o,  _i, array.get(te_bei,  _sx))
        [_rfv, _dfv] = CL.f_calculate_te_score(te_btc_o, te_vix_o, te_win_fast, te_bins, te_lag_min_vix)
        [_rrv, _drv] = CL.f_calculate_te_score(te_vix_o, te_btc_o, te_win_fast, te_bins, te_lag_min_vix)
        array.set(_rfv_buf, _rfv_w, _rfv)
        _rfv_w := (_rfv_w + 1) % 50
        if _rfv_n < 50
            _rfv_n := _rfv_n + 1
        float _rfv_s1 = 0.0
        float _rfv_s2 = 0.0
        for _k = 0 to _rfv_n - 1
            float _fv = nz(array.get(_rfv_buf, _k))
            _rfv_s1 += _fv
            _rfv_s2 += _fv * _fv
        float _rfv_mu = _rfv_n > 0 ? _rfv_s1 / float(_rfv_n) : _rfv
        float _rfv_sd = math.max(_rfv_n > 2 ? math.sqrt(math.max(_rfv_s2 / float(_rfv_n) - _rfv_mu * _rfv_mu, 0.0)) : 0.5, 1e-6)
        float pz_vf = math.min(math.abs(_rfv - _rfv_mu) / _rfv_sd, 5.0)
        ste_vix_f := CL.f_ete_state_update(_rfv * coup, pz_vf, _dfv, te_lag_min_vix)
        ste_vix_r := CL.f_ete_state_update(_rrv * coup, pz_vf, _drv, te_lag_min_vix)
        [_rfh, _dfh] = CL.f_calculate_te_score(te_btc_o, te_horc_o, te_win_fast, te_bins, te_lag_min_horc)
        [_rrh, _drh] = CL.f_calculate_te_score(te_horc_o, te_btc_o, te_win_fast, te_bins, te_lag_min_horc)
        array.set(_rfh_buf, _rfh_w, _rfh)
        _rfh_w := (_rfh_w + 1) % 50
        if _rfh_n < 50
            _rfh_n := _rfh_n + 1
        float _rfh_s1 = 0.0
        float _rfh_s2 = 0.0
        for _k = 0 to _rfh_n - 1
            float _fh = nz(array.get(_rfh_buf, _k))
            _rfh_s1 += _fh
            _rfh_s2 += _fh * _fh
        float _rfh_mu = _rfh_n > 0 ? _rfh_s1 / float(_rfh_n) : _rfh
        float _rfh_sd = math.max(_rfh_n > 2 ? math.sqrt(math.max(_rfh_s2 / float(_rfh_n) - _rfh_mu * _rfh_mu, 0.0)) : 0.5, 1e-6)
        float pz_hf = math.min(math.abs(_rfh - _rfh_mu) / _rfh_sd, 5.0)
        ste_horc_f := CL.f_ete_state_update(_rfh * coup, pz_hf, _dfh, te_lag_min_horc)
        ste_horc_r := CL.f_ete_state_update(_rrh * coup, pz_hf, _drh, te_lag_min_horc)
        [_rfb, _dfb] = CL.f_calculate_te_score(te_btc_o, te_bei_o, te_win_fast, te_bins, te_lag_min_bei)
        [_rrb, _drb] = CL.f_calculate_te_score(te_bei_o, te_btc_o, te_win_fast, te_bins, te_lag_min_bei)
        array.set(_rfb_buf, _rfb_w, _rfb)
        _rfb_w := (_rfb_w + 1) % 50
        if _rfb_n < 50
            _rfb_n := _rfb_n + 1
        float _rfb_s1 = 0.0
        float _rfb_s2 = 0.0
        for _k = 0 to _rfb_n - 1
            float _fb = nz(array.get(_rfb_buf, _k))
            _rfb_s1 += _fb
            _rfb_s2 += _fb * _fb
        float _rfb_mu = _rfb_n > 0 ? _rfb_s1 / float(_rfb_n) : _rfb
        float _rfb_sd = math.max(_rfb_n > 2 ? math.sqrt(math.max(_rfb_s2 / float(_rfb_n) - _rfb_mu * _rfb_mu, 0.0)) : 0.5, 1e-6)
        float pz_bf = math.min(math.abs(_rfb - _rfb_mu) / _rfb_sd, 5.0)
        ste_bei_f := CL.f_ete_state_update(_rfb * coup, pz_bf, _dfb, te_lag_min_bei)
        ste_bei_r := CL.f_ete_state_update(_rrb * coup, pz_bf, _drb, te_lag_min_bei)
    else
        ste_vix_f  := CL.f_ete_state_decay(ste_vix_f,  0.95)
        ste_vix_r  := CL.f_ete_state_decay(ste_vix_r,  0.95)
        ste_horc_f := CL.f_ete_state_decay(ste_horc_f, 0.95)
        ste_horc_r := CL.f_ete_state_decay(ste_horc_r, 0.95)
        ste_bei_f  := CL.f_ete_state_decay(ste_bei_f,  0.95)
        ste_bei_r  := CL.f_ete_state_decay(ste_bei_r,  0.95)
    nte_vix  := ste_vix_f.ete_held  - ste_vix_r.ete_held
    nte_horc := ste_horc_f.ete_held - ste_horc_r.ete_held
    nte_bei  := ste_bei_f.ete_held  - ste_bei_r.ete_held
    lag_vix  := math.max(te_lag_min_vix,  ste_vix_f.lag_held)
    lag_horc := math.max(te_lag_min_horc, ste_horc_f.lag_held)
    lag_bei  := math.max(te_lag_min_bei,  ste_bei_f.lag_held)

float nte_v_src     = nz(nte_vix,  0.0)
float nte_h_src     = nz(nte_horc, 0.0)
float nte_b_src     = nz(nte_bei,  0.0)
float nte_vix_slow  = ta.ema(nte_v_src, te_slow_len)
float nte_horc_slow = ta.ema(nte_h_src, te_slow_len)
float nte_bei_slow  = ta.ema(nte_b_src, te_slow_len)

float obs_vix  = F1
float obs_horc = F2
float obs_bei  = F3
if gs_enable
    float _gs_r1   = obs_vix / math.max(ta.stdev(obs_vix, gs_win), 1e-10)
    float _gs_b21  = ta.sma(obs_horc * _gs_r1, gs_win)
    float _gs_r2rw = obs_horc - _gs_b21 * _gs_r1
    float _gs_r2   = _gs_r2rw / math.max(ta.stdev(_gs_r2rw, gs_win), 1e-10)
    float _gs_b31  = ta.sma(obs_bei * _gs_r1, gs_win)
    float _gs_b3r2 = ta.sma(obs_bei * _gs_r2, gs_win)
    float _gs_r3rw = obs_bei - _gs_b31 * _gs_r1 - _gs_b3r2 * _gs_r2
    float _gs_r3   = _gs_r3rw / math.max(ta.stdev(_gs_r3rw, gs_win), 1e-10)
    obs_vix  := _gs_r1
    obs_horc := _gs_r2
    obs_bei  := _gs_r3

// B8.1 — EMA update per-factor mu_out for active regime (toggle-gated for v0.7.5 diagnostic).
if b8_enabled and b8_udt_enabled and sssm_seeded and not b6_warmup
    int j_active = sssm.active_regime
    array.set(sssm.mu_out_vix,  j_active, alpha_mu_base * obs_vix  + (1.0 - alpha_mu_base) * array.get(sssm.mu_out_vix,  j_active))
    array.set(sssm.mu_out_horc, j_active, alpha_mu_base * obs_horc + (1.0 - alpha_mu_base) * array.get(sssm.mu_out_horc, j_active))
    array.set(sssm.mu_out_bei,  j_active, alpha_mu_base * obs_bei  + (1.0 - alpha_mu_base) * array.get(sssm.mu_out_bei,  j_active))

// Granger soft-pass: confidence in [0,1] proportional to |corr| saturating at 0.20.
// Replaces hard threshold sqrt(alpha_sig)≈0.316 which was unreachable on 30m TF
// and collapsed all weights to the floor. NTE magnitudes scaled by Granger confidence.
max_bars_back(F1, 31)  // RE10143 fix: lag_vix series, te_lag_max_vix maxval=30
max_bars_back(F2, 31)  // RE10143 fix: lag_horc series, te_lag_max_horc maxval=30
max_bars_back(F3, 21)  // RE10143 fix: lag_bei series, te_lag_max_bei maxval=20
float _gr_corr_v = ta.correlation(F1[lag_vix],  btc_ret, te_win_slow)
float _gr_corr_h = ta.correlation(F2[lag_horc], btc_ret, te_win_slow)
float _gr_corr_b = ta.correlation(F3[lag_bei],  btc_ret, te_win_slow)
float _gr_sat   = 0.20
float gconf_vix  = math.min(math.abs(nz(_gr_corr_v)) / _gr_sat, 1.0)
float gconf_horc = math.min(math.abs(nz(_gr_corr_h)) / _gr_sat, 1.0)
float gconf_bei  = math.min(math.abs(nz(_gr_corr_b)) / _gr_sat, 1.0)

float _wn_v = gconf_vix  * math.abs(nte_vix_slow)
float _wn_h = gconf_horc * math.abs(nte_horc_slow)
float _wn_b = gconf_bei  * math.abs(nte_bei_slow)
float _wn_sum = math.max(_wn_v + _wn_h + _wn_b, 1e-10)
float _w_v_raw = math.max(0.02, _wn_v / _wn_sum)
float _w_h_raw = math.max(0.02, _wn_h / _wn_sum)
float _w_b_raw = math.max(0.02, _wn_b / _wn_sum)
float _w_norm  = _w_v_raw + _w_h_raw + _w_b_raw
float w_vix  = _w_v_raw / _w_norm
float w_horc = _w_h_raw / _w_norm
float w_bei  = _w_b_raw / _w_norm

// ─── B8 IRF: Impulse-Response Functions (Vector 2) ───────────────────────────
// B8.1 — EMA update per-factor mu_out for active regime.
// MOVED TO AFTER obs_vix/horc/bei DEFINITION (line ~1060)

// B8.3 — EMA-convolution blend (echo model, Step 1c).
// irf_*_out = ta.ema(z_factor, int(H_factor)) computed at global scope above.
if b8_enabled and b8_udt_enabled and sssm_seeded and not b6_warmup
    irf_vix_blend  := irf_vix_out
    irf_horc_blend := irf_horc_out
    irf_bei_blend  := irf_bei_out

// Pass-A2 diagnostic composite: equal-weight z-mean of F1/F2/F3 (placeholder
// until Pass B wires SSSM regime posteriors + IRF responses into core_norm).
float diag_core = (nz(F1) + nz(F2) + nz(F3)) / 3.0
float diag_smooth = ta.ema(diag_core, 5)

plot(diag_smooth, "Macro3F (diag)", color.aqua, 2, force_overlay=false)
plot(F1,          "F1 z(-VIX)",     color.new(color.red,    40), force_overlay=false)
plot(F2,          "F2 z(HORC)",     color.new(color.lime,   40), force_overlay=false)
plot(F3,          "F3 z(BEI)",      color.new(color.yellow, 40), force_overlay=false)
plot(nte_vix_slow,  "NTE VIX",  color.new(color.fuchsia, 60), display=display.data_window, force_overlay=false)
plot(nte_horc_slow, "NTE HORC", color.new(color.fuchsia, 60), display=display.data_window, force_overlay=false)
plot(nte_bei_slow,  "NTE BEI",  color.new(color.fuchsia, 60), display=display.data_window, force_overlay=false)
plot(w_vix,  "w_vix",  display=display.data_window, force_overlay=false)
plot(w_horc, "w_horc", display=display.data_window, force_overlay=false)
plot(w_bei,  "w_bei",  display=display.data_window, force_overlay=false)
hline(0, "Zero", color.gray)

max_bars_back(close, 301)
max_bars_back(F1, 301)
max_bars_back(F2, 301)
max_bars_back(F3, 301)
max_bars_back(macro3f, 101)
float diag_ret_h1 = math.log(close / math.max(close[diag_h1], 1e-10))
float diag_ret_h2 = math.log(close / math.max(close[diag_h2], 1e-10))
float diag_ret_h3 = math.log(close / math.max(close[diag_h3], 1e-10))
float diag_ret_h4 = math.log(close / math.max(close[diag_h4], 1e-10))
float diag_r1_h1 = ta.correlation(F1, diag_ret_h1, diag_table_window)
float diag_r2_h1 = ta.correlation(F2, diag_ret_h1, diag_table_window)
float diag_r3_h1 = ta.correlation(F3, diag_ret_h1, diag_table_window)
float diag_r1_h2 = ta.correlation(F1, diag_ret_h2, diag_table_window)
float diag_r2_h2 = ta.correlation(F2, diag_ret_h2, diag_table_window)
float diag_r3_h2 = ta.correlation(F3, diag_ret_h2, diag_table_window)
float diag_r1_h3 = ta.correlation(F1, diag_ret_h3, diag_table_window)
float diag_r2_h3 = ta.correlation(F2, diag_ret_h3, diag_table_window)
float diag_r3_h3 = ta.correlation(F3, diag_ret_h3, diag_table_window)
float diag_r1_h4 = ta.correlation(F1, diag_ret_h4, diag_table_window)
float diag_r2_h4 = ta.correlation(F2, diag_ret_h4, diag_table_window)
float diag_r3_h4 = ta.correlation(F3, diag_ret_h4, diag_table_window)
float diag_total_factor = (nz(F1) + nz(F2) + nz(F3)) / 3.0
float diag_total_r_h1 = ta.correlation(diag_total_factor, diag_ret_h1, diag_table_window)
float diag_total_r_h2 = ta.correlation(diag_total_factor, diag_ret_h2, diag_table_window)
float diag_total_r_h3 = ta.correlation(diag_total_factor, diag_ret_h3, diag_table_window)
float diag_total_r_h4 = ta.correlation(diag_total_factor, diag_ret_h4, diag_table_window)
float diag_total_r2_h1 = na(diag_total_r_h1) ? na : diag_total_r_h1 * diag_total_r_h1
float diag_total_r2_h2 = na(diag_total_r_h2) ? na : diag_total_r_h2 * diag_total_r_h2
float diag_total_r2_h3 = na(diag_total_r_h3) ? na : diag_total_r_h3 * diag_total_r_h3
float diag_total_r2_h4 = na(diag_total_r_h4) ? na : diag_total_r_h4 * diag_total_r_h4
float diag_macro_sig = (macro3f - 50.0) / 50.0
float diag_macro_r_h1 = ta.correlation(diag_macro_sig[diag_h1], diag_ret_h1, diag_table_window)
float diag_macro_r_h2 = ta.correlation(diag_macro_sig[diag_h2], diag_ret_h2, diag_table_window)
float diag_macro_r_h3 = ta.correlation(diag_macro_sig[diag_h3], diag_ret_h3, diag_table_window)
float diag_macro_r_h4 = ta.correlation(diag_macro_sig[diag_h4], diag_ret_h4, diag_table_window)
float diag_macro_r2_h1 = na(diag_macro_r_h1) ? na : diag_macro_r_h1 * diag_macro_r_h1
float diag_macro_r2_h2 = na(diag_macro_r_h2) ? na : diag_macro_r_h2 * diag_macro_r_h2
float diag_macro_r2_h3 = na(diag_macro_r_h3) ? na : diag_macro_r_h3 * diag_macro_r_h3
float diag_macro_r2_h4 = na(diag_macro_r_h4) ? na : diag_macro_r_h4 * diag_macro_r_h4
float diag_avg_r2_h1 = Log.f_diag_avg_r2(diag_r1_h1, diag_r2_h1, diag_r3_h1, diag_r3_h1)
float diag_avg_r2_h2 = Log.f_diag_avg_r2(diag_r1_h2, diag_r2_h2, diag_r3_h2, diag_r3_h2)
float diag_avg_r2_h3 = Log.f_diag_avg_r2(diag_r1_h3, diag_r2_h3, diag_r3_h3, diag_r3_h3)
float diag_avg_r2_h4 = Log.f_diag_avg_r2(diag_r1_h4, diag_r2_h4, diag_r3_h4, diag_r3_h4)
var float sil_bar = na  // per-bar silhouette EMA; training uses B2 batch silhouette after seed
float sil_ctr_euclid = na
float sil_ctr_maha = na
if sssm_seeded and array.size(sssm.regimes) >= K_REG
    float _g_sil_sum = 0.0
    float _g_sil_maha_sum = 0.0
    float _g_sil_n = 0.0
    for _g_avg_j = 0 to K_REG - 1
        RG.GaussianRegime _g_avg_rp = array.get(sssm.regimes, _g_avg_j)
        float _g_avg_dim = nw_use_f5 ? 4.0 : 3.0
        float _g_avg_spread = math.sqrt(math.max(0.0, matrix.get(_g_avg_rp.Sigma, 0, 0) + matrix.get(_g_avg_rp.Sigma, 1, 1) + matrix.get(_g_avg_rp.Sigma, 2, 2) + (nw_use_f5 ? matrix.get(_g_avg_rp.Sigma, 4, 4) : 0.0)))
        float _g_avg_spread_m = math.sqrt(_g_avg_dim)
        float _g_avg_near = na
        float _g_avg_near_m = na
        for _g_avg_k = 0 to K_REG - 1
            if _g_avg_k != _g_avg_j
                RG.GaussianRegime _g_avg_ok = array.get(sssm.regimes, _g_avg_k)
                float _g_cdx = array.get(_g_avg_rp.mu, 0) - array.get(_g_avg_ok.mu, 0)
                float _g_cdy = array.get(_g_avg_rp.mu, 1) - array.get(_g_avg_ok.mu, 1)
                float _g_cdz = array.get(_g_avg_rp.mu, 2) - array.get(_g_avg_ok.mu, 2)
                float _g_cdv = array.get(_g_avg_rp.mu, 4) - array.get(_g_avg_ok.mu, 4)
                float _g_cd = math.sqrt(_g_cdx * _g_cdx + _g_cdy * _g_cdy + _g_cdz * _g_cdz + (nw_use_f5 ? _g_cdv * _g_cdv : 0.0))
                float _g_m00 = matrix.get(_g_avg_rp.Sigma_inv, 0, 0)
                float _g_m01 = matrix.get(_g_avg_rp.Sigma_inv, 0, 1)
                float _g_m02 = matrix.get(_g_avg_rp.Sigma_inv, 0, 2)
                float _g_m11 = matrix.get(_g_avg_rp.Sigma_inv, 1, 1)
                float _g_m12 = matrix.get(_g_avg_rp.Sigma_inv, 1, 2)
                float _g_m22 = matrix.get(_g_avg_rp.Sigma_inv, 2, 2)
                float _g_m44 = matrix.get(_g_avg_rp.Sigma_inv, 4, 4)
                float _g_cd2m = _g_cdx * _g_cdx * _g_m00 + 2.0 * _g_cdx * _g_cdy * _g_m01 + 2.0 * _g_cdx * _g_cdz * _g_m02 + _g_cdy * _g_cdy * _g_m11 + 2.0 * _g_cdy * _g_cdz * _g_m12 + _g_cdz * _g_cdz * _g_m22 + (nw_use_f5 ? _g_cdv * _g_cdv * _g_m44 : 0.0)
                float _g_cdm = math.sqrt(math.max(_g_cd2m, 0.0))
                _g_avg_near := na(_g_avg_near) ? _g_cd : math.min(_g_avg_near, _g_cd)
                _g_avg_near_m := na(_g_avg_near_m) ? _g_cdm : math.min(_g_avg_near_m, _g_cdm)
        if not na(_g_avg_near) and math.max(_g_avg_spread, _g_avg_near) > 1e-10
            _g_sil_sum += (_g_avg_near - _g_avg_spread) / math.max(_g_avg_spread, _g_avg_near)
            _g_sil_n += 1.0
        if not na(_g_avg_near_m) and math.max(_g_avg_spread_m, _g_avg_near_m) > 1e-10
            _g_sil_maha_sum += (_g_avg_near_m - _g_avg_spread_m) / math.max(_g_avg_spread_m, _g_avg_near_m)
    sil_ctr_euclid := _g_sil_n > 0.0 ? _g_sil_sum / _g_sil_n : na
    sil_ctr_maha := _g_sil_n > 0.0 ? _g_sil_maha_sum / _g_sil_n : na
float health_total_neff = 0.0
float health_occ_entropy_raw = 0.0
float health_eff_k = na
float health_eff_ratio = na
float health_sep_min = na
int health_sep_bad = 0
if sssm_seeded and array.size(sssm.regimes) >= K_REG
    for j = 0 to K_REG - 1
        RG.GaussianRegime _h_rp = array.get(sssm.regimes, j)
        health_total_neff += _h_rp.n_eff
    if health_total_neff > 1e-10
        for j = 0 to K_REG - 1
            RG.GaussianRegime _h_pop_rp = array.get(sssm.regimes, j)
            float _h_pop = _h_pop_rp.n_eff / health_total_neff
            health_occ_entropy_raw += _h_pop > 1e-10 ? -_h_pop * math.log(_h_pop) : 0.0
        health_eff_k := math.exp(health_occ_entropy_raw)
        health_eff_ratio := health_eff_k / float(K_REG)
    [_h_sep_min, _h_sep_bad, _h_sep_i, _h_sep_j, _h_pairs] = f_regime_sep_diag(sssm.regimes, K_REG, false, nw_use_f5)
    health_sep_min := _h_sep_min
    health_sep_bad := _h_sep_bad
bool health_bad_gate = health_sep_bad == 0
bool health_diff_gate = health_bad_gate
bool health_eff_gate = not na(health_eff_ratio) and health_eff_ratio >= 0.84
float health_eff_norm = math.max(0.0, math.min(1.0, (nz(health_eff_ratio) - 0.84) / 0.16))
float health_s_ctr_norm = math.max(0.0, math.min(1.0, (nz(sil_ctr_euclid) + 1.0) * 0.5))
float health_s_maha_norm = math.max(0.0, math.min(1.0, (nz(sil_ctr_maha) + 1.0) * 0.5))
float health_s_bar_norm = math.max(0.0, math.min(1.0, (nz(sil_bar) + 1.0) * 0.5))
float health_delta_arg = math.max(-10.0, math.min(10.0, 5.0 * ((nz(sil_bar) - health_baseline_sil_bar) + (nz(sil_ctr_maha) - health_baseline_sil_maha))))
float health_delta_exp = math.exp(2.0 * health_delta_arg)
float health_delta = (health_delta_exp - 1.0) / (health_delta_exp + 1.0)
float health_soft = 0.20 * health_eff_norm + 0.25 * health_s_ctr_norm + 0.25 * health_s_maha_norm + 0.10 * health_s_bar_norm + 0.20 * health_delta
float health_h = health_bad_gate and health_diff_gate ? math.max(0.0, health_soft) : 0.0
var float health_i = na
health_i := na(health_i) ? health_h : health_i + 0.02 * (health_h - health_i)
var float health_committed_i = na
var array<RG.GaussianRegime> health_committed_regs = array.new<RG.GaussianRegime>()
var int health_last_checkpoint = na
if sssm_seeded and mode_in == "run" and use_frozen and adm_online_mode == "RefitKeepBest" and (na(health_last_checkpoint) or bar_index - health_last_checkpoint >= refit_update_frequency)
    [_hi_next, _hci_next, _hcr_next, _sil_next] = f_refit_keepbest_checkpoint(sssm, rb, K_REG, nw_use_f5, b8_udt_enabled, km_seed_eff + bar_index + 997, KM_ITERS, adm_min_samp, sil_ctr_euclid, health_sep_min, health_accept_epsilon, 0.60, health_bad_gate, health_diff_gate, health_eff_gate, health_delta, health_i, health_committed_i, health_committed_regs)
    int _refit_committed = na(health_committed_i) ? 1 : (_hci_next != health_committed_i ? 1 : 0)
    health_i := _hi_next
    health_committed_i := _hci_next
    health_committed_regs := _hcr_next
    if _refit_committed == 1 and not na(_hci_next)
        model_source := "REFIT"
    sil_ctr_euclid := _sil_next
    sil_bar := _sil_next
    health_last_checkpoint := bar_index
f_mobs_eval(float x, float y, float z, float v, SSSMState st, int kK, bool use_f5) =>
    float own = na
    float other = na
    int best = -1
    if array.size(st.regimes) >= kK
        for j = 0 to kK - 1
            RG.GaussianRegime rp = array.get(st.regimes, j)
            float dx = x - array.get(rp.mu, 0)
            float dy = y - array.get(rp.mu, 1)
            float dz = z - array.get(rp.mu, 2)
            float dv = v - array.get(rp.mu, 4)
            float d2 = dx * dx * matrix.get(rp.Sigma_inv, 0, 0) + dy * dy * matrix.get(rp.Sigma_inv, 1, 1) + dz * dz * matrix.get(rp.Sigma_inv, 2, 2) + (use_f5 ? dv * dv * matrix.get(rp.Sigma_inv, 4, 4) : 0.0)
            float d = math.sqrt(math.max(d2, 0.0))
            if na(own) or d < own
                other := own
                own := d
                best := j
            else if na(other) or d < other
                other := d
    [not na(own) and not na(other) ? (other - own) / math.max(own, other) : na, best]
var array<float> mobs_hist = array.new<float>()
var int mobs_last_bar = na
float mobs_eval_now = na
int mobs_eval_reg = -1
if barstate.isconfirmed and sssm_seeded
    [_mobs_v, _mobs_r] = f_mobs_eval(nz(F1r), nz(F2r), nz(F3r), nw_use_f5 ? nz(F5) : 0.0, sssm, K_REG, nw_use_f5)
    mobs_eval_now := _mobs_v
    mobs_eval_reg := _mobs_r
    if not na(_mobs_v) and mobs_last_bar != bar_index
        array.push(mobs_hist, _mobs_v)
        if array.size(mobs_hist) > diag_table_window
            array.shift(mobs_hist)
        mobs_last_bar := bar_index
float mobs_median = na
float mobs_p25 = na
float mobs_negative = na
if array.size(mobs_hist) > 0
    array<float> _mobs_sorted = array.copy(mobs_hist)
    array.sort(_mobs_sorted, order.ascending)
    int _mobs_n = array.size(_mobs_sorted)
    float _mobs_med = array.get(_mobs_sorted, math.floor((_mobs_n - 1) * 0.50))
    float _mobs_q25 = array.get(_mobs_sorted, math.floor((_mobs_n - 1) * 0.25))
    if not na(_mobs_med)
        mobs_median := _mobs_med
    if not na(_mobs_q25)
        mobs_p25 := _mobs_q25
    int _mobs_neg = 0
    for _mobs_i = 0 to _mobs_n - 1
        if array.get(_mobs_sorted, _mobs_i) < 0.0
            _mobs_neg += 1
    mobs_negative := float(_mobs_neg) / float(_mobs_n)
var table mobs_tbl = table.new(position.top_left, 4, 3, border_width=1)
f_render_mobs_table() =>
    if diag_table_on
        color _mh = color.new(color.gray, 20)
        color _mb = na(mobs_median) ? color.new(color.gray, 85) : mobs_median >= 0.35 ? color.new(color.lime, 65) : mobs_median >= 0.0 ? color.new(color.yellow, 65) : color.new(color.red, 70)
        table.cell(mobs_tbl, 0, 0, "M OBS QUALIFICATION", text_color=color.white, bgcolor=_mh)
        table.cell(mobs_tbl, 1, 0, "W " + str.tostring(diag_table_window), text_color=color.white, bgcolor=_mh)
        table.cell(mobs_tbl, 2, 0, not na(mobs_median) and mobs_median >= 0.35 ? "SILHOUETTE QUALIFIED" : "STRUCTURAL ONLY", text_color=color.white, bgcolor=_mb)
        table.cell(mobs_tbl, 0, 1, "median " + Log.f_diag_num(mobs_median), text_color=color.white, bgcolor=_mb)
        table.cell(mobs_tbl, 1, 1, "p25 " + Log.f_diag_num(mobs_p25), text_color=color.white, bgcolor=_mb)
        table.cell(mobs_tbl, 2, 1, "neg " + Log.f_diag_pct(mobs_negative), text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(mobs_tbl, 3, 1, "now " + Log.f_diag_num(mobs_eval_now), text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(mobs_tbl, 0, 2, "ctr E " + Log.f_diag_num(sil_ctr_euclid), text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(mobs_tbl, 1, 2, "ctr M " + Log.f_diag_num(sil_ctr_maha), text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(mobs_tbl, 2, 2, "B2 " + Log.f_diag_num(sil_bar), text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(mobs_tbl, 3, 2, "R" + str.tostring(mobs_eval_reg), text_color=color.white, bgcolor=color.new(color.black, 0))
    else
        table.clear(mobs_tbl, 0, 0, 3, 2)
var table diag_tbl = table.new(position.top_right, 5, K_REG * 2 + 20, border_width=1)
f_render_diag_table() =>
    if diag_table_on
        color hdr = color.new(color.gray, 20)
        color txt = color.white
        table.cell(diag_tbl, 0, 0, "Factor BTC variance", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 1, 0, "avg R2", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 2, 0, "best", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 3, 0, "|r|", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 4, 0, factor_smooth_mode, text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 0, 1, str.tostring(diag_h1) + " bars", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 1, Log.f_diag_pct(diag_avg_r2_h1), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_avg_r2_h1))
        table.cell(diag_tbl, 2, 1, Log.f_diag_best_name(diag_r1_h1, diag_r2_h1, diag_r3_h1, diag_r3_h1), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 3, 1, Log.f_diag_r_with_r2(Log.f_diag_best_abs(diag_r1_h1, diag_r2_h1, diag_r3_h1, diag_r3_h1)), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 1, "W" + str.tostring(diag_table_window), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 2, str.tostring(diag_h2) + " bars", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 2, Log.f_diag_pct(diag_avg_r2_h2), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_avg_r2_h2))
        table.cell(diag_tbl, 2, 2, Log.f_diag_best_name(diag_r1_h2, diag_r2_h2, diag_r3_h2, diag_r3_h2), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 3, 2, Log.f_diag_r_with_r2(Log.f_diag_best_abs(diag_r1_h2, diag_r2_h2, diag_r3_h2, diag_r3_h2)), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 2, "", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 3, str.tostring(diag_h3) + " bars", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 3, Log.f_diag_pct(diag_avg_r2_h3), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_avg_r2_h3))
        table.cell(diag_tbl, 2, 3, Log.f_diag_best_name(diag_r1_h3, diag_r2_h3, diag_r3_h3, diag_r3_h3), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 3, 3, Log.f_diag_r_with_r2(Log.f_diag_best_abs(diag_r1_h3, diag_r2_h3, diag_r3_h3, diag_r3_h3)), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 3, "", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 4, str.tostring(diag_h4) + " bars", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 4, Log.f_diag_pct(diag_avg_r2_h4), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_avg_r2_h4))
        table.cell(diag_tbl, 2, 4, Log.f_diag_best_name(diag_r1_h4, diag_r2_h4, diag_r3_h4, diag_r3_h4), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 3, 4, Log.f_diag_r_with_r2(Log.f_diag_best_abs(diag_r1_h4, diag_r2_h4, diag_r3_h4, diag_r3_h4)), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 4, "", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 5, "total", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 5, Log.f_diag_pct(diag_total_r2_h1), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_total_r2_h1))
        table.cell(diag_tbl, 2, 5, Log.f_diag_pct(diag_total_r2_h2), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_total_r2_h2))
        table.cell(diag_tbl, 3, 5, Log.f_diag_pct(diag_total_r2_h3), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_total_r2_h3))
        table.cell(diag_tbl, 4, 5, Log.f_diag_pct(diag_total_r2_h4), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_total_r2_h4))
        table.cell(diag_tbl, 0, 6, "macro3f fwd", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 6, Log.f_diag_pct(diag_macro_r2_h1), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_macro_r2_h1))
        table.cell(diag_tbl, 2, 6, Log.f_diag_pct(diag_macro_r2_h2), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_macro_r2_h2))
        table.cell(diag_tbl, 3, 6, Log.f_diag_pct(diag_macro_r2_h3), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_macro_r2_h3))
        table.cell(diag_tbl, 4, 6, Log.f_diag_pct(diag_macro_r2_h4), text_color=txt, bgcolor=Log.f_diag_r2_bg(diag_macro_r2_h4))
        table.cell(diag_tbl, 0, 7, "kalman fwd", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 7, "", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 2, 7, "", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 3, 7, "", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 7, "", text_color=txt, bgcolor=color.new(color.black, 0))
        float regime_sil_now = na
        float regime_sil_avg = na
        float regime_sil_maha = na
        if sssm_seeded and array.size(sssm.regimes) >= K_REG
            int _sil_j = math.max(0, math.min(sssm.active_regime, K_REG - 1))
            RG.GaussianRegime _sil_rp = array.get(sssm.regimes, _sil_j)
            float _sx = nz(F1r)
            float _sy = nz(F2r)
            float _sz = nz(F3r)
            float _sv = nw_use_f5 ? nz(F5) : 0.0
            float _adx = _sx - array.get(_sil_rp.mu, 0)
            float _ady = _sy - array.get(_sil_rp.mu, 1)
            float _adz = _sz - array.get(_sil_rp.mu, 2)
            float _adv = _sv - array.get(_sil_rp.mu, 4)
            float _a_dist = math.sqrt(_adx * _adx + _ady * _ady + _adz * _adz + (nw_use_f5 ? _adv * _adv : 0.0))
            float _b_dist = na
            for _sil_k = 0 to K_REG - 1
                if _sil_k != _sil_j
                    RG.GaussianRegime _sil_ok = array.get(sssm.regimes, _sil_k)
                    float _bdx = _sx - array.get(_sil_ok.mu, 0)
                    float _bdy = _sy - array.get(_sil_ok.mu, 1)
                    float _bdz = _sz - array.get(_sil_ok.mu, 2)
                    float _bdv = _sv - array.get(_sil_ok.mu, 4)
                    float _bd = math.sqrt(_bdx * _bdx + _bdy * _bdy + _bdz * _bdz + (nw_use_f5 ? _bdv * _bdv : 0.0))
                    _b_dist := na(_b_dist) ? _bd : math.min(_b_dist, _bd)
            regime_sil_now := not na(_b_dist) and math.max(_a_dist, _b_dist) > 1e-10 ? (_b_dist - _a_dist) / math.max(_a_dist, _b_dist) : na
            float _sil_sum = 0.0
            float _sil_maha_sum = 0.0
            float _sil_n = 0.0
            for _avg_j = 0 to K_REG - 1
                RG.GaussianRegime _avg_rp = array.get(sssm.regimes, _avg_j)
                float _avg_dim = nw_use_f5 ? 4.0 : 3.0
                float _avg_spread = math.sqrt(math.max(0.0, matrix.get(_avg_rp.Sigma, 0, 0) + matrix.get(_avg_rp.Sigma, 1, 1) + matrix.get(_avg_rp.Sigma, 2, 2) + (nw_use_f5 ? matrix.get(_avg_rp.Sigma, 4, 4) : 0.0)))
                float _avg_spread_m = math.sqrt(_avg_dim)
                float _avg_near = na
                float _avg_near_m = na
                for _avg_k = 0 to K_REG - 1
                    if _avg_k != _avg_j
                        RG.GaussianRegime _avg_ok = array.get(sssm.regimes, _avg_k)
                        float _cdx = array.get(_avg_rp.mu, 0) - array.get(_avg_ok.mu, 0)
                        float _cdy = array.get(_avg_rp.mu, 1) - array.get(_avg_ok.mu, 1)
                        float _cdz = array.get(_avg_rp.mu, 2) - array.get(_avg_ok.mu, 2)
                        float _cdv = array.get(_avg_rp.mu, 4) - array.get(_avg_ok.mu, 4)
                        float _cd = math.sqrt(_cdx * _cdx + _cdy * _cdy + _cdz * _cdz + (nw_use_f5 ? _cdv * _cdv : 0.0))
                        float _m00 = matrix.get(_avg_rp.Sigma_inv, 0, 0)
                        float _m01 = matrix.get(_avg_rp.Sigma_inv, 0, 1)
                        float _m02 = matrix.get(_avg_rp.Sigma_inv, 0, 2)
                        float _m11 = matrix.get(_avg_rp.Sigma_inv, 1, 1)
                        float _m12 = matrix.get(_avg_rp.Sigma_inv, 1, 2)
                        float _m22 = matrix.get(_avg_rp.Sigma_inv, 2, 2)
                        float _m44 = matrix.get(_avg_rp.Sigma_inv, 4, 4)
                        float _cd2m = _cdx * _cdx * _m00 + 2.0 * _cdx * _cdy * _m01 + 2.0 * _cdx * _cdz * _m02 + _cdy * _cdy * _m11 + 2.0 * _cdy * _cdz * _m12 + _cdz * _cdz * _m22 + (nw_use_f5 ? _cdv * _cdv * _m44 : 0.0)
                        float _cdm = math.sqrt(math.max(_cd2m, 0.0))
                        _avg_near := na(_avg_near) ? _cd : math.min(_avg_near, _cd)
                        _avg_near_m := na(_avg_near_m) ? _cdm : math.min(_avg_near_m, _cdm)
                if not na(_avg_near) and math.max(_avg_spread, _avg_near) > 1e-10
                    _sil_sum += (_avg_near - _avg_spread) / math.max(_avg_spread, _avg_near)
                    _sil_n += 1.0
                if not na(_avg_near_m) and math.max(_avg_spread_m, _avg_near_m) > 1e-10
                    _sil_maha_sum += (_avg_near_m - _avg_spread_m) / math.max(_avg_spread_m, _avg_near_m)
            regime_sil_avg := _sil_n > 0.0 ? _sil_sum / _sil_n : na
            regime_sil_maha := _sil_n > 0.0 ? _sil_maha_sum / _sil_n : na
        color sil_bg = na(regime_sil_now) ? color.new(color.gray, 85) : regime_sil_now >= 0.25 ? color.new(color.lime, 65) : regime_sil_now >= 0.0 ? color.new(color.yellow, 65) : color.new(color.red, 70)
        color sil_ctr_bg = na(regime_sil_avg) ? color.new(color.gray, 85) : regime_sil_avg >= 0.25 ? color.new(color.lime, 65) : regime_sil_avg >= 0.0 ? color.new(color.yellow, 65) : color.new(color.red, 70)
        color sil_maha_bg = na(regime_sil_maha) ? color.new(color.gray, 85) : regime_sil_maha >= 0.25 ? color.new(color.lime, 65) : regime_sil_maha >= 0.0 ? color.new(color.yellow, 65) : color.new(color.red, 70)
        color sil_bar_bg = na(sil_bar) ? color.new(color.gray, 85) : sil_bar >= 0.15 ? color.new(color.lime, 65) : sil_bar >= 0.0 ? color.new(color.yellow, 65) : color.new(color.red, 70)
        table.cell(diag_tbl, 0, 8, "E obs " + Log.f_diag_num(regime_sil_now), text_color=txt, bgcolor=sil_bg)
        table.cell(diag_tbl, 1, 8, "E ctr " + Log.f_diag_num(regime_sil_avg), text_color=txt, bgcolor=sil_ctr_bg)
        table.cell(diag_tbl, 2, 8, "M ctr " + Log.f_diag_num(regime_sil_maha), text_color=txt, bgcolor=sil_maha_bg)
        table.cell(diag_tbl, 3, 8, "M obs " + Log.f_diag_num(mobs_eval_now), text_color=txt, bgcolor=mobs_eval_now >= 0.25 ? color.new(color.lime, 65) : mobs_eval_now >= 0.0 ? color.new(color.yellow, 65) : color.new(color.red, 70))
        table.cell(diag_tbl, 4, 8, "B2 " + Log.f_diag_num(sil_bar), text_color=txt, bgcolor=sil_bar_bg)
        color lead_hit_bg = na(lead_hit) ? color.new(color.gray, 85) : lead_hit >= 0.55 ? color.new(color.lime, 65) : lead_hit >= 0.50 ? color.new(color.yellow, 65) : color.new(color.red, 70)
        color irf_err_bg = na(irf_realized_err_atr) ? color.new(color.gray, 85) : math.abs(irf_realized_err_atr) <= 1.0 ? color.new(color.lime, 75) : math.abs(irf_realized_err_atr) <= 2.0 ? color.new(color.yellow, 70) : color.new(color.red, 70)
        table.cell(diag_tbl, 0, 9, "lead hit", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 9, Log.f_diag_pct(lead_hit), text_color=txt, bgcolor=lead_hit_bg)
        table.cell(diag_tbl, 2, 9, "real err H" + str.tostring(_eff_fwdh), text_color=txt, bgcolor=irf_err_bg)
        table.cell(diag_tbl, 3, 9, "e " + Log.f_diag_num(irf_realized_err_atr) + " ATR", text_color=txt, bgcolor=irf_err_bg)
        table.cell(diag_tbl, 4, 9, "MAE " + Log.f_diag_num(irf_realized_mae_atr), text_color=txt, bgcolor=irf_err_bg)
        float total_neff = 0.0
        float diag_occ_entropy_raw = 0.0
        float diag_eff_k = na
        float diag_min_pop = na
        float diag_sep_min = na
        int diag_sep_bad = 0
        if sssm_seeded and array.size(sssm.regimes) >= K_REG
            for j = 0 to K_REG - 1
                RG.GaussianRegime rp_sum = array.get(sssm.regimes, j)
                total_neff += rp_sum.n_eff
            if total_neff > 1e-10
                for j = 0 to K_REG - 1
                    RG.GaussianRegime rp_pop = array.get(sssm.regimes, j)
                    float _pop_j = rp_pop.n_eff / total_neff
                    diag_min_pop := na(diag_min_pop) ? _pop_j : math.min(diag_min_pop, _pop_j)
                    diag_occ_entropy_raw += _pop_j > 1e-10 ? -_pop_j * math.log(_pop_j) : 0.0
                diag_eff_k := math.exp(diag_occ_entropy_raw)
            [_diag_sep_min, _diag_sep_bad, _diag_sep_i, _diag_sep_j, _diag_pairs] = f_regime_sep_diag(sssm.regimes, K_REG, false, nw_use_f5)
            diag_sep_min := _diag_sep_min
            diag_sep_bad := _diag_sep_bad
        if barstate.islast
            [_live_sep_min, _live_sep_bad, _live_sep_i, _live_sep_j, _live_pairs] = f_regime_sep_diag(sssm.regimes, K_REG, false, nw_use_f5)
            float _live_erosion_ratio = na
            if not na(_live_sep_min) and not na(b2_seed_sep_min_log) and b2_seed_sep_min_log > 1e-10
                _live_erosion_ratio := _live_sep_min / b2_seed_sep_min_log
            log.info("B5SEP,live_sep_min=" + str.tostring(_live_sep_min, "#.###") + ",bad=" + str.tostring(_live_sep_bad) + ",kappa=" + str.tostring(em_mu_anchor, "#.##") + ",pair=" + str.tostring(_live_sep_i) + "_" + str.tostring(_live_sep_j) + ",ratio=" + str.tostring(_live_erosion_ratio, "#.###") + ",floor=" + str.tostring(SEP_ABS_FLOOR, "#.###") + ",null=" + str.tostring(sep_null_test))
            log.info("B2PAIRS,seed," + b2_seed_pairs_log)
            log.info("B5PAIRS,live," + _live_pairs)
            log.info("SEPMIN,seed_pair=" + str.tostring(b2_seed_sep_i_log) + "_" + str.tostring(b2_seed_sep_j_log) + ",seed=" + str.tostring(b2_seed_sep_min_log, "#.###") + ",live_pair=" + str.tostring(_live_sep_i) + "_" + str.tostring(_live_sep_j) + ",live=" + str.tostring(_live_sep_min, "#.###"))
            log.info("B2MINMU,pair=" + str.tostring(b2_seed_sep_i_log) + "_" + str.tostring(b2_seed_sep_j_log) + ",mu_" + str.tostring(b2_seed_sep_i_log) + "=" + b2_seed_mu_i_log + ",mu_" + str.tostring(b2_seed_sep_j_log) + "=" + b2_seed_mu_j_log)
            log.info("B5MINMU,pair=" + str.tostring(_live_sep_i) + "_" + str.tostring(_live_sep_j) + ",mu_" + str.tostring(_live_sep_i) + "=" + f_regime_mu_vec(sssm.regimes, _live_sep_i) + ",mu_" + str.tostring(_live_sep_j) + "=" + f_regime_mu_vec(sssm.regimes, _live_sep_j))
            for j = 0 to K_REG - 1
                RG.GaussianRegime rp_log = array.get(sssm.regimes, j)
                float _pop_log = total_neff > 1e-10 ? rp_log.n_eff / total_neff : na
                log.info("B5SEPDETAIL,r=" + str.tostring(j) + ",n=" + str.tostring(rp_log.n_eff, "#.###") + ",pop=" + str.tostring(_pop_log, "#.###") + ",s0=" + str.tostring(matrix.get(rp_log.Sigma, 0, 0), "#.###") + ",s1=" + str.tostring(matrix.get(rp_log.Sigma, 1, 1), "#.###") + ",s2=" + str.tostring(matrix.get(rp_log.Sigma, 2, 2), "#.###") + ",s3=" + str.tostring(matrix.get(rp_log.Sigma, 3, 3), "#.###") + ",s4=" + str.tostring(matrix.get(rp_log.Sigma, 4, 4), "#.###"))
        float diag_erosion_ratio = na
        if not na(diag_sep_min) and not na(b2_seed_sep_min_log) and b2_seed_sep_min_log > 1e-10
            diag_erosion_ratio := diag_sep_min / b2_seed_sep_min_log
        bool diag_sep_floor_breach = not na(diag_sep_min) and diag_sep_min < SEP_ABS_FLOOR
        color eff_bg = na(diag_eff_k) ? color.new(color.gray, 85) : diag_eff_k / float(K_REG) >= 0.80 ? color.new(color.lime, 65) : diag_eff_k / float(K_REG) >= 0.65 ? color.new(color.yellow, 65) : color.new(color.red, 70)
        color sep_bg = color.new(color.gray, 85)
        if diag_sep_floor_breach or (not na(diag_erosion_ratio) and diag_erosion_ratio < 0.45)
            sep_bg := color.new(color.red, 70)
        else if not na(diag_erosion_ratio) and diag_erosion_ratio < 0.65
            sep_bg := color.new(color.yellow, 65)
        else if not na(diag_erosion_ratio)
            sep_bg := color.new(color.lime, 65)
        table.cell(diag_tbl, 0, 10, "model eff", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 10, "K " + Log.f_diag_num(diag_eff_k), text_color=txt, bgcolor=eff_bg)
        table.cell(diag_tbl, 2, 10, Log.f_diag_pct(na(diag_eff_k) ? na : diag_eff_k / float(K_REG)), text_color=txt, bgcolor=eff_bg)
        table.cell(diag_tbl, 3, 10, "sep " + Log.f_diag_num(diag_sep_min) + " r" + Log.f_diag_num(diag_erosion_ratio), text_color=txt, bgcolor=sep_bg)
        table.cell(diag_tbl, 4, 10, "bad " + str.tostring(diag_sep_bad), text_color=txt, bgcolor=sep_bg)
        color health_bg = health_bad_gate and health_diff_gate and health_eff_gate and health_delta >= 0.0 ? color.new(color.lime, 65) : color.new(color.red, 70)
        table.cell(diag_tbl, 0, 11, "health I/H", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 11, Log.f_diag_num(health_i), text_color=txt, bgcolor=health_bg)
        table.cell(diag_tbl, 2, 11, "H " + Log.f_diag_num(health_h), text_color=txt, bgcolor=health_bg)
        table.cell(diag_tbl, 3, 11, "d " + Log.f_diag_num(health_delta), text_color=txt, bgcolor=health_bg)
        table.cell(diag_tbl, 4, 11, adm_online_mode, text_color=txt, bgcolor=health_bg)
        float diag_shrinkage = 0.10
        table.cell(diag_tbl, 0, 12, "model source", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 1, 12, model_source, text_color=txt, bgcolor=model_source == "FROZEN" or model_source == "REFIT" ? color.new(color.lime, 65) : color.new(color.yellow, 65))
        table.cell(diag_tbl, 2, 12, "payload F5 " + str.tostring(parsed_payload_f5), text_color=txt, bgcolor=schema_ok ? color.new(color.black, 0) : color.new(color.red, 70))
        table.cell(diag_tbl, 3, 12, "runtime F5 " + str.tostring(nw_use_f5 ? 1 : 0), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 12, "active dim " + str.tostring(nw_use_f5 ? 4 : 3), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 13, "schema", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 13, "loaded " + str.tostring(frozen_loaded), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 2, 13, "parse " + str.tostring(frozen_parse_error), text_color=txt, bgcolor=frozen_parse_error ? color.new(color.red, 70) : color.new(color.black, 0))
        table.cell(diag_tbl, 3, 13, "K " + str.tostring(payload_k < 0 ? na : payload_k), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 13, "shrink " + Log.f_diag_num(diag_shrinkage), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 14, "admission", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 14, "hard " + str.tostring(adm_eligible_hard), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 2, 14, "dwell " + str.tostring(adm_dwell_gate), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 3, 14, "sign " + str.tostring(adm_sign_gate), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 14, "hold " + str.tostring(adm_nte_hold_gate), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 15, "admission state", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 15, "w " + Log.f_diag_num(adm_weight_now), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 2, 15, "sign% " + Log.f_diag_pct(adm_sign_rate_now), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 3, 15, "shock " + str.tostring(adm_shock_exempt), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 4, 15, "run " + str.tostring(adm_regime_run_len), text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 0, 16, "health", text_color=txt, bgcolor=color.new(color.black, 0))
        table.cell(diag_tbl, 1, 16, "I " + Log.f_diag_num(health_i), text_color=txt, bgcolor=health_bg)
        table.cell(diag_tbl, 2, 16, "H " + Log.f_diag_num(health_h), text_color=txt, bgcolor=health_bg)
        table.cell(diag_tbl, 3, 16, "Δ " + Log.f_diag_num(health_delta), text_color=txt, bgcolor=health_bg)
        table.cell(diag_tbl, 4, 16, "eff " + Log.f_diag_pct(health_eff_ratio), text_color=txt, bgcolor=health_bg)
        table.cell(diag_tbl, 0, 17, "Regime", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 1, 17, "pop", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 2, 17, "diff", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 3, 17, "pNow", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 4, 17, "state", text_color=txt, bgcolor=hdr)
        for j = 0 to K_REG - 1
            int row = 18 + j
            float pop = na
            float p_now = na
            float min_dist = na
            if sssm_seeded and array.size(sssm.regimes) >= K_REG
                RG.GaussianRegime rp_j = array.get(sssm.regimes, j)
                pop := total_neff > 1e-10 ? rp_j.n_eff / total_neff : na
                p_now := not na(alpha_filt) and array.size(alpha_filt) > j ? array.get(alpha_filt, j) : na
                float jx = array.get(rp_j.mu, 0)
                float jy = array.get(rp_j.mu, 1)
                float jz = array.get(rp_j.mu, 2)
                float jw = array.get(rp_j.mu, 3)
                float jv = array.get(rp_j.mu, 4)
                for k = 0 to K_REG - 1
                    if k != j
                        RG.GaussianRegime rp_k = array.get(sssm.regimes, k)
                        float dx = jx - array.get(rp_k.mu, 0)
                        float dy = jy - array.get(rp_k.mu, 1)
                        float dz = jz - array.get(rp_k.mu, 2)
                        float dw = jw - array.get(rp_k.mu, 3)
                        float dv = jv - array.get(rp_k.mu, 4)
                        float dist = math.sqrt(dx * dx + dy * dy + dz * dz + (nw_use_f5 ? dv * dv : 0.0))
                        min_dist := na(min_dist) ? dist : math.min(min_dist, dist)
            string state_txt = not sssm_seeded ? "wait" : na(pop) or na(min_dist) ? "na" : pop < 1.0 / float(K_REG) * 0.35 ? "thin" : min_dist < 0.75 ? "close" : "ok"
            table.cell(diag_tbl, 0, row, "R" + str.tostring(j), text_color=txt, bgcolor=color.new(color.black, 0))
            table.cell(diag_tbl, 1, row, Log.f_diag_pct(pop), text_color=txt, bgcolor=Log.f_diag_pop_bg(pop, 1.0 / float(K_REG)))
            table.cell(diag_tbl, 2, row, Log.f_diag_num(min_dist), text_color=txt, bgcolor=Log.f_diag_dist_bg(min_dist))
            table.cell(diag_tbl, 3, row, Log.f_diag_pct(p_now), text_color=txt, bgcolor=color.new(color.black, 0))
            table.cell(diag_tbl, 4, row, state_txt, text_color=txt, bgcolor=color.new(color.black, 0))
        int sigma_hdr_row = 18 + K_REG
        table.cell(diag_tbl, 0, sigma_hdr_row, "Regime", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 1, sigma_hdr_row, "n_eff", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 2, sigma_hdr_row, "Σ0/Σ1", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 3, sigma_hdr_row, "Σ2/Σ3", text_color=txt, bgcolor=hdr)
        table.cell(diag_tbl, 4, sigma_hdr_row, "Σ4", text_color=txt, bgcolor=hdr)
        for j = 0 to K_REG - 1
            int row = sigma_hdr_row + 1 + j
            if sssm_seeded and array.size(sssm.regimes) >= K_REG
                RG.GaussianRegime rp_sig = array.get(sssm.regimes, j)
                table.cell(diag_tbl, 0, row, "R" + str.tostring(j), text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 1, row, Log.f_diag_num(rp_sig.n_eff), text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 2, row, Log.f_diag_num(matrix.get(rp_sig.Sigma, 0, 0)) + "/" + Log.f_diag_num(matrix.get(rp_sig.Sigma, 1, 1)), text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 3, row, Log.f_diag_num(matrix.get(rp_sig.Sigma, 2, 2)) + "/" + Log.f_diag_num(matrix.get(rp_sig.Sigma, 3, 3)), text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 4, row, Log.f_diag_num(matrix.get(rp_sig.Sigma, 4, 4)), text_color=txt, bgcolor=color.new(color.black, 0))
            else
                table.cell(diag_tbl, 0, row, "R" + str.tostring(j), text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 1, row, "na", text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 2, row, "na", text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 3, row, "na", text_color=txt, bgcolor=color.new(color.black, 0))
                table.cell(diag_tbl, 4, row, "na", text_color=txt, bgcolor=color.new(color.black, 0))
    else
        table.clear(diag_tbl, 0, 0, 4, K_REG * 2 + 19)
if barstate.islast
    f_render_diag_table()
    f_render_mobs_table()
float nw_basis = na
float nw_upper = na
float nw_lower = na
float nw_anchor = ta.ema(close, nw_anchor_len)
float nw_atr = ta.atr(20)
bool nw_normal_mode = nw_mode == "Regime-normal reversal zones"
var array<float> X_nw_kpv = array.new<float>(3, 0.0)
var array<float> P_nw_kpv = KE.f_tri_new(3)
var array<float> H_nw_kpv_pos = array.from(1.0, 0.0, 1.0)
var array<float> H_nw_kpv_vel = array.from(0.0, 1.0, 0.0)
if barstate.isfirst
    KE.f_tri_set(P_nw_kpv, 0, 0, 3, 1.0)
    KE.f_tri_set(P_nw_kpv, 1, 1, 3, 1.0)
    KE.f_tri_set(P_nw_kpv, 2, 2, 3, 1.0)
float nw_kpv_factor_comp = (F1 + F2 - 0.5 * F3) / 2.5
float nw_kpv_factor_obs = N.f_zscore_mean_mad(nw_kpv_factor_comp, nw_kpv_zlen)
float nw_kpv_atr_log = close > 0.0 ? nw_atr / close : na
float nw_kpv_price_pos_obs = not na(nw_anchor) and not na(nw_atr) and nw_atr > 0.0 ? (close - nw_anchor) / nw_atr : na
float nw_kpv_band_half_prev = not na(nw_upper[1]) and not na(nw_lower[1]) ? math.abs(nw_upper[1] - nw_lower[1]) * 0.5 : na
float nw_kpv_band_sigma_prev = not na(nw_kpv_band_half_prev) ? nw_kpv_band_half_prev / math.max(nw_band_mult, 1e-6) : na
float nw_kpv_band_pos_obs = nw_kpv_use_band_pos and not na(nw_basis[1]) and not na(nw_kpv_band_sigma_prev) and nw_kpv_band_sigma_prev > 0.0 ? math.max(-5.0, math.min(5.0, (close - nw_basis[1]) / nw_kpv_band_sigma_prev)) : na
float nw_kpv_price_vel_obs = close > 0.0 and close[1] > 0.0 and not na(nw_kpv_atr_log) and nw_kpv_atr_log > 0.0 ? math.log(close / close[1]) / nw_kpv_atr_log : na
bool nw_kpv_ready = nw_kpv_enable and not na(nw_kpv_price_pos_obs) and not na(nw_kpv_price_vel_obs) and not na(nw_kpv_factor_obs)
if nw_kpv_ready
    bool nw_kpv_bad = na(array.get(X_nw_kpv, 0)) or na(array.get(X_nw_kpv, 1)) or na(array.get(X_nw_kpv, 2)) or na(KE.f_tri_get(P_nw_kpv, 0, 0, 3)) or na(KE.f_tri_get(P_nw_kpv, 1, 1, 3)) or na(KE.f_tri_get(P_nw_kpv, 2, 2, 3))
    if nw_kpv_bad
        array.set(X_nw_kpv, 0, 0.0)
        array.set(X_nw_kpv, 1, 0.0)
        array.set(X_nw_kpv, 2, 0.0)
        KE.f_tri_set(P_nw_kpv, 0, 0, 3, 1.0)
        KE.f_tri_set(P_nw_kpv, 0, 1, 3, 0.0)
        KE.f_tri_set(P_nw_kpv, 0, 2, 3, 0.0)
        KE.f_tri_set(P_nw_kpv, 1, 1, 3, 1.0)
        KE.f_tri_set(P_nw_kpv, 1, 2, 3, 0.0)
        KE.f_tri_set(P_nw_kpv, 2, 2, 3, 1.0)
    float nw_kpv_p00 = KE.f_tri_get(P_nw_kpv, 0, 0, 3)
    float nw_kpv_p01 = KE.f_tri_get(P_nw_kpv, 0, 1, 3)
    float nw_kpv_p02 = KE.f_tri_get(P_nw_kpv, 0, 2, 3)
    float nw_kpv_p11 = KE.f_tri_get(P_nw_kpv, 1, 1, 3)
    float nw_kpv_p12 = KE.f_tri_get(P_nw_kpv, 1, 2, 3)
    float nw_kpv_p22 = KE.f_tri_get(P_nw_kpv, 2, 2, 3)
    float nw_kpv_q_vel_eff = nw_kpv_q_vel * (1.0 + math.min(math.abs(nw_kpv_factor_obs), 3.0) * nw_kpv_factor_w)
    array.set(X_nw_kpv, 0, array.get(X_nw_kpv, 0) + array.get(X_nw_kpv, 1))
    KE.f_tri_set(P_nw_kpv, 0, 0, 3, nw_kpv_p00 + 2.0 * nw_kpv_p01 + nw_kpv_p11 + nw_kpv_q_pos)
    KE.f_tri_set(P_nw_kpv, 0, 1, 3, nw_kpv_p01 + nw_kpv_p11)
    KE.f_tri_set(P_nw_kpv, 0, 2, 3, nw_kpv_p02 + nw_kpv_p12)
    KE.f_tri_set(P_nw_kpv, 1, 1, 3, nw_kpv_p11 + nw_kpv_q_vel_eff)
    KE.f_tri_set(P_nw_kpv, 1, 2, 3, nw_kpv_p12)
    KE.f_tri_set(P_nw_kpv, 2, 2, 3, nw_kpv_p22 + nw_kpv_q_bias)
    [nw_kpv_innov_pos, nw_kpv_s_pos] = KE.f_sequential_update(X_nw_kpv, P_nw_kpv, nw_kpv_price_pos_obs, H_nw_kpv_pos, nw_kpv_r_price, 3)
    if nw_kpv_use_band_pos and not na(nw_kpv_band_pos_obs)
        [nw_kpv_innov_band, nw_kpv_s_band] = KE.f_sequential_update(X_nw_kpv, P_nw_kpv, nw_kpv_band_pos_obs, H_nw_kpv_pos, nw_kpv_r_price, 3)
    [nw_kpv_innov_vel, nw_kpv_s_vel] = KE.f_sequential_update(X_nw_kpv, P_nw_kpv, nw_kpv_price_vel_obs, H_nw_kpv_vel, nw_kpv_r_vel, 3)
    [nw_kpv_innov_fac, nw_kpv_s_fac] = KE.f_sequential_update(X_nw_kpv, P_nw_kpv, nw_kpv_factor_obs * nw_kpv_factor_w, H_nw_kpv_vel, nw_kpv_r_factor, 3)
float nw_kpv_pos = array.get(X_nw_kpv, 0)
float nw_kpv_vel = array.get(X_nw_kpv, 1)
float nw_kpv_bias = array.get(X_nw_kpv, 2)
float nw_kpv_vel_sigma = math.max(ta.stdev(nw_kpv_vel, nw_kpv_sigma_len), 1e-6)
float nw_kpv_score = nw_kpv_vel / nw_kpv_vel_sigma
max_bars_back(nw_kpv_score, 101)
float diag_kalman_r_h1 = ta.correlation(nw_kpv_score[diag_h1], diag_ret_h1, diag_table_window)
float diag_kalman_r_h2 = ta.correlation(nw_kpv_score[diag_h2], diag_ret_h2, diag_table_window)
float diag_kalman_r_h3 = ta.correlation(nw_kpv_score[diag_h3], diag_ret_h3, diag_table_window)
float diag_kalman_r_h4 = ta.correlation(nw_kpv_score[diag_h4], diag_ret_h4, diag_table_window)
float diag_kalman_r2_h1 = na(diag_kalman_r_h1) ? na : diag_kalman_r_h1 * diag_kalman_r_h1
float diag_kalman_r2_h2 = na(diag_kalman_r_h2) ? na : diag_kalman_r_h2 * diag_kalman_r_h2
float diag_kalman_r2_h3 = na(diag_kalman_r_h3) ? na : diag_kalman_r_h3 * diag_kalman_r_h3
float diag_kalman_r2_h4 = na(diag_kalman_r_h4) ? na : diag_kalman_r_h4 * diag_kalman_r_h4
if barstate.islast and diag_table_on
    color txt_kalman = color.white
    table.cell(diag_tbl, 1, 7, Log.f_diag_pct(diag_kalman_r2_h1), text_color=txt_kalman, bgcolor=Log.f_diag_r2_bg(diag_kalman_r2_h1))
    table.cell(diag_tbl, 2, 7, Log.f_diag_pct(diag_kalman_r2_h2), text_color=txt_kalman, bgcolor=Log.f_diag_r2_bg(diag_kalman_r2_h2))
    table.cell(diag_tbl, 3, 7, Log.f_diag_pct(diag_kalman_r2_h3), text_color=txt_kalman, bgcolor=Log.f_diag_r2_bg(diag_kalman_r2_h3))
    table.cell(diag_tbl, 4, 7, Log.f_diag_pct(diag_kalman_r2_h4), text_color=txt_kalman, bgcolor=Log.f_diag_r2_bg(diag_kalman_r2_h4))
color nw_basis_color = not nw_kpv_enable or not nw_kpv_ready ? color.new(color.aqua, 0) : nw_kpv_score > nw_kpv_thr ? color.new(color.lime, 0) : nw_kpv_score < -nw_kpv_thr ? color.new(color.red, 0) : color.new(color.yellow, 0)
if nw_kpv_logs and barstate.islast
    log.info("NWKPV,bar=" + str.tostring(bar_index) + ",enabled=" + str.tostring(nw_kpv_enable) + ",price_pos=" + str.tostring(nw_kpv_price_pos_obs, "#.####") + ",band_pos=" + str.tostring(nw_kpv_band_pos_obs, "#.####") + ",price_vel=" + str.tostring(nw_kpv_price_vel_obs, "#.####") + ",factor=" + str.tostring(nw_kpv_factor_obs, "#.####") + ",pos=" + str.tostring(nw_kpv_pos, "#.####") + ",vel=" + str.tostring(nw_kpv_vel, "#.####") + ",bias=" + str.tostring(nw_kpv_bias, "#.####") + ",score=" + str.tostring(nw_kpv_score, "#.####"))
f_nw_y(int i) =>
    int q = i + (nw_irf_lag ? _eff_fwdh : 0)
    float r = effectiveLead[q]
    nw_center_mode == "IRF line" and not na(r) ? (nw_normal_mode ? (close[i] - r) / math.max(nw_atr[i], 1e-10) : math.log(close[i] / math.max(r, 1e-10))) : (nw_normal_mode ? (close[i] - nw_anchor[i]) / math.max(nw_atr[i], 1e-10) : math.log(close[i]))
f_nw_valid(int i) =>
    not na(close[i]) and not na(F1[i]) and not na(F2[i]) and not na(F3[i]) and close[i] > 0.0 and (not nw_normal_mode or (not na(nw_anchor[i]) and not na(nw_atr[i]) and nw_atr[i] > 0.0)) and (nw_center_mode != "IRF line" or not na(effectiveLead[i + (nw_irf_lag ? _eff_fwdh : 0)]))
f_nw_weight(int i, float c1, float c2, float c3) =>
    N.f_nw_weight(F1[i] - c1, F2[i] - c2, F3[i] - c3, i, nw_factor_bw, nw_time_bw)
f_nw_accum(float y_mean) =>
    float w_sum = 0.0
    float y_sum = 0.0
    float var_sum = 0.0
    RG.GaussianRegime rp = array.get(sssm.regimes, sssm.active_regime)
    float c1 = array.get(rp.mu, 0)
    float c2 = array.get(rp.mu, 1)
    float c3 = array.get(rp.mu, 2)
    for i = 0 to nw_len - 1
        if f_nw_valid(i)
            float w = f_nw_weight(i, c1, c2, c3)
            float y = f_nw_y(i)
            w_sum += w
            y_sum += w * y
            if not na(y_mean)
                float resid = y - y_mean
                var_sum += w * resid * resid
    [w_sum, y_sum, var_sum]
if show_nw_bands and sssm_seeded and not b6_warmup
    [nw_w_sum, nw_y_sum, _nw_var_sum] = if true
        f_nw_accum(na)
    float nw_y_mean = nw_w_sum > 1e-10 ? nw_y_sum / nw_w_sum : na
    if not na(nw_y_mean)
        [nw_w_sum_2, nw_y_sum_2, nw_var_sum] = if true
            f_nw_accum(nw_y_mean)
        float nw_sigma = math.sqrt(math.max(nw_var_sum / math.max(nw_w_sum, 1e-10), 0.0))
        bool nw_irf_mode = nw_center_mode == "IRF line"
        float nw_irf_ref = effectiveLead[nw_irf_lag ? _eff_fwdh : 0]
        if nw_normal_mode
            float nw_band = math.max(nw_sigma, nw_atr_floor) * nw_band_mult
            float nw_mid = nw_irf_mode and not na(nw_irf_ref) ? nw_irf_ref : nw_anchor
            nw_basis := nw_mid + nw_y_mean * nw_atr
            nw_upper := nw_mid + (nw_y_mean + nw_band) * nw_atr
            nw_lower := nw_mid + (nw_y_mean - nw_band) * nw_atr
        else
            float nw_atr_log = close > 0.0 ? nw_atr / close : 0.0
            float nw_band = math.max(nw_sigma, nw_atr_log * nw_atr_floor) * nw_band_mult
            float nw_log_mid = nw_irf_mode and not na(nw_irf_ref) ? math.log(nw_irf_ref) : 0.0
            nw_basis := math.exp(nw_log_mid + nw_y_mean)
            nw_upper := math.exp(nw_log_mid + nw_y_mean + nw_band)
            nw_lower := math.exp(nw_log_mid + nw_y_mean - nw_band)
        if nw_center_mode == "IRF median" and not na(anchorLead) and not na(effectiveLead) and not na(nw_basis)
            nw_shift = (anchorLead + effectiveLead) * 0.5 - nw_basis
            nw_basis += nw_shift
            nw_upper += nw_shift
            nw_lower += nw_shift
plot(sssm_seeded ? macro3f                    : na, "macro3f (B7)",         color=color.new(color.aqua, 0), linewidth=2, force_overlay=false)
p_nw_basis = plot(show_nw_bands ? nw_basis : na, "NW regime mean", color=nw_basis_color, linewidth=2, force_overlay=true)
p_nw_upper = plot(show_nw_bands ? nw_upper : na, "NW regime upper reversal", color=color.new(color.red, 0), linewidth=1, force_overlay=true)
p_nw_lower = plot(show_nw_bands ? nw_lower : na, "NW regime lower reversal", color=color.new(color.lime, 0), linewidth=1, force_overlay=true)
fill(p_nw_upper, p_nw_lower, color=show_nw_bands ? color.new(color.aqua, 92) : na, title="NW regime reversal zone")
// B8 IRF price-pane overlay —  per-plot, indicator stays overlay=false.
// NOTE: fill() cannot take force_overlay; both anchor plots carry it so fill follows to price pane.
// If fill distorts price axis, remove the fill() line and rely on line color only.
plotchar(regime_exit_pending and nz(macro3f[1]) >= 50.0, "Macro regime ended up", "•", location=location.abovebar, color=color.orange, size=size.tiny, force_overlay=true)
plotchar(regime_exit_pending and nz(macro3f[1]) < 50.0, "Macro regime ended down", "•", location=location.belowbar, color=color.aqua, size=size.tiny, force_overlay=true)
bool irf_magnet_on = b8_enabled and sssm_seeded and (irf_price_display == "Magnet" or irf_price_display == "Magnet + Projection")
bool irf_projection_on = b8_enabled and sssm_seeded and (irf_price_display == "Projection" or irf_price_display == "Magnet + Projection")
color irf_magnet_color = na(effectiveLead) ? color.gray : effectiveLead >= close ? color.teal : color.orange
int irf_magnet_transp = na(lead_hit) or lead_hit < 0.50 ? 82 : 22
plot(irf_magnet_on ? effectiveLead : na, "IRF fair-value magnet", color=color.new(irf_magnet_color, irf_magnet_transp), linewidth=2, force_overlay=true)
var line irf_projection_line = na
var line irf_projection_upper = na
var line irf_projection_lower = na
float irf_conf = na(lead_hit) ? 0.0 : math.max(0.0, math.min(1.0, lead_hit))
float irf_cone_half = nz(_atr14) * (0.50 + 0.50 * (1.0 - irf_conf))
if barstate.islast
    if not na(irf_projection_line)
        line.delete(irf_projection_line)
    if not na(irf_projection_upper)
        line.delete(irf_projection_upper)
    if not na(irf_projection_lower)
        line.delete(irf_projection_lower)
    if irf_projection_on and not na(effectiveLead)
        irf_projection_line := line.new(bar_index, close, bar_index + _eff_fwdh, effectiveLead, xloc=xloc.bar_index, color=color.new(irf_magnet_color, irf_magnet_transp), style=line.style_dashed, width=2, force_overlay=true)
        irf_projection_upper := line.new(bar_index, close, bar_index + _eff_fwdh, effectiveLead + irf_cone_half, xloc=xloc.bar_index, color=color.new(irf_magnet_color, 65), style=line.style_dotted, width=1, force_overlay=true)
        irf_projection_lower := line.new(bar_index, close, bar_index + _eff_fwdh, effectiveLead - irf_cone_half, xloc=xloc.bar_index, color=color.new(irf_magnet_color, 65), style=line.style_dotted, width=1, force_overlay=true)
//plot(b8_enabled and sssm_seeded ? irf_vix_blend  : na, "dbg.irf_vix_blend",  display=display.data_window, force_overlay=false)
//plot(b8_enabled and sssm_seeded ? irf_horc_blend : na, "dbg.irf_horc_blend", display=display.data_window, force_overlay=false)
//plot(b8_enabled and sssm_seeded ? irf_bei_blend  : na, "dbg.irf_bei_blend",  display=display.data_window, force_overlay=false)
//plot(b8_enabled and sssm_seeded ? irf_vix_out  : na, "dbg.irf_vix_h0",  display=display.data_window, force_overlay=false)
//plot(b8_enabled and sssm_seeded ? irf_horc_out : na, "dbg.irf_horc_h0", display=display.data_window, force_overlay=false)
//plot(b8_enabled and sssm_seeded ? irf_bei_out  : na, "dbg.irf_bei_h0",  display=display.data_window, force_overlay=false)
// B5 n_eff vector plots (urgent: ghost regime vs collapse diagnostic)
///plot(sssm_seeded ? array.get(sssm.regimes, 0).n_eff : na, "b5.n_eff_0", display=display.data_window, force_overlay=false)
//plot(sssm_seeded ? array.get(sssm.regimes, 1).n_eff : na, "b5.n_eff_1", display=display.data_window, force_overlay=false)
//plot(sssm_seeded ? array.get(sssm.regimes, 2).n_eff : na, "b5.n_eff_2", display=display.data_window, force_overlay=false)
//plot(sssm_seeded ? array.get(sssm.regimes, 3).n_eff : na, "b5.n_eff_3", display=display.data_window, force_overlay=false)
//plot(sssm_seeded ? array.get(sssm.regimes, 4).n_eff : na, "b5.n_eff_4", display=display.data_window, force_overlay=false)
//plot(sssm_seeded ? array.get(sssm.regimes, 5).n_eff : na, "b5.n_eff_5", display=display.data_window, force_overlay=false)
// B9 IRF-weighted composite diagnostic plots (disabled until toggle invariance passes)
// plot(b9_enable and sssm_seeded ? 0.0 : na, "dbg.b9_w_vix",  display=display.data_window, force_overlay=false)
// plot(b9_enable and sssm_seeded ? 0.0 : na, "dbg.b9_w_horc", display=display.data_window, force_overlay=false)
// plot(b9_enable and sssm_seeded ? 0.0 : na, "dbg.b9_w_bei",  display=display.data_window, force_overlay=false)
// plot(b9_enable and sssm_seeded ? 0.0 : na, "dbg.b9_irf_blend", display=display.data_window, force_overlay=false)
// ============================================================================
//  ALPHA-ENGINE EXPORT BLOCK  —  Macro 3F (m3f)
//  Appended to m3f_sssm_v06_alphaex.pine
//  Adds 2 plots. No new request.security calls.
//  NOTE: macro3f is scaled [0,100] centered at 50 (bull=50+, bear=50−).
//  Codebook: 0=neutral 1=long 2=short 3=invalid
// ============================================================================
// --- canonical confidence-gated state ---
float m3f_conf_min = input.float(0.55, "Export: m3f Confidence Gate", minval=0.0, maxval=1.0, group="Alpha Export")
bool  m3f_valid    = not na(macro3f) and not na(signal_confidence) and barstate.isconfirmed and inAeSpan
// macro3f: 50 = neutral, >50 = bullish, <50 = bearish
int   m3f_code = switch
    not m3f_valid                          => 3
    signal_confidence < m3f_conf_min       => 0
    macro3f >  50.0                        => 1
    macro3f <  50.0                        => 2
    =>                                        0

// --- tanh-compressed signed strength in [-1,1] ---
// normalize macro3f from [0,100] → [-1,1] before tanh
float m3f_norm     = (nz(macro3f) - 50.0) / 50.0
float m3f_strength = m3f_valid ? (2.0 / (1.0 + math.exp(-2.0 * m3f_norm)) - 1.0) : 0.0

// --- bit-packed export: this indicator occupies bits 0-1 ---

// plot(M3F_PACKED,   "AE_STATE_m3f",    color=color.new(color.aqua, 100), display=display.data_window, force_overlay=false)
// plot(m3f_strength, "AE_STRENGTH_m3f", color=color.new(color.aqua, 100), display=display.data_window, force_overlay=false)
// plot(M3F_PACKED,   "AE_STATE_m3f_v2",    color=color.new(color.blue, 100), display=display.data_window, force_overlay=false)
// plot(m3f_strength, "AE_STRENGTH_m3f_v2", color=color.new(color.blue, 100), display=display.data_window, force_overlay=false)
//plot(sssm_seeded and not b6_warmup ? 1.0 : 0.0, "AE_m3f_ready",      color=color.new(color.aqua, 100), display=display.data_window, force_overlay=false)
//plot(float(bar_index - (last_bar_index - aeSpanBack)), "AE_m3f_spanFilled", color=color.new(color.aqua, 100), display=display.data_window, force_overlay=false)

var Log.Logger aeLog = Log.f_logger_new(Log.f_logger_mode_buffered(), "AE_m3f", "bar,code,str", 25)
var Log.Logger modelDiagLog = Log.f_logger_new(Log.f_logger_mode_buffered(), "M3F_MODEL", "bar,regime,mu0,mu1,mu2,mu3,mu4,n_eff,s00,s01,s02,s03,s04,s11,s12,s13,s14,s22,s23,s24,s33,s34,s44", 40)
f_emit_ae_log() =>
    if barstate.isconfirmed and m3f_valid
        aeLog.append("AE," + str.tostring(bar_index) + "," + str.tostring(m3f_code) + "," + str.tostring(m3f_strength, "#.###"))
f_emit_model_diag_log() =>
    if mode_in == "diagnostic" and barstate.islast and sssm_seeded and array.size(sssm.regimes) >= K_REG
        for _md_j = 0 to K_REG - 1
            RG.GaussianRegime _md_rp = array.get(sssm.regimes, _md_j)
            string _md_row = str.tostring(bar_index) + "," + str.tostring(_md_j)
            for _md_d = 0 to 4
                _md_row += "," + str.tostring(array.get(_md_rp.mu, _md_d), "#.#####")
            _md_row += "," + str.tostring(_md_rp.n_eff, "#.#####")
            for _md_r = 0 to 4
                for _md_c = _md_r to 4
                    _md_row += "," + str.tostring(matrix.get(_md_rp.Sigma, _md_r, _md_c), "#.#####")
            modelDiagLog.append(_md_row)
        modelDiagLog.flush()
f_emit_ae_log()
f_emit_model_diag_log()



// ─── Phase B ground-truth export: full smoothed posterior vector γ_smooth ──
// B6 already computes gamma_smooth (size K_REG) + k_smooth + gamma_smooth_max.
// Scalar summaries alone lose the per-regime distribution needed for
// entropy / second-mass / calibration checks. Export all K components.
// Dead-row guard: emit na (never 0) on pre-seed / non-computed bars.
bool gs_valid = sssm_seeded and sssm.posterior_history.count >= 2 and compute_active
float gs0 = gs_valid ? N.f_safe_get_f(gamma_smooth, 0) : na
float gs1 = gs_valid ? N.f_safe_get_f(gamma_smooth, 1) : na
float gs2 = gs_valid ? N.f_safe_get_f(gamma_smooth, 2) : na
float gs3 = gs_valid ? N.f_safe_get_f(gamma_smooth, 3) : na
float gs4 = gs_valid ? N.f_safe_get_f(gamma_smooth, 4) : na
float gs5 = gs_valid ? N.f_safe_get_f(gamma_smooth, 5) : na

// Filtered (forward-only) posterior vector α_filt — needed to measure the
// smoother's forward→smoothed correction (the value B6 actually adds).

// Smoothed posterior entropy (nats) — regime uncertainty ground-truth metric.
float _gs_ent = 0.0
if gs_valid
    for _j = 0 to K_REG - 1
        float _p = array.get(gamma_smooth, _j)
        if not na(_p) and _p > 1e-12
            _gs_ent := _gs_ent - _p * math.log(_p)
float gamma_smooth_entropy = _gs_ent

// ─── Parallel full-Kim ground-truth export (KIM_GT_H = 6 look-ahead) ─────
// Output at bar t is the smoothed posterior for bar t-KIM_GT_H. Python builder
// shifts these six columns forward by KIM_GT_H so corpus row i describes bar i.
// Leading / trailing / post-session-transition bars are masked na.
bool gkg_valid = _kim_gt_inv_ok and sssm_seeded and sssm.posterior_history.count >= KIM_GT_H and kim_gt_truncate_bars == 0 and not (bar_index > last_bar_index - KIM_GT_H) and barstate.isconfirmed and compute_active

float _gkg_ent = 0.0
if gkg_valid
    for _j = 0 to K_REG - 1
        float _p = array.get(gamma_kim_gt, _j)
        if not na(_p) and _p > 1e-12
            _gkg_ent := _gkg_ent - _p * math.log(_p)
float gamma_kim_gt_entropy = _gkg_ent
float kim_gt_entropy_median = ta.median(gamma_kim_gt_entropy, 300)
float kim_gt_max = na
int kim_gt_label_int = -1
if gkg_valid
    for _j = 0 to K_REG - 1
        float _p = array.get(gamma_kim_gt, _j)
        if na(kim_gt_max) or _p > kim_gt_max
            kim_gt_max := _p
            kim_gt_label_int := _j
float kim_gt_label = gkg_valid ? float(kim_gt_label_int) : na
float kim_gt_label_conf = gkg_valid and not na(kim_gt_entropy_median) and gamma_kim_gt_entropy <= kim_gt_entropy_median ? kim_gt_label : na
hold_zlen = input.int(300, "Regime-hold Z window", minval=50, maxval=1000, group="Regime Hold Monitor")
hold_slope_len = input.int(6, "Regime-hold slope length", minval=2, maxval=50, group="Regime Hold Monitor")
hold_slope_pct_win = input.int(300, "Regime-hold slope percentile window", minval=50, maxval=1000, group="Regime Hold Monitor")
hold_slope_pct = input.float(10.0, "Regime-hold slope warning percentile", minval=1.0, maxval=50.0, step=1.0, group="Regime Hold Monitor")
float hold_conf_z = N.f_zscore_mean_mad(kim_gt_max, hold_zlen)
float hold_entropy_z = N.f_zscore_mean_mad(gamma_kim_gt_entropy, hold_zlen)
float hold_lead_z = N.f_zscore_mean_mad(math.abs(nz(lead_corr)), hold_zlen)
float hold_nte_sum = math.abs(nz(nte_vix_slow)) + math.abs(nz(nte_horc_slow)) + math.abs(nz(nte_bei_slow))
float hold_nte_z = N.f_zscore_mean_mad(hold_nte_sum, hold_zlen)
float regime_hold_raw = 0.40 * nz(hold_conf_z) - 0.30 * nz(hold_entropy_z) + 0.20 * nz(hold_lead_z) + 0.10 * nz(hold_nte_z)
float regime_hold_score = 1.0 / (1.0 + math.exp(-regime_hold_raw))
float regime_hold_slope = ta.linreg(regime_hold_score, hold_slope_len, 0) - ta.linreg(regime_hold_score, hold_slope_len, 1)
float regime_hold_slope_p10 = ta.percentile_nearest_rank(regime_hold_slope, hold_slope_pct_win, hold_slope_pct)
bool regime_hold_slope_warn = not na(regime_hold_slope_p10) and regime_hold_slope <= regime_hold_slope_p10
float regime_hold_atr = ta.atr(14)
// Feed hold score into next bar's admission gate carry (1-bar lag is correct).
_adm_hold_carry := regime_hold_score
// ─── Global silhouette (hoisted from diag block for hold-dot color gate) ─────
float g_sil_now = na
if sssm_seeded and array.size(sssm.regimes) >= K_REG
    int _gs_j = math.max(0, math.min(sssm.active_regime, K_REG - 1))
    RG.GaussianRegime _gs_rp = array.get(sssm.regimes, _gs_j)
    float _gx = nz(F1r)
    float _gy = nz(F2r)
    float _gz = nz(F3r)
    float _gv = nw_use_f5 ? nz(F5) : 0.0
    float _ga = math.sqrt(math.pow(_gx - array.get(_gs_rp.mu, 0), 2) + math.pow(_gy - array.get(_gs_rp.mu, 1), 2) + math.pow(_gz - array.get(_gs_rp.mu, 2), 2) + (nw_use_f5 ? math.pow(_gv - array.get(_gs_rp.mu, 4), 2) : 0.0))
    float _gb = na
    for _gs_k = 0 to K_REG - 1
        if _gs_k != _gs_j
            RG.GaussianRegime _gs_ok = array.get(sssm.regimes, _gs_k)
            float _gd = math.sqrt(math.pow(_gx - array.get(_gs_ok.mu, 0), 2) + math.pow(_gy - array.get(_gs_ok.mu, 1), 2) + math.pow(_gz - array.get(_gs_ok.mu, 2), 2) + (nw_use_f5 ? math.pow(_gv - array.get(_gs_ok.mu, 4), 2) : 0.0))
            _gb := na(_gb) ? _gd : math.min(_gb, _gd)
    g_sil_now := not na(_gb) and math.max(_ga, _gb) > 1e-10 ? (_gb - _ga) / math.max(_ga, _gb) : na
// Per-bar silhouette EMA (W=240): rolling mean of g_sil_now for data-window export and table
var float _sil_bar_ema = na
if mode_in == "training" and not na(b2_train_sil_bar_log)
    sil_bar := b2_train_sil_bar_log
else
    if not na(g_sil_now)
        _sil_bar_ema := na(_sil_bar_ema) ? g_sil_now : _sil_bar_ema + (2.0 / 241.0) * (g_sil_now - _sil_bar_ema)
    sil_bar := nz(_sil_bar_ema, sil_bar)
// ─── Regime-hold monitor dot (plotshape, price pane) ─────────────────────────
// Color logic:
//   gray   → sil < 0.05 or na: current obs indistinguishable between regimes
//   yellow → slope warn (hold score trending down)
//   green  → bull-scored (mu_out active > 0) + strong hold + no warn
//   red    → bear-scored (mu_out active <= 0) + strong hold + no warn
float _hd_mu_scored = sssm_seeded ? N.f_safe_get_f(sssm.mu_out_scored, sssm.active_regime) : na
float _hd_mu_raw = sssm_seeded ? N.f_safe_get_f(sssm.mu_out, sssm.active_regime) : na
float _hd_mu = not na(_hd_mu_scored) and math.abs(_hd_mu_scored) > 1e-6 ? _hd_mu_scored : _hd_mu_raw
bool _hd_bull = not na(_hd_mu) and _hd_mu > 0.0
bool _hd_undiff = na(g_sil_now) or g_sil_now < 0.05
color _hd_col = _hd_undiff ? color.new(color.gray, 40) : regime_hold_slope_warn ? color.new(color.yellow, 20) : _hd_bull ? color.new(color.lime, 20) : color.new(color.red, 20)
plotshape(hold_line_on and sssm_seeded ? low : na, title="Regime hold dot", style=shape.square, location=location.bottom, color=_hd_col, size=size.tiny, force_overlay=true)
float lev_regime_pack = sssm_seeded and lvg_phase >= -1 ? float(sssm.active_regime + (lvg_phase + 1) * 16) : na

// Causal downstream conditioner; never written to rb.f1/f2/f3 or rb.adm_weight.
float btc_condition = math.max(0.0, math.min(1.0, adm_weight_pre))
float btccond_macro = 50.0 + (macro3f - 50.0) * btc_condition

// ─── Export ──────────────────────────────────────────────────────────────
float gamma_smooth_pack_012 = Log.f_pack3x10(Log.f_q_unsigned(gs0, 1023.0, 1023), Log.f_q_unsigned(gs1, 1023.0, 1023), Log.f_q_unsigned(gs2, 1023.0, 1023))
float gamma_smooth_pack_345 = Log.f_pack3x10(Log.f_q_unsigned(gs3, 1023.0, 1023), Log.f_q_unsigned(gs4, 1023.0, 1023), Log.f_q_unsigned(gs5, 1023.0, 1023))
plot(gamma_smooth_pack_012, "gamma_smooth_0_2_q10", display=display.data_window, force_overlay=false)
plot(gamma_smooth_pack_345, "gamma_smooth_3_5_q10", display=display.data_window, force_overlay=false)
//plot(af0, "alpha_filt_0", display=display.data_window, force_overlay=false)
//plot(af1, "alpha_filt_1", display=display.data_window, force_overlay=false)
//plot(af2, "alpha_filt_2", display=display.data_window, force_overlay=false)
//plot(af3, "alpha_filt_3", display=display.data_window, force_overlay=false)
//plot(af4, "alpha_filt_4", display=display.data_window, force_overlay=false)
//plot(af5, "alpha_filt_5", display=display.data_window, force_overlay=false)
plot(gamma_smooth_entropy, "gamma_smooth_entropy", display=display.data_window, force_overlay=false)
// ─── Regime label overlay ─────────────────────────────────────────────────
var int   _rl_prev_k  = -1
var label _rl_now_lbl = na
var int _rl_last_logged_bar = na
var float _rl_start_price = na
var int _rl_start_bar = na

if show_regime and sssm_seeded and barstate.isconfirmed
    int    _rl_k    = sssm.active_regime
    float  _rl_conf = signal_confidence
    bool _rl_new_segment = _rl_k != _rl_prev_k or na(_rl_start_price)
    if _rl_new_segment
        _rl_start_price := open
        _rl_start_bar := bar_index
    float _rl_end_price = close
    float _rl_chg_pct = not na(_rl_start_price) and _rl_start_price != 0.0 ? (_rl_end_price / _rl_start_price - 1.0) * 100.0 : na
    int _rl_age = not na(_rl_start_bar) ? bar_index - _rl_start_bar + 1 : 0
    string _rl_bias = not na(_rl_chg_pct) and _rl_chg_pct > 0.0 ? "BULL" : not na(_rl_chg_pct) and _rl_chg_pct < 0.0 ? "BEAR" : "NEUT"
    float _rl_conf_safe = math.max(0.0, math.min(nz(_rl_conf, 0.0), 1.0))
    int _rl_bg_transp = int(math.round(60.0 - _rl_conf_safe * 50.0))
    color  _rl_col  = _rl_bias == "BULL" ? color.new(color.green, _rl_bg_transp) : _rl_bias == "BEAR" ? color.new(color.red, _rl_bg_transp) : color.new(color.gray, _rl_bg_transp)
    color _rl_txt_col = color.white
    // Inline tooltip
    RG.GaussianRegime _rl_rp = array.get(sssm.regimes, _rl_k)
    float _rl_f1 = array.get(_rl_rp.mu, 0)
    float _rl_f2 = array.get(_rl_rp.mu, 1)
    float _rl_f3 = array.get(_rl_rp.mu, 2)
    float _rl_mu = array.get(sssm.mu_out, _rl_k)
    string _rl_chg_txt = (not na(_rl_chg_pct) and _rl_chg_pct > 0.0 ? "+" : "") + str.tostring(_rl_chg_pct, "#.##")
    string _rl_mood  = _rl_bias == "BULL" ? "Positive regime price change" : _rl_bias == "BEAR" ? "Negative regime price change" : "Flat regime price change"
    string _rl_ckind = _rl_f1 < -0.5 ? "low fear"        : _rl_f1 > 0.5 ? "elevated fear"    : "neutral fear"
    string _rl_hkind = _rl_f2 > 0.5  ? "tight credit"    : _rl_f2 < -0.5 ? "easy credit"     : "neutral credit"
    string _rl_bkind = _rl_f3 > 0.5  ? "rising inflation" : _rl_f3 < -0.5 ? "falling inflation" : "stable inflation"
    string _rl_top   = w_vix >= w_horc and w_vix >= w_bei ? "VIX (fear)" : w_horc >= w_bei ? "HORC (credit)" : "BEI (inflation)"
    string _rl_tip_str = "▸ Macro regime " + str.tostring(_rl_k) + " of " + str.tostring(K_REG - 1) + "  (" + _rl_mood + ")" +
         "\n" +
         "\nMacro score:       " + str.tostring(macro3f, "#.#") + " / 100  (50 = neutral)" +
         "\nSignal confidence: " + str.tostring(math.round(_rl_conf * 100)) + "%" +
         "\nRegime change:     " + _rl_chg_txt + "%" +
         "\nStart / end:       " + str.tostring(_rl_start_price, format.mintick) + " → " + str.tostring(_rl_end_price, format.mintick) +
         "\nRegime age:        " + str.tostring(_rl_age) + " bars" +
         "\nSmoothed regime:   R" + str.tostring(k_smooth) + "  (Kim backward smoother)" +
         "\n" +
         "\n— What's driving the signal —" +
         "\nTop driver:  " + _rl_top +
         "\nVIX weight:  " + str.tostring(math.round(w_vix  * 100)) + "%  (volatility / fear)" +
         "\nHORC weight: " + str.tostring(math.round(w_horc * 100)) + "%  (credit stress)" +
         "\nBEI weight:  " + str.tostring(math.round(w_bei  * 100)) + "%  (inflation expectations)" +
         "\n" +
         "\n— Regime character —" +
         "\nVIX fear factor:  " + str.tostring(_rl_f1, "#.##") + "  (" + _rl_ckind + ")" +
         "\nCredit stress:    " + str.tostring(_rl_f2, "#.##") + "  (" + _rl_hkind + ")" +
         "\nInflation signal: " + str.tostring(_rl_f3, "#.##") + "  (" + _rl_bkind + ")" +
         "\n" +
         "\n— Regime health —" +
         "\nComposite output: " + str.tostring(_rl_mu, "#.###") + "  (regime return forecast)" +
         "\nEffective weight: " + str.tostring(_rl_rp.n_eff, "#.#") + "  (higher = more data support)"
    float _rl_atr_safe = nz(regime_hold_atr, ta.atr(14))
    float _rl_label_y = _rl_bias == "BULL" ? low - _rl_atr_safe * 0.35 : _rl_bias == "BEAR" ? high + _rl_atr_safe * 0.35 : close
    // — Changepoint label at every regime transition —
    if _rl_k != _rl_prev_k and _rl_prev_k != -1
        label.new(bar_index, _rl_label_y, "R" + str.tostring(_rl_k),
             xloc=xloc.bar_index, yloc=yloc.price,
             color=_rl_col, textcolor=_rl_txt_col,
             style=_rl_bias == "BULL" ? label.style_label_up : _rl_bias == "BEAR" ? label.style_label_down : label.style_label_center, size=size.small,
             tooltip=_rl_tip_str, force_overlay=true)
    _rl_prev_k := _rl_k
    // — Persistent "now" label at right edge —
    string _rl_now_text = "R" + str.tostring(_rl_k)
    if na(_rl_now_lbl)
        _rl_now_lbl := label.new(bar_index, _rl_label_y, _rl_now_text,
             xloc=xloc.bar_index, yloc=yloc.price,
             color=_rl_col, textcolor=_rl_txt_col,
             style=_rl_bias == "BULL" ? label.style_label_up : _rl_bias == "BEAR" ? label.style_label_down : label.style_label_left, size=size.small,
             tooltip=_rl_tip_str, force_overlay=true)
    else
        label.set_x(_rl_now_lbl, bar_index)
        label.set_y(_rl_now_lbl, _rl_label_y)
        label.set_yloc(_rl_now_lbl, yloc.price)
        label.set_style(_rl_now_lbl, _rl_bias == "BULL" ? label.style_label_up : _rl_bias == "BEAR" ? label.style_label_down : label.style_label_left)
        label.set_text(_rl_now_lbl, _rl_now_text)
        label.set_color(_rl_now_lbl, _rl_col)
        label.set_textcolor(_rl_now_lbl, _rl_txt_col)
        label.set_tooltip(_rl_now_lbl, _rl_tip_str)
    if barstate.islast and (na(_rl_last_logged_bar) or _rl_last_logged_bar != bar_index)
        log.info("RLABEL,bar=" + str.tostring(bar_index) + ",regime=R" + str.tostring(_rl_k) + ",bias=" + _rl_bias + ",start_price=" + str.tostring(_rl_start_price, format.mintick) + ",end_price=" + str.tostring(_rl_end_price, format.mintick) + ",change_pct=" + _rl_chg_txt + ",start_bar=" + str.tostring(_rl_start_bar) + ",age=" + str.tostring(_rl_age))
        _rl_last_logged_bar := bar_index

// ─── OLS Rolling Betas: BTC returns on macro factor returns ───────────────
// Diagnostic-only. Not fed to SSSM. Export for v2-feature audit.
// v2 FIX: clip factor-return inputs to ±D_CLIP before OLS to prevent spike leakage.
//         F1/F2/F3 z-scores occasionally spike to ±70-80 (transition bars);
//         their first-difference then explodes the OLS slope by ~1000x.
int    BETA_WIN = input.int(300, "Beta Window (bars)", minval=50, group="Beta Diag")
float  D_CLIP   = input.float(5.0, "Factor-return clip (±)", minval=1.0, step=0.5, group="Beta Diag", tooltip="Winsorize factor first-differences before OLS. Blocks z-score spike bars from blowing up the rolling slope.")
float  btc_ret2  = math.log(math.max(close / math.max(close[1], 1e-5), 1e-5))

// Helper: OLS slope of y ~ x over a rolling window. Denominator-guarded.
f_ols_beta(float x_src, float y_src, int win) =>
    float sx    = math.sum(nz(x_src), win)
    float sy    = math.sum(nz(y_src), win)
    float sxx   = math.sum(nz(x_src) * nz(x_src), win)
    float sxy   = math.sum(nz(x_src) * nz(y_src), win)
    float denom = float(win) * sxx - sx * sx
    math.abs(denom) > 1e-10 ? (float(win) * sxy - sx * sy) / denom : 0.0

// Factor returns (first-difference of z-scored signals), WINSORIZED at ±D_CLIP.
float d_horc = math.max(-D_CLIP, math.min(D_CLIP, nz(z_horc) - nz(z_horc[1])))
float d_bei  = math.max(-D_CLIP, math.min(D_CLIP, nz(z_bei)  - nz(z_bei[1])))

float b_horc_raw = f_ols_beta(d_horc, btc_ret2, BETA_WIN)
float b_bei_raw  = f_ols_beta(d_bei,  btc_ret2, BETA_WIN)

// Optional post-clip on the slope itself as a second safety net (mirrors v2 ±0.02 on horc).
float b_horc_clip = math.max(-0.02, math.min(0.02, b_horc_raw))

// rvol: realized vol = sqrt of rolling mean squared log-returns (confirmed correct).
int   RVOL_WIN = input.int(20, "RVol Window (bars)", minval=5, group="Beta Diag")
float rvol_val = math.sqrt(math.max(ta.sma(btc_ret2 * btc_ret2, RVOL_WIN), 0.0))

// ─── Export ──────────────────────────────────────────────────────────────
plot(regime_hold_score, "regime.hold_score", display=display.data_window, force_overlay=false)
plot(regime_hold_slope, "regime.hold_slope", display=display.data_window, force_overlay=false)
plot(b_horc_clip, "b_horc",     display=display.data_window, force_overlay=false)
plot(b_bei_raw,   "b_bei",      display=display.data_window, force_overlay=false)
plot(rvol_val,    "rvol",       display=display.data_window, force_overlay=false)
int admission_flags_pack = Log.f_encode_flags(adm_eligible_hard, adm_dwell_gate, adm_sign_gate, adm_nte_hold_gate, adm_shock_exempt, false, false, false)
plot(admission_flags_pack, "adm.flags_pack", display=display.data_window, force_overlay=false)
float health_pack_ih_eff = Log.f_pack3x10(Log.f_q_unsigned(health_i, 1023.0, 1023), Log.f_q_unsigned(health_h, 1023.0, 1023), Log.f_q_unsigned(health_eff_ratio, 1023.0, 1023))
