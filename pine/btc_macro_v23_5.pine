// PRODUCT CONTRACT: B2-B6 remain macro-only; BTC/leverage conditions only the released trading signal.
//@version=6
// Product: m3f_sssm (Macro Factor Fusion — State-Space Model)
// Version: v23.5 RELEASE — audited split 2026-07-11
// Lineage: Independent product. Not to be merged with m3f_te-research.
// Features: B2 bar-anchored K-means, B3 Hamilton forward filter, B4 online EM, B5 Π regularization, B6 Kim backward smoother, B7 semantic prior, B8 IRF (toggle-gated)
// Absent: Transfer Entropy pipeline, carry-forward decay, adaptive Kalman betas (see m3f_te-research)
//
// Changelog v0.7.7:
//   [FIX 6]  gamma_smooth export gated by sssm_seeded + b6_count >= 2 + compute_active;
//            dead/pre-seed rows emit na (never 0), keeping downstream sum-checks honest.
//   [FIX 7]  sssm.seeded export bound to live sssm_seeded var (was already correct; explicit).
//   [NEW]    Parallel full-Kim ground-truth label column: gamma_kim_gt_0..5 (KIM_GT_H=6).
//            Emit-at-bar-t semantics: value at bar t is the smoothed posterior for bar t-6.
//            Python builder shifts the column forward by 6 so corpus row i describes bar i.
//            Uses rolling matrix.copy(sssm.Pi) per bar (locally-consistent smoothing).
//            Ring-buffer reset on CME weekend-gap session transition (Fri 22:00 UTC –
//            Sun 22:00 UTC). Leading / trailing / post-transition bars emit na. Label-side
//            only — not in E56 tensor. Live 1-step B6 path untouched.
//   [RETAIN] D_CLIP=5 winsorization on d_vix/d_horc/d_bei (spike-leakage fix).
//   [RETAIN] posterior export block: gamma_smooth_0..5, alpha_filt_0..5, gamma_smooth_entropy.
//
// Changelog v0.7.6:
//   [MAIN FIX] q_alpha 2.0 → 1.0 — sharpened likelihood, eliminated posterior over-diffusion
//   [NEW]      signal_confidence = margin^0.6 · neff^0.2 · smooth^0.2 (core deliverable)
//   [NEW]      export cols: signal_confidence, n_eff_active, conf_margin, conf_neff
//   [FIX 5]    LL clamp at -10; [FIX 4] GAMMA_FLOOR=3e-4 — retained
//   [TUNED]    EM_REG=0.08 / SHRINKAGE=0.05 optimal (0.06/0.03 no gain, raised saturation)
//
// Frozen parameters: q_alpha=1.0  EM_REG=0.08  SHRINKAGE=0.05  GAMMA_FLOOR=3e-4
//                    LL_clamp=-10  kxm_seed=42  K=6
//////////////test3
// Acceptance (4000 confirmed bars per TF):
//                  15m      30m      60m     target
// active regimes   6/6      6/6      6/6     6/6      PASS
// margin           0.136    0.368    0.439   >0.15    15m soft-spot*
// p_active         0.390    0.584    0.632   0.45+    15m soft-spot*
// top-2 mass       0.645    0.820    0.848   >0.70    15m soft-spot*
// flat%            29.2     6.6      7.1     <25      15m soft-spot*
// pmax saturation  0.00     0.31     0.17    <5%      PASS
// switch%          3.92     5.62     5.75    3–7%     PASS
// LL min/spikes    -10/0    -10/0    -10/0   >-10     PASS
// confidence med   0.251    0.504    0.563   —        PASS
// trust >0.3       45%      71%      74%     —        PASS
// * 15m soft-spot: noisier TF, lower SNR → softer posterior. NOT a blocker.
//
// Verification gates — ALL GREEN:
//   B8 toggle-invariance: posterior_active & log_likelihood bit-exact (max|Δ|=0.00e+00 all TF)
//   active_regime divergences: 0 (NaN-warmup excluded)
//   MD5 baseline (confirmed bars, time+regime+posterior+LL+confidence):
//     15m: 9f214b8029a6651af2040c0d3dbcbbcb
//     30m: 815d963250c6f9f756707365b31ab5a8
//     60m: ce12a73970187a04f18f473796178907
//   MD5(B8=true) == MD5(B8=false) on all TF → B8 confirmed read-only
//   Artifact: m3f_v076_md5_baseline.json
//   B2 determinism: seed0=226, centroid_0=[-0.14, -0.322, -2.435]
indicator("BTC-conditioned Macro v23.5", shorttitle="btccondMacro v23.5", overlay=true, precision=2, max_labels_count=500, max_lines_count=100, max_bars_back=4500)
import cybermediaboy/CyberCausalityLib/7 as CL
import cybermediaboy/BasketLib/6 as BL
import cybermediaboy/LogLib/16 as Log
import cybermediaboy/KalmanEngineLib/6 as KE
import cybermediaboy/CyberLearningLib/6 as LRN
import cybermediaboy/CyberNumLib/3 as N
import cybermediaboy/CyberRegimeLib/1 as RG

// ───────── AE BAR SPAN ─────────
string GRP_SPAN  = "AE Bar Span"
int  iAeSpan    = input.int(4500, "Bars Back", minval=200, maxval=20000, step=100, group=GRP_SPAN, tooltip="Bars back from the last bar over which this indicator fetches data, computes, and emits valid export codes.")
te_hist_bars_in   = input.int(4000, "TE History Bars", minval=200, maxval=10000, step=100, group=GRP_SPAN)



int aeSpanBack  = math.max(200, iAeSpan)

// Replay-safe anchor: tracks the highest bar_index seen = replay playhead.
// In live mode this equals last_bar_index. In replay mode it slides with the cursor.
var int replayAnchor = 0
replayAnchor := math.max(replayAnchor, bar_index)

bool inAeSpan   = bar_index >= replayAnchor - aeSpanBack

mode_in           = input.string("run", "Mode", options=["training","run","diagnostic"], group="Mode")
retrain_threshold = input.int(1000, "Retrain staleness bars", minval=100, group="Mode")

frozen_in = input.text_area("", "Frozen centroids", group="Seed")
frozen_mode = input.string("Freeze only", "Frozen centroid mode", options=["Freeze only", "Learn after load"], group="Seed")
frozen_pack_mode = input.string("Plain", "Frozen centroid payload", options=["Plain", "Hex packed"], group="Seed")
adm_online_mode = input.string("Freeze", "Online adaptation mode", options=["Freeze", "RefitKeepBest", "Free"], group="Seed")
refit_update_frequency = input.int(100, "Refit/update frequency bars", minval=25, maxval=1000, step=25, group="Seed")
refit_prior_cap = input.float(75.0, "Refit prior cap", minval=0.0, maxval=1000.0, step=25.0, group="Seed")
health_baseline_sil_bar = input.float(0.197, "Health baseline sil_bar", minval=-1.0, maxval=1.0, step=0.001, group="Seed")
health_baseline_sil_maha = input.float(0.197, "Health baseline sil_M", minval=-1.0, maxval=1.0, step=0.001, group="Seed")
health_accept_epsilon = input.float(0.01, "Health accept epsilon", minval=0.0, maxval=0.10, step=0.005, group="Seed")
bool run_freeze_centroids = adm_online_mode == "Freeze"
bool use_frozen = mode_in == "run" and str.length(str.replace_all(str.replace_all(frozen_in, "\n", ""), " ", "")) > 10



K_REG_IN   = input.int(6, "Hidden Regimes", minval=3, maxval=9, group="SSSM")
EM_TICK    = input.int(50, "EM Throttle Ticks", minval=10, group="SSSM")
delta_hyst = input.float(0.10, "Regime switch margin", minval=0.0, maxval=0.50, step=0.05, group="SSSM")
hyst_bars  = input.int(3, "Min bars between switches", minval=0, maxval=20, group="SSSM")
q_alpha    = input.float(1.0, "Adaptive Q sensitivity", step=0.5, group="SSSM")
W_Z       = input.int(200, "Z-score Window", minval=50, group="Factors")
factor_smooth_mode_in = input.string("Double", "Factor smoothing mode", options=["Raw", "Double", "EMA"], group="Factors")
W_TE      = input.int(500, "TE/Granger Window", minval=200, group="Causality")
alpha_sig = input.float(0.10, "Granger alpha threshold", step=0.01, group="Causality")
if barstate.isfirst and aeSpanBack < W_TE + 200
    log.info("AEWARN m3f compute " + str.tostring(aeSpanBack) + " < WTE+200 (" + str.tostring(W_TE + 200) + ") — K-means may not seed; directional codes will not emit.")
// B8 isolation toggles (v0.7.5 diagnostic)
bool b8_enabled = true
bool b8_udt_enabled = true
H_VOL      = input.int(48, "IRF VIX horizon", minval=10, group="IRF")
H_HORC     = input.int(240, "IRF HORC horizon", minval=10, group="IRF")
H_BEI      = input.int(480, "IRF BEI horizon", minval=10, group="IRF")
irf_scale  = input.float(1.0, "IRF blend scale",  minval=0.0, step=0.1, group="IRF")
irf_w_vix  = input.float(0.333, "IRF VIX weight",  minval=0.0, maxval=1.0, step=0.05, group="IRF")
irf_w_horc = input.float(0.333, "IRF HORC weight", minval=0.0, maxval=1.0, step=0.05, group="IRF")
irf_w_bei  = input.float(0.334, "IRF BEI weight",  minval=0.0, maxval=1.0, step=0.05, group="IRF")
irf_preset      = input.string("Custom", "IRF Preset", options=["Custom","BTC-30m","Aggressive","Stable"], group="IRF", tooltip="Preset overrides all IRF parameters below when not Custom. BTC-30m: fast 30m profile. Aggressive: early turning-point. Stable: low-noise.")
irf_anchor_len  = input.int(100,    "Anchor Length",     minval=10,     group="IRF")
irf_fwd_h       = input.int(6,      "IRF Fwd Horizon",  minval=1, maxval=50,  group="IRF", tooltip="Lookahead-free: beta estimated from past realized returns over this window.")
irf_beta_len    = input.int(300,    "IRF Beta Window",  minval=50,     group="IRF")
irf_atr_cap     = input.float(3.0,  "Max Lead ATR cap", minval=0.5, step=0.25, group="IRF")
