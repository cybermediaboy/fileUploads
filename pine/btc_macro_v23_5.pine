irf_kal_r       = input.float(0.01,   "Kalman R", minval=0.001,   step=0.001,  group="IRF")
// IRF preset effective values — preset ≠ "Custom" overrides individual inputs below
int   _eff_hvol    = irf_preset == "BTC-30m" ? 24  : irf_preset == "Aggressive" ? 16  : irf_preset == "Stable" ? 36  : H_VOL
int   _eff_hhorc   = irf_preset == "BTC-30m" ? 96  : irf_preset == "Aggressive" ? 72  : irf_preset == "Stable" ? 144 : H_HORC
int   _eff_hbei    = irf_preset == "BTC-30m" ? 192 : irf_preset == "Aggressive" ? 144 : irf_preset == "Stable" ? 288 : H_BEI
float _eff_scale   = irf_preset == "BTC-30m" ? 0.35 : irf_preset == "Aggressive" ? 0.25 : irf_preset == "Stable" ? 0.50 : irf_scale
float _eff_wvix    = irf_preset == "BTC-30m" ? 0.50 : irf_preset == "Aggressive" ? 0.60 : irf_preset == "Stable" ? 0.45 : irf_w_vix
float _eff_whorc   = irf_preset == "BTC-30m" ? 0.30 : irf_preset == "Aggressive" ? 0.25 : irf_preset == "Stable" ? 0.35 : irf_w_horc
float _eff_wbei    = irf_preset == "BTC-30m" ? 0.20 : irf_preset == "Aggressive" ? 0.15 : irf_preset == "Stable" ? 0.20 : irf_w_bei
int   _eff_anclen  = irf_preset == "BTC-30m" ? 80  : irf_preset == "Aggressive" ? 60  : irf_preset == "Stable" ? 120 : irf_anchor_len
int   _eff_fwdh    = irf_preset == "BTC-30m" ? 6   : irf_preset == "Aggressive" ? 4   : irf_preset == "Stable" ? 8   : irf_fwd_h
int   _eff_betalen = irf_preset == "BTC-30m" ? 220 : irf_preset == "Aggressive" ? 160 : irf_preset == "Stable" ? 300 : irf_beta_len
float _eff_atrcp   = irf_preset == "BTC-30m" ? 2.5 : irf_preset == "Aggressive" ? 3.0 : irf_preset == "Stable" ? 2.0 : irf_atr_cap
float _eff_kalq    = irf_preset == "BTC-30m" ? 0.0002 : irf_preset == "Aggressive" ? 0.0003 : irf_preset == "Stable" ? 0.0001 : irf_kal_q
float _eff_kalr    = irf_preset == "BTC-30m" ? 0.008 : irf_preset == "Aggressive" ? 0.006 : irf_preset == "Stable" ? 0.012 : irf_kal_r
TRAIN_CHUNK = input.int(100, "Training chunk size", minval=20, group="Training")
KM_ITERS    = input.int(20, "K-means iterations", minval=5, group="Training")
em_passes   = input.int(5, "EM passes", minval=1, group="Training")
KIM_WINDOW  = input.int(1000, "Kim smoother window", minval=100, group="Training")
km_seed     = input.int(42, "K-means RNG seed", group="Determinism", tooltip="Seed for K-means++ centroid initialization. Change to test seed sensitivity. Default 42.")
b2_anchor_bar_offset = input.int(-1, "B2 anchor bar offset", minval=-1, group="Determinism", tooltip="Bar offset from last_bar_index for B2 K-means gate. -1 = session-coupled (fires when rb full). ≥0 = bar-anchored (fires at last_bar_index - offset). Use ≥500 for cross-session determinism.")
b2_min_na_coverage = input.float(0.95, "B2 min non-NA coverage", minval=0.5, maxval=1.0, step=0.05, group="Determinism", tooltip="Minimum fraction of non-NA bars required in K-means sample window. Prevents NA-contaminated centroids.")
b2_min_seed_sep_in = input.float(1.5, "B2 min centroid separation", minval=0.0, maxval=3.0, step=0.1, group="Determinism")
b2_repulse_lambda_in = input.float(0.0, "B2 centroid repulsion", minval=0.0, maxval=0.50, step=0.01, group="Determinism")
em_mu_anchor_in = input.float(0.0, "B5 EM mu-seed anchor (kappa)", minval=0.0, maxval=1.0, step=0.05, group="Determinism", tooltip="MAP prior pulling each EM centroid toward its B2 seed each M-step. 0=pure online EM. Preset-overridable.")
// Regime Admission v0.7.18-final LOCKED config:
//   HARD AND gate: dwell>=2 AND sign==5/5 (lev-residualized vel) AND hold_3of5>=0.50
//   resid_lev_factors=on: F1/F2/F3 residualized vs lev.z_price_delta before B2/B5
//   F5 excluded from classification. Reprice-shock catch-up path exempt from dwell.
//   Targets (C02): sil_ctr≈+0.17, sep≈1.32, min_occ≈0.19, sil_bar≈0.33
adm_mode_in        = input.string("HARD", "Adm mode",              options=["SOFT", "HARD"], group="Regime Admission", tooltip="HARD (default, locked): binary AND gate — min_dwell=2 AND sign_k/x=5/5 AND hold_3of5>=tau. SOFT: continuous weight w_t = sign_frac^2 * dwell_frac * hold_ma5.")
adm_min_dwell_in   = input.int(2,    "Adm min dwell",             minval=1, maxval=20,  group="Regime Admission", tooltip="HARD minimum consecutive bars in active regime. Locked dispatch value: 2.")
adm_use_sign_gate_in = input.bool(true, "Use sign gate",           group="Regime Admission", tooltip="HARD gate component. Locked on: leverage-residualized price velocity must agree with macro direction.")
adm_sign_k_in      = input.int(5,    "Adm sign min count (k)",    minval=1, maxval=20,  group="Regime Admission", tooltip="HARD sign gate k in k/x. Locked dispatch value: 5.")
adm_sign_win_in    = input.int(5,    "Adm sign window (x)",       minval=2, maxval=20,  group="Regime Admission", tooltip="HARD sign gate x in k/x. Locked dispatch value: 5; requires 5/5 agreement.")
string adm_gate_logic = input.string("AND", "Adm gate logic", options=["AND"], group="Regime Admission", tooltip="Locked dispatch value: AND. HARD requires min_dwell AND sign gate AND NTE hold gate.")
adm_dwell_sat_in   = input.int(5,    "Adm dwell saturation (SOFT)", minval=1, maxval=20, group="Regime Admission", tooltip="SOFT-only dwell ramp saturation. HARD uses Adm min dwell.")
adm_use_hold_gate_in = input.bool(true, "Use NTE hold gate",       group="Regime Admission", tooltip="HARD gate component. Locked on: hold score must be sustained k-of-window.")
adm_hold_ma_win_in = input.int(5,    "Adm hold-count window",     minval=1, maxval=20,  group="Regime Admission", tooltip="HARD hold gate window. Locked dispatch value: 5.")
adm_hold_k_in      = input.int(3,    "Adm hold min count (k)",    minval=1, maxval=20,  group="Regime Admission", tooltip="HARD hold gate k in sustained k-of-window. Locked dispatch value: 3-of-5.")
adm_hard_hold_tau_in = input.float(0.50, "Adm hold tau",           minval=0.0, maxval=1.0, step=0.05, group="Regime Admission", tooltip="HARD hold score threshold. Locked dispatch value: 0.50.")
adm_denoise_lev_in = input.bool(true, "Adm residualize lev factors", group="Regime Admission", tooltip="resid_lev_factors=on: residualize F1/F2/F3 vs lev.z_price_delta before B2/B5 and sign test.")
adm_min_samples_in = input.int(20,   "Adm min samples fallback",  minval=5, maxval=100,  group="Regime Admission", tooltip="Fallback retained. If admitted B2 count or B5 n_eff falls below this, gating is bypassed for that regime.")



ramp_alpha = input.float(0.10, "Handover Ramp alpha", minval=0.01, maxval=0.50, step=0.01, group="Handover")
show_regime = input.bool(true,  "Show regime label",       group="Display")
show_comp   = input.bool(false, "Show factor components",  group="Display")
irf_price_display = input.string("Magnet + Projection", "IRF price display", options=["Off", "Magnet", "Projection", "Magnet + Projection"], group="Display")
show_nw_bands = input.bool(true, "Show regime NW price bands", group="Display")
hold_line_on = input.bool(true, "Show regime-hold monitor", group="Display")
pred_lag    = input.int(6, "Forward projection bars", minval=1, maxval=30, group="Display")
show_debug  = input.bool(false, "Debug data window",       group="Debug")
diag_table_on = input.bool(true, "Show diagnostic table", group="Diagnostics")
diag_table_window = input.int(240, "Variance window", minval=50, maxval=1000, group="Diagnostics")
diag_h1 = input.int(1, "BTC horizon 1", minval=1, maxval=100, group="Diagnostics")
diag_h2 = input.int(3, "BTC horizon 2", minval=1, maxval=100, group="Diagnostics")
diag_h3 = input.int(6, "BTC horizon 3", minval=1, maxval=100, group="Diagnostics")
diag_h4 = input.int(12, "BTC horizon 4", minval=1, maxval=100, group="Diagnostics")
nw_mode = input.string("Regime-normal reversal zones", "NW basis mode", options=["Now price NW", "Regime-normal reversal zones"], group="Regime NW Bands")
nw_center_mode = input.string("Current line", "NW center", options=["Current line", "IRF median", "IRF line"], group="Regime NW Bands")
