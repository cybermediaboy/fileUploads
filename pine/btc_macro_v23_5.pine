nw_kpv_enable = input.bool(true, "Color NW median with Kalman velocity", group="NW Kalman Price Velocity")
nw_kpv_use_band_pos_in = input.bool(false, "Use signed band z-position", group="NW Kalman Price Velocity")
nw_kpv_q_pos = input.float(0.001, "Q position", minval=0.0001, maxval=0.05, step=0.0001, group="NW Kalman Price Velocity")
