int active_sigma_f2_q8 = Log.f_q_unsigned(sssm_seeded ? matrix.get(active_export_regime.Sigma, 1, 1) : na, 32.0, 255)
int active_sigma_f3_q8 = Log.f_q_unsigned(sssm_seeded ? matrix.get(active_export_regime.Sigma, 2, 2) : na, 32.0, 255)
