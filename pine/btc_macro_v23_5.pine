int te_hist_bars  = math.max(te_hist_bars_in, aeSpanBack)
ete_recompute     = input.int(5, "ETE Cadence", minval=1, maxval=20, group="TE")
te_beta_thr       = input.float(0.0002, "NTE Gate Threshold", minval=0.0, maxval=0.02, step=0.0001, group="TE")
te_slow_len       = input.int(50, "NTE Slow EMA Len", minval=10, maxval=100, group="TE")
gs_enable         = input.bool(true, "GS Orthogonalize", group="TE")
gs_win            = input.int(100, "GS Window", minval=30, maxval=500, group="TE")
int B6_HORIZON = 100
int KIM_GT_H      = 6  // Hard constant: full-Kim ground-truth look-ahead. Changing it requires a corpus rebuild and MD5 rebaseline of the label column.
// INVARIANT: KIM_GT_H must be <= B6_HORIZON.
// B6_HORIZON is the ring buffer capacity (default 100); KIM_GT_H=6 is the look-ahead depth.
// If KIM_GT_H > B6_HORIZON the backward pass would read uninitialized ring slots.
// Violation collapses gamma_kim_gt_0..5 to na across the entire panel,
// detectable as an all-null column in the exported CSV.
// This is the Pine-v6-enforceable equivalent of a compile-time assert.
bool _kim_gt_inv_ok = KIM_GT_H <= B6_HORIZON  // false → gkg_valid permanently false → all gamma_kim_gt_* = na
vix_fast = input.int(10,  "VIX Fast SS",   minval=3,  group="VIX")
