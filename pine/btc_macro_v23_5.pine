int active_mu_f2_q8 = Log.f_q_signed(sssm_seeded ? array.get(active_export_regime.mu, 1) : na, 32.0, 128, 255)
int active_mu_f3_q8 = Log.f_q_signed(sssm_seeded ? array.get(active_export_regime.mu, 2) : na, 32.0, 128, 255)
int active_mu_f5_q8 = Log.f_q_signed(sssm_seeded ? array.get(active_export_regime.mu, 4) : na, 32.0, 128, 255)
