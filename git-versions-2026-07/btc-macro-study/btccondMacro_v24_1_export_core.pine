    log.info("RAW_A,bar=" + str.tostring(bar_index) + ",time=" + str.tostring(time) + ",replay_chunk_id=" + str.tostring(replay_chunk_id_in) + ",K=" + str.tostring(K_REG) + ",valid=" + str.tostring(enriched_valid_now ? 1 : 0) + ",a0=" + str.tostring(N.f_safe_get_f(alpha_filt, 0), "#.########") + ",a1=" + str.tostring(N.f_safe_get_f(alpha_filt, 1), "#.########") + ",a2=" + str.tostring(N.f_safe_get_f(alpha_filt, 2), "#.########") + ",a3=" + str.tostring(N.f_safe_get_f(alpha_filt, 3), "#.########") + ",a4=" + str.tostring(N.f_safe_get_f(alpha_filt, 4), "#.########") + ",a5=" + str.tostring(N.f_safe_get_f(alpha_filt, 5), "#.########") + ",a6=" + str.tostring(N.f_safe_get_f(alpha_filt, 6), "#.########") + ",a7=" + str.tostring(N.f_safe_get_f(alpha_filt, 7), "#.########") + ",a8=" + str.tostring(N.f_safe_get_f(alpha_filt, 8), "#.########") + ",f1_raw=" + str.tostring(-z_vix_raw, "#.########") + ",f2_raw=" + str.tostring(z_horc_raw, "#.########") + ",f3_raw=" + str.tostring(z_bei_raw, "#.########") + ",f1_smooth=" + str.tostring(F1_model, "#.########") + ",f2_smooth=" + str.tostring(F2_model, "#.########") + ",f3_smooth=" + str.tostring(F3_model, "#.########") + ",f1_innov=" + str.tostring(F1_model - nz(F1_model[1], F1_model), "#.########") + ",f2_innov=" + str.tostring(F2_model - nz(F2_model[1], F2_model), "#.########") + ",f3_innov=" + str.tostring(F3_model - nz(F3_model[1], F3_model), "#.########"))
    log.info("RAW_B,bar=" + str.tostring(bar_index) + ",time=" + str.tostring(time) + ",replay_chunk_id=" + str.tostring(replay_chunk_id_in) + ",active_regime=" + str.tostring(sssm.active_regime) + ",regime_age=" + str.tostring(regime_age) + ",mu_f1=" + str.tostring(_raw_log_mu_f1, "#.########") + ",mu_f2=" + str.tostring(_raw_log_mu_f2, "#.########") + ",mu_f3=" + str.tostring(_raw_log_mu_f3, "#.########") + ",regime_factor_dynamics=" + _raw_log_regime_factor_dynamics + ",sil_maha=" + str.tostring(sil_ctr_maha, "#.########") + ",sil_euclid=" + str.tostring(sil_ctr_euclid, "#.########") + ",sep_min=" + str.tostring(health_sep_min, "#.########") + ",sep_bad=" + str.tostring(health_sep_bad) + ",eff_ratio=" + str.tostring(health_eff_ratio, "#.########") + ",health_i=" + str.tostring(health_i, "#.########") + ",mobs_median=" + str.tostring(mobs_median, "#.########") + ",leverage_oi_z=" + str.tostring(lvg.z_oi, "#.########") + ",leverage_oi_delta_z=" + str.tostring(lvg.z_oid, "#.########") + ",funding_z=" + str.tostring(lvg.z_fund_raw, "#.########") + ",price_shock_z=" + str.tostring(lvg.z_price_delta, "#.########") + ",leverage_score=" + str.tostring(lvg.score, "#.########") + ",leverage_phase=" + str.tostring(lvg.phase) + ",btc_log_return=" + str.tostring(btc_ret_raw, "#.########") + ",btc_volatility=" + str.tostring(btc_vol_ema, "#.########"))
    log.info("RAW_C,bar=" + str.tostring(bar_index) + ",time=" + str.tostring(time) + ",replay_chunk_id=" + str.tostring(replay_chunk_id_in) + ",te_fwd_vix=" + str.tostring(ste_vix_f.ete_held, "#.########") + ",te_fwd_horc=" + str.tostring(ste_horc_f.ete_held, "#.########") + ",te_fwd_bei=" + str.tostring(ste_bei_f.ete_held, "#.########") + ",te_rev_vix=" + str.tostring(ste_vix_r.ete_held, "#.########") + ",te_rev_horc=" + str.tostring(ste_horc_r.ete_held, "#.########") + ",te_rev_bei=" + str.tostring(ste_bei_r.ete_held, "#.########") + ",nte_vix=" + str.tostring(nte_vix, "#.########") + ",nte_horc=" + str.tostring(nte_horc, "#.########") + ",nte_bei=" + str.tostring(nte_bei, "#.########") + ",te_conf_vix=" + str.tostring(te_granger_conf_vix, "#.########") + ",te_conf_horc=" + str.tostring(te_granger_conf_horc, "#.########") + ",te_conf_bei=" + str.tostring(te_granger_conf_bei, "#.########") + ",te_lag_vix=" + str.tostring(lag_vix) + ",te_lag_horc=" + str.tostring(lag_horc) + ",te_lag_bei=" + str.tostring(lag_bei) + ",admission_weight=" + str.tostring(adm_weight_now, "#.########") + ",admission_eligible=" + str.tostring(adm_eligible_hard ? 1 : 0) + ",te_stale_vix=" + str.tostring(ste_vix_f.bars_since_recomp) + ",te_stale_horc=" + str.tostring(ste_horc_f.bars_since_recomp) + ",te_stale_bei=" + str.tostring(ste_bei_f.bars_since_recomp) + ",te_active=" + str.tostring(te_active ? 1 : 0) + ",session_gap=" + str.tostring(_raw_log_session_gap ? 1 : 0) + ",seeded=" + str.tostring(sssm_seeded ? 1 : 0) + ",warmup=" + str.tostring(b6_warmup ? 1 : 0) + ",valid=" + str.tostring(enriched_valid_now ? 1 : 0))
